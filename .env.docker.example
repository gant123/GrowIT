# Copy to .env and fill in real values before running `docker compose up`.
# .env is gitignored; this template is safe to commit.

# --- Postgres ---
POSTGRES_DB=GrowIT
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5433

# --- Web host ---
CLIENT_PORT=5180
CLIENT_URL=https://beta.growit.now
INTERNAL_API_BASE_URL=http://localhost:8080

# --- Database startup ---
# When true, the app applies EF migrations and bootstraps roles + the SuperAdmin on
# startup. Recommended for beta deploys; set false if you migrate out-of-band.
DATABASE_AUTOMIGRATE=true

# --- Auth / JWT (generate a long random key) ---
JWT_KEY=ChangeMe-Set-A-Long-Random-Key-Before-Beta

# --- Single platform SuperAdmin ---
# The account elevated to SuperAdmin during identity bootstrap. Leave blank to skip
# (bootstrap logs a warning and provisions no SuperAdmin). The user must already exist.
SUPER_ADMIN_EMAIL=

# --- Licensing ---
SYNCFUSION_LICENSE=

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=

# --- Email / Resend ---
EMAIL_RESEND_API_KEY=
EMAIL_RESEND_BASE_URL=https://api.resend.com
EMAIL_FROM_EMAIL=noreply@growit.local
EMAIL_FROM_NAME=grow.IT
EMAIL_TIMEOUT_MS=10000
EMAIL_DEV_FILE_FALLBACK_ENABLED=false

# --- Reports scheduler ---
REPORT_SCHEDULER_ENABLED=true
REPORT_SCHEDULER_POLL_SECONDS=60
REPORT_SCHEDULER_MAX_PER_CYCLE=20
REPORT_SCHEDULER_DEFAULT_TYPE=impact-summary
REPORT_SCHEDULER_DEFAULT_FORMAT=pdf
