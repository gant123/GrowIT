# Copy this file to .env and update values before running docker compose.

POSTGRES_DB=GrowIT
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433

CLIENT_PORT=5180
CLIENT_URL=https://beta-growit.ganthome.cloud

JWT_KEY=change-me-to-a-long-random-secret-for-beta

EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USE_SSL=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_EMAIL=noreply@beta-growit.ganthome.cloud
EMAIL_TIMEOUT_MS=10000
EMAIL_DEV_FILE_FALLBACK_ENABLED=false

REPORT_SCHEDULER_ENABLED=true
REPORT_SCHEDULER_POLL_SECONDS=60
REPORT_SCHEDULER_MAX_PER_CYCLE=20
REPORT_SCHEDULER_DEFAULT_TYPE=impact-summary
REPORT_SCHEDULER_DEFAULT_FORMAT=pdf
