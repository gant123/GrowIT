{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ClientUrl": "https://your-client-hostname.example",
  "Cors": {
    "AllowedOrigins": [
      "https://your-client-hostname.example"
    ]
  },
  "Reports": {
    "Scheduler": {
      "Enabled": true,
      "PollSeconds": 60,
      "MaxSchedulesPerCycle": 25,
      "DefaultReportType": "impact-summary",
      "DefaultFormat": "pdf"
    }
  },
  "Email": {
    "SmtpHost": "smtp.your-provider.com",
    "SmtpPort": "587",
    "UseSsl": "true",
    "TimeoutMs": "15000",
    "SmtpUser": "",
    "SmtpPass": "",
    "FromEmail": "no-reply@yourdomain.com",
    "DevFileFallbackEnabled": "false"
  }
}
