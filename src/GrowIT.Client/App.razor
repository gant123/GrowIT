@using static Microsoft.AspNetCore.Components.Web.RenderMode

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="application-name" content="grow.IT" />
    <meta name="apple-mobile-web-app-title" content="grow.IT" />
    <meta name="apple-mobile-web-app-capable" content="yes" />

    <base href="/" />

    <title>grow.IT - Nonprofit Impact Management</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/png" sizes="32x32" href="favicon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="icon-512.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="icon-192.png" />
    <link rel="manifest" href="manifest.webmanifest" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/open-iconic/1.1.1/font/css/open-iconic-bootstrap.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="_content/Syncfusion.Blazor.Themes/bootstrap5.css" />

    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="css/layout.css" />
    <link rel="stylesheet" href="css/pages.css" />
    <link rel="stylesheet" href="css/public.css?v=20260227-4" />
    <link rel="stylesheet" href="css/enterprise-overrides.css" />
    <link rel="stylesheet" href="css/syncfusion-overrides.css" />
    <link rel="stylesheet" href="GrowIT.Client.styles.css" />

    <script>
        (function () {
            try {
                var theme = localStorage.getItem('growit-theme');
                if (theme === 'dark' || theme === 'light') {
                    document.documentElement.setAttribute('data-theme', theme);
                }
            } catch { }
        })();
    </script>

    <style>
        #blazor-error-ui {
            display: none;
            position: fixed;
            bottom: 1rem;
            left: 1rem;
            right: 1rem;
            z-index: 9999;
            background: #fee2e2;
            color: #7f1d1d;
            border: 1px solid #fca5a5;
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
        }

        #blazor-error-ui .error-content {
            display: flex;
            align-items: center;
            gap: 0.625rem;
            font-size: 0.9375rem;
        }

        #blazor-error-ui svg {
            width: 1rem;
            height: 1rem;
            flex: 0 0 auto;
        }

        #blazor-error-ui .reload {
            margin-left: auto;
            color: inherit;
            text-decoration: underline;
            cursor: pointer;
        }

        #blazor-error-ui .dismiss {
            margin-left: 0.5rem;
            color: inherit;
            text-decoration: underline;
            cursor: pointer;
        }

        .not-found-page .btn svg {
            width: 1rem;
            height: 1rem;
            flex: 0 0 auto;
        }
    </style>

    <HeadOutlet @rendermode="InteractiveServer" />
</head>
<body>
    <AppToastHost @rendermode="InteractiveServer" />
    <Routes @rendermode="InteractiveServer" />

    <div id="blazor-error-ui">
        <div class="error-content">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <p>An unhandled error has occurred.</p>
            <a href="" class="reload">Reload</a>
            <a class="dismiss">🗙</a>
        </div>
    </div>

    <script src="_content/Syncfusion.Blazor.Core/scripts/syncfusion-blazor.min.js"></script>
    <script src="js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
