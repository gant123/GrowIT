@using Microsoft.AspNetCore.Components.Web

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="application-name" content="grow.IT" />
    <meta name="apple-mobile-web-app-title" content="grow.IT" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="description" content="grow.IT - Transform nonprofit service into measurable impact. Track investments, document outcomes, and demonstrate your impact to funders." />

    <title>grow.IT - Nonprofit Impact Management</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="icon" type="image/png" sizes="32x32" href="favicon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="icon-192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="icon-512.png">
    <link rel="apple-touch-icon" sizes="192x192" href="icon-192.png">
    <link rel="manifest" href="manifest.webmanifest">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/open-iconic/1.1.1/font/css/open-iconic-bootstrap.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="_content/Syncfusion.Blazor.Themes/bootstrap5.css" />

    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="css/layout.css" />
    <link rel="stylesheet" href="css/pages.css" />
    <link rel="stylesheet" href="css/public.css" />
    <link rel="stylesheet" href="css/enterprise-overrides.css" />
    <link rel="stylesheet" href="css/syncfusion-overrides.css" />
    <link rel="stylesheet" href="GrowIT.Client.styles.css" />

    <base href="/" />
    <script>
        (function () {
            try {
                var theme = localStorage.getItem('growit-theme');
                if (theme === 'dark' || theme === 'light') {
                    document.documentElement.setAttribute('data-theme', theme);
                    var meta = document.querySelector('meta[name="theme-color"]');
                    if (meta) {
                        meta.setAttribute('content', theme === 'dark' ? '#020617' : '#f8fafc');
                    }
                }
            } catch (e) {
                // ignore localStorage access issues
            }
        })();
    </script>
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
</head>
<body class="app-booting">
    <div id="app-boot-splash" aria-hidden="true">
        <div class="boot-content">
            <img src="images/logo-dark.png" alt="" class="boot-logo boot-logo-light" />
            <img src="images/logo-light.png" alt="" class="boot-logo boot-logo-dark" />
            <div class="boot-brand">grow<span>.IT</span></div>
            <div class="boot-spinner"></div>
        </div>
    </div>

    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />

    <div id="blazor-error-ui">
        <div class="error-content">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <p>An unhandled error has occurred.</p>
            <a href="" class="reload">Reload</a>
            <a class="dismiss">🗙</a>
        </div>
    </div>

    <script src="_content/Syncfusion.Blazor.Core/scripts/syncfusion-blazor.min.js"></script>
    <script src="js/app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="_framework/blazor.web.js"></script>
    <script>
        (function () {
            var splash = document.getElementById('app-boot-splash');
            if (!splash) return;

            function markReady() {
                var hasLayout =
                    document.querySelector('.main-layout') ||
                    document.querySelector('.public-layout') ||
                    document.querySelector('.not-found-page') ||
                    document.querySelector('.access-denied-page');

                if (!hasLayout) return false;

                document.body.classList.add('app-ready');
                window.setTimeout(function () {
                    splash.remove();
                }, 280);
                return true;
            }

            if (markReady()) return;

            var observer = new MutationObserver(function () {
                if (markReady()) {
                    observer.disconnect();
                }
            });

            observer.observe(document.body, { childList: true, subtree: true });

            // Fallback: never keep splash forever if the observer misses.
            window.setTimeout(function () {
                document.body.classList.add('app-ready');
                observer.disconnect();
                if (document.getElementById('app-boot-splash')) {
                    splash.remove();
                }
            }, 8000);
        })();
    </script>

    <style>
        html,
        body {
            background: #f8fafc;
        }

        html[data-theme="dark"],
        html[data-theme="dark"] body {
            background: #020617;
        }

        #app-boot-splash {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background:
                radial-gradient(circle at 80% 20%, rgba(39, 176, 98, 0.08), transparent 45%),
                radial-gradient(circle at 10% 90%, rgba(50, 80, 90, 0.09), transparent 40%),
                #f8fafc;
            z-index: 9998;
            opacity: 1;
            transition: opacity 0.24s ease;
        }

        html[data-theme="dark"] #app-boot-splash {
            background:
                radial-gradient(circle at 80% 20%, rgba(39, 176, 98, 0.16), transparent 45%),
                radial-gradient(circle at 10% 90%, rgba(50, 80, 90, 0.20), transparent 40%),
                #020617;
        }

        body.app-ready #app-boot-splash {
            opacity: 0;
            pointer-events: none;
        }

        #app-boot-splash .boot-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        #app-boot-splash .boot-logo {
            width: 52px;
            height: 52px;
            object-fit: contain;
        }

        #app-boot-splash .boot-logo-dark {
            display: none;
        }

        html[data-theme="dark"] #app-boot-splash .boot-logo-light {
            display: none;
        }

        html[data-theme="dark"] #app-boot-splash .boot-logo-dark {
            display: block;
        }

        #app-boot-splash .boot-brand {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 1.24rem;
            letter-spacing: -0.01em;
            color: #32505a;
        }

        #app-boot-splash .boot-brand span {
            color: #27b062;
        }

        html[data-theme="dark"] #app-boot-splash .boot-brand {
            color: #e2e8f0;
        }

        #app-boot-splash .boot-spinner {
            width: 22px;
            height: 22px;
            border-radius: 999px;
            border: 2px solid rgba(39, 176, 98, 0.24);
            border-top-color: #27b062;
            animation: boot-spin 0.9s linear infinite;
        }

        @@keyframes boot-spin {
            to { transform: rotate(360deg); }
        }

        @@media (prefers-reduced-motion: reduce) {
            #app-boot-splash {
                transition: none;
            }

            #app-boot-splash .boot-spinner {
                animation: none;
                border-top-color: rgba(39, 176, 98, 0.24);
            }
        }

        #blazor-error-ui {
            display: none;
            position: fixed;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%);
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 12px;
            padding: 16px 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            z-index: 9999;
        }

        #blazor-error-ui .error-content {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        #blazor-error-ui svg {
            width: 24px;
            height: 24px;
            color: #dc2626;
        }

        #blazor-error-ui p {
            margin: 0;
            color: #991b1b;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        #blazor-error-ui .reload,
        #blazor-error-ui .dismiss {
            color: #dc2626;
            text-decoration: none;
            font-weight: 500;
            margin-left: 8px;
        }

        #blazor-error-ui .reload:hover {
            text-decoration: underline;
        }

        #blazor-error-ui .dismiss {
            cursor: pointer;
        }
    </style>
</body>
</html>
