@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var target = authState.User.Identity?.IsAuthenticated == true
                ? BuildRedirectTarget("/access-denied", "access-denied")
                : BuildRedirectTarget("/login", "auth-required");

            Navigation.NavigateTo(target, replace: true);
        }
    }

    private string BuildRedirectTarget(string basePath, string reason)
    {
        var current = Navigation.ToAbsoluteUri(Navigation.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(current.PathAndQuery + current.Fragment)
            ? "/"
            : $"{current.PathAndQuery}{current.Fragment}";

        return $"{basePath}?reason={Uri.EscapeDataString(reason)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    }
}
