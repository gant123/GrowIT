@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IAuthService AuthService

<div class="growit-app" data-theme="@_currentTheme">
    <!-- Sidebar Overlay for Mobile -->
    <div class="sidebar-overlay" @onclick="CloseMobileSidebar"></div>
    
    <!-- Sidebar Navigation -->
    <aside class="growit-sidebar @(_sidebarCollapsed ? "collapsed" : "")">
        <div class="sidebar-header">
            <a href="/" class="sidebar-brand">
                <img src="images/logo-@(_currentTheme).png" alt="GrowIT" class="brand-logo" />
                <span class="brand-text">grow.IT</span>
            </a>
            <button class="sidebar-collapse-btn" @onclick="ToggleSidebar" title="Toggle sidebar">
                <i class="bi bi-chevron-bar-left"></i>
            </button>
        </div>
        
        <nav class="sidebar-nav">
            <div class="nav-section">
                <div class="nav-section-label">Main</div>
                <NavLink href="/" class="nav-item" Match="NavLinkMatch.All" title="Dashboard" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-grid-1x2"></i></span>
                    <span class="nav-text">Dashboard</span>
                </NavLink>
                
                <NavLink href="/clients" class="nav-item" title="Case Files" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-people"></i></span>
                    <span class="nav-text">Case Files</span>
                </NavLink>

                <NavLink href="/households" class="nav-item" title="Households" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-house-door"></i></span>
                    <span class="nav-text">Households</span>
                </NavLink>
            </div>
            
            <div class="nav-section">
                <div class="nav-section-label">Impact</div>
                <NavLink href="/funds" class="nav-item" title="Funds" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-wallet2"></i></span>
                    <span class="nav-text">Funds</span>
                </NavLink>

                <NavLink href="/programs" class="nav-item" title="Programs" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-folder2-open"></i></span>
                    <span class="nav-text">Programs</span>
                </NavLink>

                <NavLink href="/investments" class="nav-item" title="Service Investments" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-cash-stack"></i></span>
                    <span class="nav-text">Investments</span>
                </NavLink>
                
                <NavLink href="/imprints" class="nav-item" title="Imprints" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-check2-circle"></i></span>
                    <span class="nav-text">Imprints</span>
                </NavLink>

                <NavLink href="/growth-plans" class="nav-item" title="Growth Plans" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-diagram-3"></i></span>
                    <span class="nav-text">Growth Plans</span>
                </NavLink>
            </div>
            
            <AuthorizeView Roles="Admin,Manager">
                <div class="nav-section">
                    <div class="nav-section-label">Intelligence</div>
                    <NavLink href="/reports" class="nav-item" title="Funding Readiness Reports" @onclick="HandleNavSelected">
                        <span class="nav-icon"><i class="bi bi-pie-chart"></i></span>
                        <span class="nav-text">Reports</span>
                    </NavLink>
                    
                    <NavLink href="/insights" class="nav-item" title="Insights (Beta)" @onclick="HandleNavSelected">
                        <span class="nav-icon"><i class="bi bi-activity"></i></span>
                        <span class="nav-text">Insights</span>
                        <span class="nav-badge">Beta</span>
                    </NavLink>
                </div>
            </AuthorizeView>
            
            <div class="nav-section">
                <div class="nav-section-label">System</div>
                <NavLink href="/organization" class="nav-item" title="Organization" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-building"></i></span>
                    <span class="nav-text">Organization</span>
                </NavLink>

                <NavLink href="/settings" class="nav-item" title="Settings" @onclick="HandleNavSelected">
                    <span class="nav-icon"><i class="bi bi-gear"></i></span>
                    <span class="nav-text">Settings</span>
                </NavLink>
            </div>
        </nav>
        
        <!-- User Profile Area -->
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="sidebar-user-avatar">
                    <span>@_userInitials</span>
                </div>
                <div class="sidebar-user-info">
                    <span class="sidebar-user-name">@_userName</span>
                    <span class="sidebar-user-role">@_userRole</span>
                </div>
                <button class="user-menu-btn" @onclick="ToggleUserMenu">
                    <i class="bi bi-three-dots-vertical"></i>
                </button>
            </div>
        </div>
    </aside>
    
    <!-- Main Content Area -->
    <main class="growit-main @(_sidebarCollapsed ? "sidebar-collapsed" : "")">
        <!-- Top Bar -->
        <header class="growit-topbar">
            <div class="topbar-left">
                <button class="mobile-menu-btn" @onclick="OpenMobileSidebar" title="Open menu">
                    <i class="bi bi-list"></i>
                </button>

                <div class="workspace-chip" title="Current workspace context">
                    <span class="workspace-chip-label">Founder Workspace</span>
                    <span class="workspace-chip-meta">@_userRole</span>
                </div>
                
                <nav class="breadcrumbs">
                    @foreach (var crumb in _breadcrumbs)
                    {
                        <div class="breadcrumb-item @(crumb.IsLast ? "active" : "")">
                            @if (crumb.IsLast)
                            {
                                <span>@crumb.Label</span>
                            }
                            else
                            {
                                <a href="@crumb.Href">@crumb.Label</a>
                                <span class="breadcrumb-separator">
                                    <i class="bi bi-chevron-right"></i>
                                </span>
                            }
                        </div>
                    }
                </nav>
            </div>
            
            <div class="topbar-center">
                <div class="topbar-search">
                    <div class="search-input-wrapper" @onfocusin="HandleSearchFocusIn" @onfocusout="HandleSearchFocusOut">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" placeholder="Search anything (⌘K)" 
                               @ref="_searchInput"
                               @bind="_searchQuery" @bind:event="oninput" 
                               @onkeyup="HandleSearchKeyUp" />
                        <div class="search-shortcut">⌘K</div>
                    </div>
                    @if (_showSearchSuggestions)
                    {
                        <div class="topbar-search-dropdown">
                            @if (SearchSuggestions.Any())
                            {
                                @for (var i = 0; i < SearchSuggestions.Count; i++)
                                {
                                    var item = SearchSuggestions[i];
                                    <button type="button"
                                            class="search-suggestion @(i == _highlightedSearchIndex ? "active" : "")"
                                            title="@item.Description"
                                            @onmousedown="@(() => NavigateToQuickItem(item))">
                                        <span class="suggestion-icon"><i class="@item.Icon"></i></span>
                                        <span class="suggestion-content">
                                            <span class="suggestion-label">@item.Label</span>
                                            <span class="suggestion-meta">@item.Description</span>
                                        </span>
                                        <span class="suggestion-category">@item.Category</span>
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="search-empty-state">
                                    <i class="bi bi-search"></i>
                                    <span>No quick navigation matches</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            
            <div class="topbar-right">
                <div class="topbar-actions">
                    <div class="fiscal-year-container">
                        <select @bind="_selectedFiscalYear" @bind:after="OnFiscalYearChanged" class="fiscal-select-input">
                            <option value="FY24-25">FY 2024-25</option>
                            <option value="FY23-24">FY 2023-24</option>
                            <option value="FY22-23">FY 2022-23</option>
                        </select>
                        <i class="bi bi-chevron-down select-chevron"></i>
                    </div>

                    <div class="action-divider"></div>

                    <button class="topbar-btn theme-toggle" @onclick="ToggleTheme" title="Toggle theme">
                        @if (_currentTheme == "dark")
                        {
                            <i class="bi bi-sun-fill"></i>
                        }
                        else
                        {
                            <i class="bi bi-moon-stars"></i>
                        }
                    </button>
                    
                    <div class="dropdown-container">
                        <button class="topbar-btn notifications-btn @(_notificationsOpen ? "active" : "")" @onclick="ToggleNotifications" title="Notifications">
                            <i class="bi bi-bell"></i>
                            @if (_notificationCount > 0)
                            {
                                <span class="notification-badge">@(_notificationCount > 9 ? "9+" : _notificationCount.ToString())</span>
                            }
                        </button>
                        
                        @if (_notificationsOpen)
                        {
                            <div class="topbar-dropdown notifications-dropdown">
                                <div class="dropdown-header">
                                    <h3>Notifications</h3>
                                    <button class="btn-link" @onclick="MarkNotificationsAsRead" @onclick:stopPropagation="true">Mark all as read</button>
                                </div>
                                <div class="dropdown-body">
                                    <div class="notification-item @(_notificationCount > 0 ? "unread" : "")">
                                        <div class="notification-icon success">
                                            <i class="bi bi-check2"></i>
                                        </div>
                                        <div class="notification-content">
                                            <p><strong>New Impact Documented</strong> for John Smith</p>
                                            <span class="notification-time">2 minutes ago</span>
                                        </div>
                                    </div>
                                    @if (_notificationCount > 1)
                                    {
                                        <div class="notification-item unread">
                                            <div class="notification-icon info">
                                                <i class="bi bi-info-circle"></i>
                                            </div>
                                            <div class="notification-content">
                                                <p>Grant report for <strong>FY24 Q3</strong> is ready</p>
                                                <span class="notification-time">1 hour ago</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="dropdown-footer">
                                    <a href="/notifications" @onclick="NavigateToNotifications">View all notifications</a>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="dropdown-container">
                        <button class="user-profile-btn" @onclick="ToggleUserMenu">
                            <div class="user-avatar">@_userInitials</div>
                            <i class="bi bi-chevron-down select-chevron"></i>
                        </button>
                        
                        @if (_userMenuOpen)
                        {
                            <div class="topbar-dropdown user-dropdown">
                                <div class="user-dropdown-header">
                                    <div class="user-avatar lg">@_userInitials</div>
                                    <div class="user-details">
                                        <span class="user-name">@_userName</span>
                                        <span class="user-email">@_userEmail</span>
                                    </div>
                                </div>
                                <div class="dropdown-body">
                                    <NavLink href="/profile" class="dropdown-item" @onclick="() => _userMenuOpen = false">
                                        <i class="bi bi-person-gear"></i>
                                        Profile Settings
                                    </NavLink>
                                    <NavLink href="/settings" class="dropdown-item" @onclick="() => _userMenuOpen = false">
                                        <i class="bi bi-sliders"></i>
                                        System Preferences
                                    </NavLink>
                                    <div class="dropdown-divider"></div>
                                    <button class="dropdown-item logout" @onclick="HandleLogout" @onclick:stopPropagation="true">
                                        <i class="bi bi-box-arrow-right"></i>
                                        Sign Out
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    <button class="btn btn-primary btn-plant" @onclick="OpenPlantSeedModal">
                        <i class="bi bi-plus-lg"></i>
                        <span>Plant Seed</span>
                    </button>
                </div>
            </div>
        </header>
        
        <!-- Page Content -->
        <div class="growit-content">
            @Body
        </div>
    </main>

    <GrowIT.Client.Shared.PlantSeedModal @bind-Show="_plantSeedModalOpen" />
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private string _userName = "User";
    private string _userEmail = "";
    private string _userRole = "Guest";
    private string _userInitials = "U";

    private string _currentTheme = "light";
    private bool _sidebarCollapsed = false;
    private string _searchQuery = "";
    private string _selectedFiscalYear = "FY24-25";
    private int _notificationCount = 3;
    private bool _userMenuOpen = false;
    private bool _notificationsOpen = false;
    private bool _plantSeedModalOpen = false;
    private List<Breadcrumb> _breadcrumbs = new();
    private bool _searchFocused = false;
    private int _highlightedSearchIndex = -1;
    private ElementReference _searchInput;

    private static readonly List<QuickNavItem> QuickNavItems =
    [
        new("/", "Dashboard", "Founder survivability and capacity view", "Main", "bi bi-grid-1x2", "dashboard home overview"),
        new("/clients", "Case Files", "Directory of service records and households", "Main", "bi bi-people", "clients cases people directory"),
        new("/clients/create", "New Case File", "Create a founder case record", "Main", "bi bi-person-plus", "new create client case"),
        new("/households", "Households", "Manage household groupings", "Main", "bi bi-house-door", "households family homes"),
        new("/funds", "Funds", "Available capital and balances", "Impact", "bi bi-wallet2", "funds money balance"),
        new("/programs", "Programs", "Program categories and funding logic", "Impact", "bi bi-folder2-open", "programs categories"),
        new("/investments", "Investments", "Document service investments", "Impact", "bi bi-cash-stack", "investments seeds spending aid"),
        new("/imprints", "Imprints", "Document outcomes and milestones", "Impact", "bi bi-check2-circle", "imprints milestones outcomes"),
        new("/growth-plans", "Growth Plans", "Capacity and scaling plans", "Impact", "bi bi-diagram-3", "growth plans scale"),
        new("/reports", "Reports", "Funding readiness reports", "Intelligence", "bi bi-pie-chart", "reports export funding"),
        new("/insights", "Insights", "Operational intelligence (beta)", "Intelligence", "bi bi-activity", "insights analytics"),
        new("/organization", "Organization", "Organization profile and setup", "System", "bi bi-building", "organization org"),
        new("/settings", "Settings", "System preferences and controls", "System", "bi bi-gear", "settings preferences"),
        new("/profile", "Profile", "Account profile and preferences", "System", "bi bi-person-gear", "profile account user"),
        new("/notifications", "Notifications", "Alerts and updates", "System", "bi bi-bell", "notifications alerts")
    ];

    private class Breadcrumb
    {
        public string Label { get; set; } = "";
        public string Href { get; set; } = "";
        public bool IsLast { get; set; }
    }

    private sealed record QuickNavItem(string Route, string Label, string Description, string Category, string Icon, string Keywords);

    private List<QuickNavItem> SearchSuggestions =>
        QuickNavItems
            .Where(item => MatchesQuickSearch(item, _searchQuery))
            .OrderBy(item => item.Category)
            .ThenBy(item => item.Label)
            .Take(8)
            .ToList();

    private bool _showSearchSuggestions =>
        _searchFocused && (_searchQuery.Length > 0 || SearchSuggestions.Count > 0);

    protected override Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdateBreadcrumbs();
        return Task.CompletedTask;
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthState;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated ?? false)
        {
            _userName = user.Identity.Name ?? "User";
            _userEmail = user.FindFirst(c => c.Type == "email" || c.Type == System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
            _userRole = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
            
            if (!string.IsNullOrEmpty(_userName))
            {
                var parts = _userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 1)
                {
                    _userInitials = $"{parts[0][0]}{parts[^1][0]}".ToUpper();
                }
                else if (parts.Length == 1)
                {
                    _userInitials = parts[0][0].ToString().ToUpper();
                }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _currentTheme = await JS.InvokeAsync<string>("blazorInterop.getTheme");
            _selectedFiscalYear = await JS.InvokeAsync<string>("fiscalYearManager.get");
            StateHasChanged();
        }
    }

    private async Task OnFiscalYearChanged()
    {
        await JS.InvokeVoidAsync("fiscalYearManager.set", _selectedFiscalYear);
        await JS.InvokeVoidAsync("blazorInterop.showToast", $"Fiscal Year changed to {_selectedFiscalYear}", "success");
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _userMenuOpen = false;
        _notificationsOpen = false;
        UpdateBreadcrumbs();
        StateHasChanged();
    }

    private void UpdateBreadcrumbs()
    {
        var uri = new Uri(Navigation.Uri);
        var segments = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        
        _breadcrumbs.Clear();
        _breadcrumbs.Add(new Breadcrumb { Label = "Home", Href = "/", IsLast = segments.Length == 0 });
        
        var path = "";
        for (int i = 0; i < segments.Length; i++)
        {
            path += "/" + segments[i];
            var previousSegment = i > 0 ? segments[i - 1] : null;
            var label = FormatBreadcrumbLabel(segments[i], previousSegment);
            _breadcrumbs.Add(new Breadcrumb 
            { 
                Label = label, 
                Href = path, 
                IsLast = i == segments.Length - 1 
            });
        }
    }

    private string FormatBreadcrumbLabel(string segment, string? previousSegment = null)
    {
        if (Guid.TryParse(segment, out _))
        {
            return previousSegment?.ToLowerInvariant() switch
            {
                "clients" => "Case File",
                "member" => "Member Profile",
                _ => "Details"
            };
        }

        if (segment.Equals("clients", StringComparison.OrdinalIgnoreCase)) return "Case Files";
        if (segment.Equals("growth-plans", StringComparison.OrdinalIgnoreCase)) return "Growth Plans";
        if (segment.Equals("imprints", StringComparison.OrdinalIgnoreCase)) return "Imprints";

        var label = segment.Replace("-", " ");
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(label);
    }

    private async Task ToggleTheme()
    {
        _currentTheme = await JS.InvokeAsync<string>("blazorInterop.toggleTheme");
        StateHasChanged();
    }

    private async Task HandleLogout()
    {
        _userMenuOpen = false;
        await AuthService.Logout();
        Navigation.NavigateTo("/welcome");
    }

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }

    private async Task OpenMobileSidebar()
    {
        _sidebarCollapsed = false; // Ensure it's not collapsed when opening mobile
        await JS.InvokeVoidAsync("sidebarManager.openMobile");
    }

    private async Task CloseMobileSidebar()
    {
        await JS.InvokeVoidAsync("sidebarManager.closeMobile");
    }

    private void ToggleUserMenu()
    {
        _userMenuOpen = !_userMenuOpen;
        if (_userMenuOpen) _notificationsOpen = false;
        _searchFocused = false;
        StateHasChanged();
    }

    private void ToggleNotifications()
    {
        _notificationsOpen = !_notificationsOpen;
        if (_notificationsOpen) _userMenuOpen = false;
        _searchFocused = false;
        StateHasChanged();
    }

    private async Task MarkNotificationsAsRead()
    {
        _notificationCount = 0;
        await JS.InvokeVoidAsync("blazorInterop.showToast", "All notifications marked as read", "success");
        StateHasChanged();
    }

    private void OpenPlantSeedModal()
    {
        _plantSeedModalOpen = true;
    }

    private void HandleSearchFocusIn(FocusEventArgs _)
    {
        _searchFocused = true;
        _highlightedSearchIndex = SearchSuggestions.Count > 0 ? 0 : -1;
    }

    private async Task HandleSearchFocusOut(FocusEventArgs _)
    {
        // Allow click events on suggestion buttons to fire first.
        await Task.Delay(120);
        _searchFocused = false;
        _highlightedSearchIndex = -1;
        StateHasChanged();
    }

    private async Task HandleNavSelected()
    {
        _userMenuOpen = false;
        _notificationsOpen = false;
        _searchFocused = false;
        _highlightedSearchIndex = -1;
        await CloseMobileSidebar();
    }

    private void NavigateToQuickItem(QuickNavItem item)
    {
        _searchQuery = string.Empty;
        _searchFocused = false;
        _highlightedSearchIndex = -1;
        Navigation.NavigateTo(item.Route);
    }

    private async Task NavigateToNotifications()
    {
        _notificationsOpen = false;
        Navigation.NavigateTo("/notifications");
        await Task.CompletedTask;
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        var suggestions = SearchSuggestions;

        if (e.Key == "ArrowDown")
        {
            if (suggestions.Count == 0) return;
            _searchFocused = true;
            _highlightedSearchIndex = Math.Min(_highlightedSearchIndex + 1, suggestions.Count - 1);
            return;
        }

        if (e.Key == "ArrowUp")
        {
            if (suggestions.Count == 0) return;
            _searchFocused = true;
            _highlightedSearchIndex = Math.Max(_highlightedSearchIndex - 1, 0);
            return;
        }

        if (e.Key == "Escape")
        {
            _searchFocused = false;
            _highlightedSearchIndex = -1;
            return;
        }

        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
        {
            if (suggestions.Count > 0)
            {
                var index = _highlightedSearchIndex >= 0 ? _highlightedSearchIndex : 0;
                NavigateToQuickItem(suggestions[index]);
                return;
            }

            var route = ResolveSearchRoute(_searchQuery);
            if (route is not null)
            {
                _searchFocused = false;
                Navigation.NavigateTo(route);
                return;
            }

            await JS.InvokeVoidAsync("blazorInterop.showToast", $"No quick match for '{_searchQuery}'", "info");
        }

        _highlightedSearchIndex = suggestions.Count > 0 ? 0 : -1;
    }

    private static bool MatchesQuickSearch(QuickNavItem item, string query)
    {
        if (string.IsNullOrWhiteSpace(query)) return true;
        var normalized = query.Trim().ToLowerInvariant();
        return item.Label.Contains(normalized, StringComparison.OrdinalIgnoreCase)
               || item.Description.Contains(normalized, StringComparison.OrdinalIgnoreCase)
               || item.Category.Contains(normalized, StringComparison.OrdinalIgnoreCase)
               || item.Keywords.Contains(normalized, StringComparison.OrdinalIgnoreCase);
    }

    private static string? ResolveSearchRoute(string query)
    {
        var normalized = query.Trim().ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(normalized))
        {
            return null;
        }

        if (normalized.Contains("dashboard") || normalized == "home")
            return "/";
        if (normalized.Contains("client") || normalized.Contains("case"))
            return "/clients";
        if (normalized.Contains("house"))
            return "/households";
        if (normalized.Contains("fund"))
            return "/funds";
        if (normalized.Contains("program"))
            return "/programs";
        if (normalized.Contains("invest"))
            return "/investments";
        if (normalized.Contains("imprint") || normalized.Contains("milestone"))
            return "/imprints";
        if (normalized.Contains("growth"))
            return "/growth-plans";
        if (normalized.Contains("report"))
            return "/reports";
        if (normalized.Contains("insight"))
            return "/insights";
        if (normalized.Contains("setting"))
            return "/settings";
        if (normalized.Contains("organization") || normalized.Contains("org"))
            return "/organization";
        if (normalized.Contains("profile") || normalized.Contains("account"))
            return "/profile";
        if (normalized.Contains("notification"))
            return "/notifications";

        return null;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
