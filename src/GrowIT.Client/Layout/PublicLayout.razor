@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="public-layout @(_mobileMenuOpen ? "mobile-menu-open" : string.Empty)" data-theme="@_currentTheme">
    <HeadContent>
        <meta name="description" content="@CurrentSeo.Description" />
        <meta name="keywords" content="@CurrentSeo.Keywords" />
        <meta name="author" content="grow.IT" />
        <meta name="robots" content="@(CurrentSeo.NoIndex ? "noindex,nofollow,noarchive" : "index,follow,max-image-preview:large")" />

        <link rel="canonical" href="@CurrentSeoCanonicalUrl" />
        <link rel="alternate" href="@CurrentSeoCanonicalUrl" hreflang="en-US" />

        <meta property="og:site_name" content="grow.IT" />
        <meta property="og:type" content="@CurrentSeo.OpenGraphType" />
        <meta property="og:title" content="@CurrentSeo.Title" />
        <meta property="og:description" content="@CurrentSeo.Description" />
        <meta property="og:url" content="@CurrentSeoCanonicalUrl" />
        <meta property="og:image" content="@CurrentSeoImageUrl" />
        <meta property="og:locale" content="en_US" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="@CurrentSeo.Title" />
        <meta name="twitter:description" content="@CurrentSeo.Description" />
        <meta name="twitter:image" content="@CurrentSeoImageUrl" />
        <meta name="twitter:url" content="@CurrentSeoCanonicalUrl" />

        <script type="application/ld+json">@((MarkupString)CurrentSeoJsonLd)</script>
    </HeadContent>

    <!-- Public Header -->
    <header class="public-header">
        <div class="header-content">
            <a href="/welcome" class="header-brand">
                <img src="images/logo-@(_currentTheme == "dark" ? "light" : "dark").png" alt="GrowIT" class="brand-logo" />
                <span class="brand-text">grow<span class="brand-highlight">.IT</span></span>
            </a>
            
            <nav class="header-nav">
                <a href="/welcome#features">Features</a>
                <a href="/welcome#pricing">Pricing</a>
                <a href="/demo">Demo</a>
                <a href="/blog">Blog</a>
                <a href="/contact">Contact</a>
            </nav>
            
            <div class="header-actions">
                <button class="theme-toggle" @onclick="ToggleTheme" title="Toggle theme">
                    @if (_currentTheme == "dark")
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="5"/>
                            <line x1="12" y1="1" x2="12" y2="3"/>
                            <line x1="12" y1="21" x2="12" y2="23"/>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                            <line x1="1" y1="12" x2="3" y2="12"/>
                            <line x1="21" y1="12" x2="23" y2="12"/>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    }
                </button>
                <a href="/login" class="btn btn-ghost">Sign in</a>
                <a href="/register" class="btn btn-primary">Start Free</a>
            </div>
            
            <button class="mobile-menu-btn"
                    type="button"
                    aria-controls="public-mobile-menu"
                    aria-expanded="@_mobileMenuOpen"
                    aria-label="@(_mobileMenuOpen ? "Close navigation menu" : "Open navigation menu")"
                    @onclick="ToggleMobileMenu">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    @if (_mobileMenuOpen)
                    {
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    }
                    else
                    {
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    }
                </svg>
            </button>
        </div>
        
        <!-- Mobile Menu -->
        @if (_mobileMenuOpen)
        {
            <button type="button" class="mobile-menu-backdrop" @onclick="CloseMobileMenu" aria-label="Close navigation menu"></button>
            <div class="mobile-menu" id="public-mobile-menu" role="dialog" aria-modal="true" aria-label="Mobile navigation">
                <div class="mobile-menu-header">
                    <span>Navigate grow.IT</span>
                </div>
                <nav class="mobile-nav">
                    <a href="/welcome#features" @onclick="CloseMobileMenu">Features</a>
                    <a href="/welcome#pricing" @onclick="CloseMobileMenu">Pricing</a>
                    <a href="/demo" @onclick="CloseMobileMenu">Demo</a>
                    <a href="/blog" @onclick="CloseMobileMenu">Blog</a>
                    <a href="/contact" @onclick="CloseMobileMenu">Contact</a>
                </nav>
                <div class="mobile-actions">
                    <a href="/login" class="btn btn-ghost btn-block">Sign in</a>
                    <a href="/register" class="btn btn-primary btn-block">Start Free Trial</a>
                </div>
            </div>
        }
    </header>
    
    <!-- Main Content -->
    <main class="public-main">
        @Body
    </main>

    @if (ShowGlobalPublicFooter)
    {
        <PublicSiteFooter CurrentTheme="@_currentTheme" />
    }
</div>

@code {
    private sealed record SeoPage(string Title, string Description, string Keywords, string OpenGraphType = "website", bool NoIndex = false);

    private static readonly SeoPage DefaultSeo = new(
        "grow.IT - Mission Operations Platform",
        "grow.IT helps mission-led organizations track service delivery, capacity, and funding readiness with enterprise-grade operational reporting.",
        "nonprofit software, impact reporting, mission operations, funding readiness, service tracking");

    private static readonly Dictionary<string, SeoPage> SeoPages = new(StringComparer.OrdinalIgnoreCase)
    {
        ["/"] = new(
            "grow.IT - Founder Survivability & Funding Readiness",
            "grow.IT helps mission-led organizations document service delivery, track cost and capacity, and produce funding-ready evidence before operational strain stalls the vision.",
            "founder survivability, funding readiness, nonprofit platform, service operations, impact measurement"),
        ["/welcome"] = new(
            "grow.IT - Founder Survivability & Funding Readiness",
            "grow.IT helps mission-led organizations document service delivery, track cost and capacity, and produce funding-ready evidence before operational strain stalls the vision.",
            "founder survivability, funding readiness, nonprofit platform, service operations, impact measurement"),
        ["/blog"] = new(
            "Blog - grow.IT",
            "Practical insights on founder survivability, operating discipline, and funding readiness for mission-driven organizations.",
            "nonprofit blog, impact operations, founder guidance, funding strategy"),
        ["/contact"] = new(
            "Contact - grow.IT",
            "Contact grow.IT for rollout planning, procurement support, implementation guidance, and enterprise platform questions.",
            "contact growit, implementation support, nonprofit software demo"),
        ["/about"] = new(
            "About - grow.IT",
            "Learn the mission behind grow.IT and how we help teams build durable operational systems for long-term impact.",
            "about growit, mission operations, impact platform"),
        ["/careers"] = new(
            "Careers - grow.IT",
            "Explore career opportunities at grow.IT and help build durable systems for mission-led organizations.",
            "growit careers, mission technology jobs, nonprofit software careers"),
        ["/partners"] = new(
            "Partners - grow.IT",
            "Partner with grow.IT to strengthen implementation outcomes and mission operations at scale.",
            "growit partners, implementation partners, mission operations network"),
        ["/docs"] = new(
            "Documentation - grow.IT",
            "Implementation and product documentation for using grow.IT across households, programs, milestones, and reporting workflows.",
            "growit docs, nonprofit implementation, impact reporting documentation"),
        ["/webinars"] = new(
            "Webinars - grow.IT",
            "Join grow.IT webinars focused on operational readiness, reporting workflows, and leadership execution.",
            "growit webinars, nonprofit operations training, funding readiness webinar"),
        ["/templates"] = new(
            "Report Templates - grow.IT",
            "Use starter templates for funder reporting, board review, and operational cadence planning.",
            "report templates, funder reports, board reporting templates"),
        ["/changelog"] = new(
            "Changelog - grow.IT",
            "Track product updates, platform hardening, and public feature releases across grow.IT.",
            "growit changelog, product updates, release notes"),
        ["/privacy"] = new(
            "Privacy Policy - grow.IT",
            "Review how grow.IT collects, uses, and protects personal and operational data.",
            "growit privacy policy, data protection, platform privacy"),
        ["/terms"] = new(
            "Terms of Service - grow.IT",
            "Read the terms governing use of the grow.IT platform and services.",
            "growit terms, terms of service, legal"),
        ["/security"] = new(
            "Security - grow.IT",
            "Understand grow.IT security controls, logging, and governance practices for mission-critical operations.",
            "growit security, platform security, operational governance"),

        // Public auth routes should be crawlable only for direct user access, not indexed.
        ["/login"] = new("Sign In - grow.IT", "Sign in to your grow.IT workspace.", "growit login", NoIndex: true),
        ["/register"] = new("Create Account - grow.IT", "Create your grow.IT account.", "growit register", NoIndex: true),
        ["/forgot-password"] = new("Reset Password - grow.IT", "Request a grow.IT password reset.", "growit password reset", NoIndex: true),
        ["/reset-password"] = new("Reset Password - grow.IT", "Set a new grow.IT password.", "growit reset password", NoIndex: true),
        ["/accept-invite"] = new("Accept Invitation - grow.IT", "Accept your organization invitation to grow.IT.", "growit invite", NoIndex: true),
        ["/access-denied"] = new("Access Denied - grow.IT", "You are not authorized to access that route.", "growit access denied", NoIndex: true),
        ["/not-found"] = new("Not Found - grow.IT", "The requested page does not exist.", "growit not found", NoIndex: true)
    };

    private string _currentTheme = "light";
    private bool _mobileMenuOpen = false;
    private static readonly HashSet<string> FooterExcludedPaths = new(StringComparer.OrdinalIgnoreCase)
    {
        "/login",
        "/register",
        "/forgot-password",
        "/reset-password",
        "/accept-invite"
    };

    private bool ShowGlobalPublicFooter
    {
        get
        {
            var normalized = GetNormalizedPath();
            return !FooterExcludedPaths.Contains(normalized);
        }
    }

    private string CurrentSeoCanonicalUrl
    {
        get
        {
            var absolute = Navigation.ToAbsoluteUri(Navigation.Uri);
            var origin = absolute.GetLeftPart(UriPartial.Authority).TrimEnd('/');
            var canonicalPath = GetCanonicalPath(GetNormalizedPath());
            return canonicalPath == "/" ? $"{origin}/" : $"{origin}{canonicalPath}";
        }
    }

    private string CurrentSeoImageUrl
    {
        get
        {
            var absolute = Navigation.ToAbsoluteUri(Navigation.Uri);
            var origin = absolute.GetLeftPart(UriPartial.Authority).TrimEnd('/');
            return $"{origin}/icon-512.png";
        }
    }

    private SeoPage CurrentSeo
    {
        get
        {
            var path = GetNormalizedPath();
            return SeoPages.TryGetValue(path, out var entry) ? entry : DefaultSeo;
        }
    }

    private string CurrentSeoJsonLd
    {
        get
        {
            var websiteUrl = Navigation.ToAbsoluteUri("/").ToString();
            var payload = new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "WebPage",
                ["name"] = CurrentSeo.Title,
                ["description"] = CurrentSeo.Description,
                ["url"] = CurrentSeoCanonicalUrl,
                ["inLanguage"] = "en-US",
                ["isPartOf"] = new Dictionary<string, object?>
                {
                    ["@type"] = "WebSite",
                    ["name"] = "grow.IT",
                    ["url"] = websiteUrl
                },
                ["publisher"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Organization",
                    ["name"] = "grow.IT",
                    ["url"] = websiteUrl,
                    ["logo"] = new Dictionary<string, object?>
                    {
                        ["@type"] = "ImageObject",
                        ["url"] = CurrentSeoImageUrl
                    }
                }
            };

            return System.Text.Json.JsonSerializer.Serialize(payload);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _currentTheme = await JS.InvokeAsync<string>("blazorInterop.getTheme");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _currentTheme = await JS.InvokeAsync<string>("blazorInterop.toggleTheme");
        StateHasChanged();
    }

    private void ToggleMobileMenu()
    {
        _mobileMenuOpen = !_mobileMenuOpen;
        StateHasChanged();
    }

    private void CloseMobileMenu()
    {
        _mobileMenuOpen = false;
        StateHasChanged();
    }

    private string GetNormalizedPath()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri);
        var trimmed = path.Split('?', '#')[0].Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return "/";
        }

        return "/" + trimmed.Trim('/').ToLowerInvariant();
    }

    private static string GetCanonicalPath(string normalizedPath) => normalizedPath switch
    {
        "/welcome" => "/",
        _ => normalizedPath
    };

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (_mobileMenuOpen)
        {
            _mobileMenuOpen = false;
            _ = InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
