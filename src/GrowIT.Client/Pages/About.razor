@page "/about"
@layout PublicLayout

<PageTitle>About - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Company</span>
        <h1>About grow.IT</h1>
        <p>grow.IT was built for mission operators balancing direct service, operational strain, and funding accountability at the same time.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>Our Mission</h2>
                <p>Help mission-led organizations document impact and operational reality with confidence and consistency.</p>
            </article>
            <article class="contact-card">
                <h2>Our Approach</h2>
                <p>Combine practical workflow design with compliance-ready data foundations that teams can sustain.</p>
            </article>
            <article class="contact-card">
                <h2>Our Focus</h2>
                <p>Founder survivability, program continuity, and funder-ready reporting for long-term impact growth.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Learn how we support mission execution.</h2>
            <p>Talk with our team about your operating environment and reporting objectives.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=About%20grow.IT" class="btn btn-primary">Talk With Us</a>
                <a href="/blog" class="btn btn-outline">Read Insights</a>
            </div>
        </div>
    </section>
</div>
