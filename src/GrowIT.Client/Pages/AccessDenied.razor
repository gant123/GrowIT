@page "/access-denied"
@layout PublicLayout
@inject AppNotificationService Notifications
@inject NavigationManager Navigation

<PageTitle>Access Denied - grow.IT</PageTitle>

<div class="access-denied-page">
    <div class="access-denied-card">
        <span class="access-denied-kicker">Authorization Required</span>
        <h1>Hey, you are not authorized to access that page.</h1>
        <p>
            Please sign in with an account that has access to continue.
            @if (!string.IsNullOrWhiteSpace(_returnUrl))
            {
                <span>You tried to access <code>@_returnUrl</code>.</span>
            }
        </p>

        <div class="access-denied-actions">
            <a href="/login" class="btn btn-primary">Sign In</a>
            <a href="/welcome" class="btn btn-outline">Go To Welcome</a>
        </div>
    </div>
</div>

@code {
    private string? _returnUrl;
    private string? _lastReason;

    [SupplyParameterFromQuery(Name = "reason")]
    public string? Reason { get; set; }

    protected override void OnParametersSet()
    {
        var absoluteUri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(absoluteUri.Query);
        if (query.TryGetValue("returnUrl", out var returnUrl) || query.TryGetValue("ReturnUrl", out returnUrl))
        {
            _returnUrl = returnUrl.ToString();
        }

        if (_lastReason == Reason)
        {
            return;
        }

        _lastReason = Reason;
        Notifications.Warning("You do not have access to that page.");
    }
}
