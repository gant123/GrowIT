@page "/careers"
@layout PublicLayout

<PageTitle>Careers - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Company</span>
        <h1>Careers</h1>
        <p>We work with builders who care about durable systems, honest data, and mission outcomes.</p>
    </section>

    <section class="contact-form-section">
        <article class="contact-form-card">
            <h2>Current Openings</h2>
            <p>We do not have publicly posted openings right now, but we are always interested in meeting strong product, engineering, and operations talent aligned with mission-led work.</p>
            <p>If you want to be considered for future roles, send your background and interests through our contact channel.</p>
        </article>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Interested in future roles?</h2>
            <p>Share your profile and the role type you are targeting.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Career%20Interest" class="btn btn-primary">Submit Interest</a>
                <a href="/about" class="btn btn-outline">About The Company</a>
            </div>
        </div>
    </section>
</div>
