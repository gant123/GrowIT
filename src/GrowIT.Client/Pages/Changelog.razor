@page "/changelog"
@layout PublicLayout

<PageTitle>Changelog - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Product Updates</span>
        <h1>Grow.IT Changelog</h1>
        <p>Track platform improvements focused on clarity, security, reporting, readiness, and data reuse.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>July 2026</h2>
                <p>Added ASC readiness, clearer child/service value visibility, stronger confirmation email behavior, resend safeguards, follow-up action items, task relationship hardening, and practical in-app documentation.</p>
            </article>
            <article class="contact-card">
                <h2>June 2026</h2>
                <p>Improved role-based access, super admin user visibility, audit redaction, report detail protection, database constraints, and anonymous response standardization.</p>
            </article>
            <article class="contact-card">
                <h2>March 2026</h2>
                <p>Migrated authentication to ASP.NET Core Identity, added billing foundations, authentication rate limiting, and operational insights.</p>
            </article>
            <article class="contact-card">
                <h2>February 2026</h2>
                <p>Added public content workflows, contact submissions, super admin content management, and unauthorized access auditing.</p>
            </article>
            <article class="contact-card">
                <h2>January 2026</h2>
                <p>Improved tenant hardening, report lifecycle tracking, organization invites, profile support, and dashboard stability.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Need release context for your records?</h2>
            <p>Ask for product history, security context, or implementation notes for board and procurement review.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Release%20Notes%20Request" class="btn btn-primary">Request Details</a>
                <a href="/docs" class="btn btn-outline">How It Works</a>
            </div>
        </div>
    </section>
</div>
