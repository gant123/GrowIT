@page "/changelog"
@layout PublicLayout

<PageTitle>Changelog - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Product Updates</span>
        <h1>grow.IT Changelog</h1>
        <p>Track platform updates, reliability improvements, and release milestones.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>June 2026</h2>
                <p>Hardened role-based access with distinct platform (super admin) and organization administration, consistent authorization on every service endpoint, a single source of truth for user roles, and dark-mode and navigation refinements.</p>
            </article>
            <article class="contact-card">
                <h2>March 2026</h2>
                <p>Migrated authentication to ASP.NET Core Identity, added Stripe billing and subscription management, authentication rate limiting, and an operational insights view.</p>
            </article>
            <article class="contact-card">
                <h2>February 2026</h2>
                <p>Added public blog and contact workflows, super admin content management, and unauthorized access auditing.</p>
            </article>
            <article class="contact-card">
                <h2>January 2026</h2>
                <p>Improved tenancy hardening, report lifecycle tracking, organization invite controls, and profile photo support.</p>
            </article>
            <article class="contact-card">
                <h2>December 2025</h2>
                <p>Stabilized operational dashboards and expanded family/member linkage for client outcomes and funding reporting.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Need release notes for compliance records?</h2>
            <p>Our team can provide implementation and release traceability for procurement and board reporting.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Release%20Notes%20Request" class="btn btn-primary">Request Details</a>
                <a href="/blog" class="btn btn-outline">Read Platform Insights</a>
            </div>
        </div>
    </section>
</div>
