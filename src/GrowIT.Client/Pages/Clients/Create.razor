@page "/clients/create"
@using GrowIT.Shared.DTOs
@using GrowIT.Shared.Enums
@attribute [Authorize]
@inject IClientService ClientService
@inject NavigationManager NavManager

<div class="create-client-page fade-in">
    <PageHeader Title="Create Founder Case File" Subtitle="Start documenting service, capacity, and household context from day one.">
        <Actions>
            <a href="/clients" class="btn-growit btn-secondary-growit">
                <i class="bi bi-arrow-left me-1"></i> Back to Directory
            </a>
        </Actions>
    </PageHeader>

    <div class="card-growit form-card">
        <div class="card-body">
            <div class="create-intro-panel">
                <div class="intro-icon"><i class="bi bi-seedling"></i></div>
                <div>
                    <div class="intro-title">Start with service, build structure as you go</div>
                    <div class="intro-text">This case file becomes the foundation for tracking service investments, household progress, and future funding readiness.</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-danger-growit">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@errorMessage</span>
                </div>
            }

            <EditForm Model="@clientRequest" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <!-- Basic Information -->
                <div class="form-section">
                    <h3 class="section-title">Basic Information</h3>
                    
                    <div class="form-row two-col">
                        <div>
                            <div class="form-group-growit">
                                <label>First Name <span style="color: var(--growit-danger);">*</span></label>
                                <InputText @bind-Value="clientRequest.FirstName" class="form-input-growit" placeholder="e.g. John" />
                                <ValidationMessage For="@(() => clientRequest.FirstName)" />
                            </div>
                        </div>
                        <div>
                            <div class="form-group-growit">
                                <label>Last Name <span style="color: var(--growit-danger);">*</span></label>
                                <InputText @bind-Value="clientRequest.LastName" class="form-input-growit" placeholder="e.g. Smith" />
                                <ValidationMessage For="@(() => clientRequest.LastName)" />
                            </div>
                        </div>
                    </div>

                    <div class="form-row two-col">
                        <div>
                            <div class="form-group-growit">
                                <label>Email</label>
                                <InputText @bind-Value="clientRequest.Email" class="form-input-growit" placeholder="john@example.com" />
                            </div>
                        </div>
                        <div>
                            <div class="form-group-growit">
                                <label>Phone</label>
                                <InputText @bind-Value="clientRequest.Phone" class="form-input-growit" placeholder="(555) 123-4567" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Assessment -->
                <div class="form-section">
                    <h3 class="section-title">Service Readiness Assessment</h3>
                    
                    <div class="form-row two-col">
                        <div>
                            <div class="form-group-growit">
                                <label>Household Size</label>
                                <InputNumber @bind-Value="clientRequest.HouseholdCount" class="form-input-growit" />
                            </div>
                        </div>
                        <div>
                            <div class="form-group-growit">
                                <label>Stability Score (1-10)</label>
                                <InputNumber @bind-Value="clientRequest.StabilityScore" class="form-input-growit" min="1" max="10" />
                                <div class="score-preview">
                                    <div class="score-bar">
                                        <div class="score-fill" style="width: @($"{Math.Clamp(clientRequest.StabilityScore, 0, 10) * 10}%")"></div>
                                    </div>
                                    <div class="score-caption">Higher scores indicate stronger immediate stability and lower founder strain risk.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group-growit">
                        <label>Life Phase</label>
                        <div class="phase-selector">
                            <label class="phase-option @(clientRequest.LifePhase == LifePhase.Crisis ? "selected" : "")" @onclick="@(() => clientRequest.LifePhase = LifePhase.Crisis)">
                                <i class="bi bi-exclamation-triangle phase-icon crisis"></i>
                                <span class="phase-name">Crisis</span>
                                <span class="phase-desc">Immediate assistance needed</span>
                            </label>
                            <label class="phase-option @(clientRequest.LifePhase == LifePhase.Stable ? "selected" : "")" @onclick="@(() => clientRequest.LifePhase = LifePhase.Stable)">
                                <i class="bi bi-shield-check phase-icon stable"></i>
                                <span class="phase-name">Stable</span>
                                <span class="phase-desc">Maintaining status</span>
                            </label>
                            <label class="phase-option @(clientRequest.LifePhase == LifePhase.Thriving ? "selected" : "")" @onclick="@(() => clientRequest.LifePhase = LifePhase.Thriving)">
                                <i class="bi bi-graph-up-arrow phase-icon thriving"></i>
                                <span class="phase-name">Thriving</span>
                                <span class="phase-desc">Progressing positively</span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a href="/clients" class="btn-growit btn-secondary-growit">Cancel</a>
                    <button type="submit" class="btn-growit btn-primary-growit" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-growit" style="width: 16px; height: 16px; border-width: 2px;"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <i class="bi bi-check2-circle"></i>
                            <span>Create Case File</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private CreateClientRequest clientRequest = new()
    {
        LifePhase = LifePhase.Crisis,
        StabilityScore = 5,
        HouseholdCount = 1
    };
    
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isSubmitting = true;

        try
        {
            var clientId = await ClientService.CreateClientAsync(clientRequest);
            if (clientId != Guid.Empty)
            {
                NavManager.NavigateTo("/clients");
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
