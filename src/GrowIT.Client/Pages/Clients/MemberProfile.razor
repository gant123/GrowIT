@page "/clients/member/{Id:guid}"
@attribute [Authorize]
@using GrowIT.Shared.DTOs
@using GrowIT.Client.Shared
@inject IClientService ClientService
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (_isLoading)
{
    <div class="loading-state">
        <div class="spinner-growit"></div>
        <p class="loading-state-text">Opening individual file...</p>
    </div>
}
else if (profile == null)
{
    <div class="alert alert-danger">@(_loadError ?? "Unable to load member profile.")</div>
}
else
{
    <div class="member-profile-page fade-in">
    @if (!string.IsNullOrWhiteSpace(_deleteError))
    {
        <div class="alert alert-danger mb-4">@_deleteError</div>
    }

    <PageHeader Title="@profile.Name" Subtitle="@($"{profile.Relationship} Profile • {profile.Age} years old")">
        <Actions>
            <button class="btn-growit btn-secondary-growit" @onclick="GoBack">
                <i class="bi bi-arrow-left me-1"></i> Back
            </button>
            <button class="btn-growit btn-secondary-growit" @onclick="ToggleEdit">
                <i class="bi bi-pencil-square me-1"></i>Edit
            </button>
            <button class="btn-growit btn-danger-growit" @onclick="ConfirmDelete">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        </Actions>
    </PageHeader>

    <div class="grid-3 mb-4">
        <div class="member-metric-card">
            <div class="metric-icon info"><i class="bi bi-cash-stack"></i></div>
            <div>
                <div class="metric-label">Allocated Service Value</div>
                <div class="metric-value">@profile.TotalInvested.ToString("C0")</div>
                <div class="metric-subtext">Tracked to this household member</div>
            </div>
        </div>
        <div class="member-metric-card">
            <div class="metric-icon warning"><i class="bi bi-journal-text"></i></div>
            <div>
                <div class="metric-label">Timeline Entries</div>
                <div class="metric-value">@profile.Timeline.Count</div>
                <div class="metric-subtext">Investments and imprints recorded</div>
            </div>
        </div>
        <div class="member-metric-card">
            <div class="metric-icon primary"><i class="bi bi-calendar-heart"></i></div>
            <div>
                <div class="metric-label">Date of Birth</div>
                <div class="metric-value-sm">@(profile.DateOfBirth?.ToString("MMM dd, yyyy") ?? "Not recorded")</div>
                <div class="metric-subtext">Age and lifecycle context</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
            <div class="col-lg-4">
                <div class="card-growit mb-4">
                    <div class="card-header">
                        <h3 class="section-title">Individual Profile Summary</h3>
                    </div>
                    <div class="card-body">
                        <div class="member-summary-list">
                            <div class="detail-row"><span>Relationship</span><strong>@profile.Relationship</strong></div>
                            <div class="detail-row"><span>Age</span><strong>@profile.Age years</strong></div>
                            <div class="detail-row"><span>School</span><strong>@(string.IsNullOrWhiteSpace(profile.School) ? "Not recorded" : profile.School)</strong></div>
                            <div class="detail-row"><span>Total allocated</span><strong class="text-info">@profile.TotalInvested.ToString("C2")</strong></div>
                        </div>
                    </div>
                </div>

                <div class="card-growit">
                    <div class="card-header">
                        <h3 class="section-title">Notes & Context</h3>
                    </div>
                    <div class="card-body">
                        <div class="member-notes-panel">
                            @if (string.IsNullOrWhiteSpace(profile.Notes))
                            {
                                <div class="empty-state">
                                    <i class="bi bi-journal empty-state-icon"></i>
                                    <div class="empty-state-title">No individual notes yet</div>
                                    <div class="empty-state-description">Use this profile to capture context that supports continuity of service.</div>
                                </div>
                            }
                            else
                            {
                                <p>@profile.Notes</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card-growit h-100">
                    <div class="card-header">
                        <h3 class="section-title">Personal Activity Timeline</h3>
                        <span class="badge-growit badge-neutral">@profile.Timeline.Count Entries</span>
                    </div>
                    <div class="card-body p-0">
                        @if (profile.Timeline.Any())
                        {
                            <div class="list-group list-group-flush member-timeline-list">
                                @foreach (var item in profile.Timeline)
                                {
                                    <div class="list-group-item p-4 d-flex gap-3 member-timeline-item">
                                        <div class="member-timeline-dot @MapTimelineTone(item.ColorClass)">
                                            <i class="@MapTimelineIcon(item.Icon)"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between">
                                                <h6 class="fw-bold mb-1">@item.Title</h6>
                                                <div>
                                                    <small class="text-muted">@item.Date.ToShortDateString()</small>
                                                    @if (item.Type == "Investment")
                                                    {
                                                        <button class="btn btn-sm btn-link text-info p-0 ms-2" title="Reassign investment" @onclick="() => OpenReassignModal(item.Id)">
                                                            <i class="bi bi-arrow-left-right"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                            <p class="small mb-2 text-secondary">@item.Description</p>
                                            @if (item.Amount.HasValue)
                                            {
                                                <span class="badge-growit bg-info text-white">@item.Amount.Value.ToString("C2")</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="bi bi-clock-history empty-state-icon"></i>
                                <div class="empty-state-title">No personal activity yet</div>
                                <div class="empty-state-description">Timeline entries will appear when investments or imprints are tied to this individual.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
        
        <AddFamilyMemberModal @bind-Show="showEditModal" 
                              MemberId="@Id" 
                              OnMemberAdded="LoadProfile" />

        <ReassignInvestmentModal @bind-Show="showReassignModal" 
                                 InvestmentId="selectedInvestmentId"
                                 Members="householdMembers"
                                 OnChanged="LoadProfile" />
}

@code {
    [Parameter] public Guid Id { get; set; }
    private FamilyMemberProfileDto? profile;
    private List<FamilyMemberDto> householdMembers = new();
    private bool showEditModal = false;
    private bool showReassignModal = false;
    private Guid selectedInvestmentId;
    private string? _loadError;
    private string? _deleteError;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync() => await LoadProfile();

    private async Task LoadProfile()
    {
        _loadError = null;
        _isLoading = true;
        try
        {
            profile = await ClientService.GetMemberProfileAsync(Id);
            var clientDetail = await ClientService.GetClientDetailAsync(profile.ClientId);
            householdMembers = clientDetail?.HouseholdMembers ?? new();
        }
        catch (Exception ex)
        {
            profile = null;
            householdMembers = new();
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleEdit() => showEditModal = true;

    private void OpenReassignModal(Guid investmentId)
    {
        selectedInvestmentId = investmentId;
        showReassignModal = true;
    }

    private async Task ConfirmDelete()
    {
        _deleteError = null;
        if (await JS.InvokeAsync<bool>("confirm", "Delete this member?"))
        {
            try
            {
                await ClientService.DeleteFamilyMemberAsync(Id);
                Nav.NavigateTo("/clients");
            }
            catch (Exception ex)
            {
                _deleteError = ex.Message;
                await JS.InvokeVoidAsync("alert", _deleteError);
            }
        }
    }

    private void GoBack()
    {
        if (profile != null)
        {
            Nav.NavigateTo($"/clients/{profile.ClientId}");
            return;
        }

        Nav.NavigateTo("/clients");
    }

    private static string MapTimelineIcon(string icon) => icon switch
    {
        var value when value.Contains("dollar", StringComparison.OrdinalIgnoreCase) => "bi bi-cash-stack",
        var value when value.Contains("flag", StringComparison.OrdinalIgnoreCase) => "bi bi-flag",
        var value when value.Contains("check", StringComparison.OrdinalIgnoreCase) => "bi bi-check2-circle",
        var value when value.Contains("people", StringComparison.OrdinalIgnoreCase) || value.Contains("person", StringComparison.OrdinalIgnoreCase) => "bi bi-people",
        _ => "bi bi-activity"
    };

    private static string MapTimelineTone(string colorClass) => colorClass switch
    {
        var value when value.Contains("success", StringComparison.OrdinalIgnoreCase) => "success",
        var value when value.Contains("warning", StringComparison.OrdinalIgnoreCase) => "warning",
        var value when value.Contains("danger", StringComparison.OrdinalIgnoreCase) => "danger",
        var value when value.Contains("info", StringComparison.OrdinalIgnoreCase) => "info",
        _ => "neutral"
    };
}
