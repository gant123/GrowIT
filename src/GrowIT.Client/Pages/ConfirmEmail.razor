@page "/confirm-email"
@layout PublicLayout
@using GrowIT.Client.Services
@implements IDisposable
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject PersistentComponentState ApplicationState

<PageTitle>Confirm Email - grow.IT</PageTitle>

<div class="auth-page">
    <div class="auth-container auth-container-centered">
        <div class="auth-card">
            <div class="auth-logo">
                <a href="/welcome">
                    <img src="images/logo-@(_currentTheme == "dark" ? "light" : "dark").png" alt="GrowIT" class="brand-icon" />
                    <span class="brand-text">grow<span class="brand-highlight">.IT</span></span>
                </a>
            </div>

            @if (_isLoading)
            {
                <div class="auth-header">
                    <div class="confirmation-state-icon loading"><i class="bi bi-hourglass-split"></i></div>
                    <h1>Confirming your email</h1>
                    <p>Please wait while we activate your account.</p>
                </div>
            }
            else
            {
                <div class="auth-header">
                    <div class="confirmation-state-icon @GetStateIconClass()">
                        <i class="@GetStateIcon()"></i>
                    </div>
                    <h1>@GetConfirmationTitle()</h1>
                    <p>@_message</p>
                </div>

                @if (!_confirmed)
                {
                    <div class="auth-context-strip confirmation-help">
                        <div class="context-chip">
                            <span class="label">Good to know</span>
                            <span class="value">Confirmation links expire 24 hours after they're sent — the newest email from grow.IT always has the freshest link.</span>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_resendMessage))
                {
                    <div class="auth-alert success">
                        <i class="bi bi-check2-circle"></i>
                        <span>@_resendMessage</span>
                    </div>
                }

                <div class="auth-footer">
                    @if (_confirmed)
                    {
                        <a href="@BuildLoginUrl()" class="btn btn-primary btn-block">Continue to sign in</a>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(_email))
                        {
                            <button type="button" class="btn btn-primary btn-block" @onclick="ResendConfirmationAsync" disabled="@_isResending">
                                @if (_isResending)
                                {
                                    <span>Sending new link...</span>
                                }
                                else
                                {
                                    <span>Send a new confirmation link</span>
                                }
                            </button>
                        }
                        <a href="/login" class="btn btn-primary btn-block">Back to sign in</a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private const string ConfirmResultStateKey = "confirm-email-result";

    private string _currentTheme = "light";
    private bool _isLoading = true;
    private bool _confirmed;
    private bool _alreadyConfirmed;
    private bool _isResending;
    private string? _email;
    private string? _resendMessage;
    private string _message = "We could not process the confirmation link.";
    private ConfirmEmailResultDto? _result;
    private PersistingComponentStateSubscription _persistSubscription;

    [SupplyParameterFromQuery(Name = "userId")]
    public string? UserId { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _email = Email;
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistResultAsync);

        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
        {
            _message = "This confirmation link is incomplete. Open the link directly from the newest email we sent you, or request a fresh link below.";
            _isLoading = false;
            return;
        }

        // This page renders twice (prerender + interactive circuit). Reuse the prerender
        // outcome instead of confirming a second time — otherwise a transient failure on
        // the second call can show "failed" even though the email was already confirmed.
        if (ApplicationState.TryTakeFromJson<ConfirmEmailResultDto>(ConfirmResultStateKey, out var restored) && restored is not null)
        {
            ApplyResult(restored);
            _isLoading = false;
            return;
        }

        try
        {
            var result = await AuthService.ConfirmEmail(UserId, Token);
            if (result is not null)
            {
                ApplyResult(result);
            }
        }
        catch (ApiException ex)
        {
            ApplyResult(new ConfirmEmailResultDto
            {
                Succeeded = false,
                Email = _email ?? string.Empty,
                Message = ex.Message
            });
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyResult(ConfirmEmailResultDto result)
    {
        _result = result;
        _confirmed = result.Succeeded;
        _alreadyConfirmed = result.AlreadyConfirmed;
        _email = string.IsNullOrWhiteSpace(result.Email) ? _email : result.Email;
        _message = string.IsNullOrWhiteSpace(result.Message) ? _message : result.Message;
    }

    private Task PersistResultAsync()
    {
        if (_result is not null)
        {
            ApplicationState.PersistAsJson(ConfirmResultStateKey, _result);
        }

        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription.Dispose();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _currentTheme = await JS.InvokeAsync<string>("blazorInterop.getTheme");
            StateHasChanged();
        }
    }

    private string BuildLoginUrl()
    {
        var reason = _alreadyConfirmed ? "email-already-confirmed" : "email-confirmed";
        var builder = $"/login?reason={Uri.EscapeDataString(reason)}";
        if (!string.IsNullOrWhiteSpace(_email))
        {
            builder += $"&email={Uri.EscapeDataString(_email)}";
        }

        return builder;
    }

    private string GetConfirmationTitle()
    {
        if (!_confirmed)
        {
            return "Email confirmation failed";
        }

        return _alreadyConfirmed ? "Email already confirmed" : "Email confirmed";
    }

    private string GetStateIconClass()
    {
        if (!_confirmed)
        {
            return "failed";
        }

        return _alreadyConfirmed ? "already" : "confirmed";
    }

    private string GetStateIcon()
    {
        if (!_confirmed)
        {
            return "bi bi-exclamation-triangle";
        }

        return _alreadyConfirmed ? "bi bi-patch-check" : "bi bi-check2-circle";
    }

    private async Task ResendConfirmationAsync()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            _message = "Enter your email on the sign-in page to request a new confirmation link.";
            return;
        }

        _isResending = true;
        _resendMessage = null;

        try
        {
            var result = await AuthService.ResendConfirmationEmail(new ResendConfirmationEmailRequest
            {
                Email = _email
            });
            _resendMessage = result?.Message ?? "If your account exists, a confirmation link will be sent.";
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
        finally
        {
            _isResending = false;
        }
    }
}
