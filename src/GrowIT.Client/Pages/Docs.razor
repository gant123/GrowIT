@page "/docs"
@layout PublicLayout

<PageTitle>Documentation - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Resources</span>
        <h1>Documentation</h1>
        <p>Implementation guidance for onboarding, reporting workflows, and operating rhythm setup.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>Workspace Setup</h2>
                <p>Get tenant setup, initial configuration, and team invite patterns aligned before rollout.</p>
            </article>
            <article class="contact-card">
                <h2>Service Documentation</h2>
                <p>Learn how to model households, programs, and milestones with audit-ready data lineage.</p>
            </article>
            <article class="contact-card">
                <h2>Reporting Operations</h2>
                <p>Create cadence-ready reporting with scheduled runs and operational review workflows.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Need a guided implementation plan?</h2>
            <p>Request a documentation walkthrough tailored to your operating model.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Documentation%20Walkthrough" class="btn btn-primary">Book Walkthrough</a>
                <a href="/templates" class="btn btn-outline">View Templates</a>
            </div>
        </div>
    </section>
</div>
