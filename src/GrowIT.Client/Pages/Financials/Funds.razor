@page "/funds"
@using GrowIT.Shared.DTOs
@using GrowIT.Client.Shared
@inject IFinancialService FinancialService
@inject IRoleAccessService RoleAccessService
@inject ILogger<Funds> Logger

<PageTitle>Money Sources - grow.IT</PageTitle>

<div class="funds-page">
    <PageHeader Title="Money Sources" Subtitle="Save grants, donations, budgets, or other money your organization can use. Grow.IT connects this information to service records and reports.">
        <Actions>
            @if (_canManageFinancials)
            {
                <button class="btn btn-primary" @onclick="CreateNew">
                    <i class="bi bi-plus-lg"></i>
                    <span>Add Money Source</span>
                </button>
            }
        </Actions>
    </PageHeader>

    @if (!_canManageFinancials)
    {
        <div class="alert alert-info" role="alert">
            You can view money sources, but only Admin, Manager, or Owner roles can add or edit them.
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center" role="alert">
            <div>@errorMessage</div>
            <button class="btn btn-sm btn-outline-light" @onclick="ReloadFunds">Retry</button>
        </div>
    }

    <div class="funds-kpis">
        <div class="funds-kpi-card">
            <div class="funds-kpi-icon total"><i class="bi bi-wallet2"></i></div>
            <div>
                <div class="funds-kpi-label">Money Sources</div>
                <div class="funds-kpi-value">@(funds?.Count ?? 0)</div>
            </div>
        </div>
        <div class="funds-kpi-card">
            <div class="funds-kpi-icon available"><i class="bi bi-piggy-bank"></i></div>
            <div>
                <div class="funds-kpi-label">Available Money</div>
                <div class="funds-kpi-value">@TotalAvailable.ToString("C0")</div>
            </div>
        </div>
        <div class="funds-kpi-card">
            <div class="funds-kpi-icon deployed"><i class="bi bi-arrow-up-right-circle"></i></div>
            <div>
                <div class="funds-kpi-label">Used</div>
                <div class="funds-kpi-value">@TotalDeployed.ToString("C0")</div>
            </div>
        </div>
        <div class="funds-kpi-card">
            <div class="funds-kpi-icon coverage"><i class="bi bi-shield-check"></i></div>
            <div>
                <div class="funds-kpi-label">Still Available</div>
                <div class="funds-kpi-value">@HealthyFundCount</div>
            </div>
        </div>
    </div>

    <section class="funds-panel">
        <div class="funds-panel-header">
            <div>
                <h2>Saved Money Sources</h2>
                <p>Track the original amount, how much has been used, and what remains for each grant, donation pool, or budget.</p>
            </div>
            @if (funds != null)
            {
                <div class="funds-panel-meta">@funds.Count source(s)</div>
            }
        </div>

        @if (funds == null)
        {
            <div class="funds-loading">
                <div class="spinner-border text-success" role="status"></div>
                <p>Loading money sources...</p>
            </div>
        }
        else if (!funds.Any())
        {
            <div class="funds-empty">
                <div class="funds-empty-icon"><i class="bi bi-wallet2"></i></div>
                <h3>No money sources yet</h3>
                <p>Add a grant, donation pool, budget, or other funding source before recording services that use money.</p>
                @if (_canManageFinancials)
                {
                    <button class="btn btn-outline-primary" @onclick="CreateNew">
                        <i class="bi bi-plus-lg"></i>
                        <span>Add First Money Source</span>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="fund-cards-grid">
                @foreach (var fund in funds.OrderBy(f => f.Name))
                {
                    var percent = GetPercent(fund);
                    var used = GetUsedAmount(fund);

                    <article class="fund-card" @key="fund.Id">
                        <div class="fund-card-header">
                            <div>
                                <h3>@fund.Name</h3>
                                <div class="fund-card-subtitle">@GetStatusLabel(percent)</div>
                            </div>
                            <div class="fund-card-actions">
                                <span class="fund-status-pill @GetStatusClass(percent)">@GetStatusLabel(percent)</span>
                                @if (_canManageFinancials)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditFund(fund)" title="Edit Fund">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="fund-card-body">
                            <div class="fund-money-grid">
                                <div class="money-block">
                                    <span class="label">Available</span>
                                    <strong>@fund.AvailableAmount.ToString("C0")</strong>
                                </div>
                                <div class="money-block">
                                    <span class="label">Used</span>
                                    <strong>@used.ToString("C0")</strong>
                                </div>
                                <div class="money-block">
                                    <span class="label">Original Amount</span>
                                    <strong>@fund.TotalAmount.ToString("C0")</strong>
                                </div>
                                <div class="money-block">
                                    <span class="label">Percent Used</span>
                                    <strong>@percent%</strong>
                                </div>
                            </div>

                            <div class="utilization-wrap">
                                <div class="utilization-header">
                                    <span>Percent Used</span>
                                    <span>@percent%</span>
                                </div>
                                <div class="utilization-track" role="progressbar" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100">
                                    <div class="utilization-fill @GetStatusClass(percent)" style="width: @($"{percent}%")"></div>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@if (_canManageFinancials)
{
    <CreateFundModal @bind-Show="showCreateModal"
                     FundToEdit="selectedFund"
                     OnFundCreated="ReloadFunds" />
}

@code {
    private List<FundDto>? funds;
    private FundDto? selectedFund;
    private bool showCreateModal;
    private string? errorMessage;
    private bool _canManageFinancials;

    private decimal TotalAvailable => funds?.Sum(f => f.AvailableAmount) ?? 0m;
    private decimal TotalBudget => funds?.Sum(f => f.TotalAmount) ?? 0m;
    private decimal TotalDeployed => TotalBudget - TotalAvailable;
    private int HealthyFundCount => funds?.Count(f => GetPercent(f) < 80) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        _canManageFinancials = (await RoleAccessService.GetAccessAsync()).CanManageFinancials;
        await ReloadFunds();
    }

    private async Task ReloadFunds()
    {
        try
        {
            errorMessage = null;
            funds = await FinancialService.GetFundsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load funds from api/financials/funds");
            funds = [];
            errorMessage = "Couldn't load funds. Please try again.";
        }
    }

    private void EditFund(FundDto fund)
    {
        if (!_canManageFinancials) return;
        selectedFund = fund;
        showCreateModal = true;
    }

    private void CreateNew()
    {
        if (!_canManageFinancials) return;
        selectedFund = null;
        showCreateModal = true;
    }

    private static int GetPercent(FundDto f)
    {
        if (f.TotalAmount <= 0) return 0;

        var used = f.TotalAmount - f.AvailableAmount;
        var percent = used / f.TotalAmount * 100m;
        return (int)Math.Clamp(decimal.Round(percent, 0, MidpointRounding.AwayFromZero), 0m, 100m);
    }

    private static decimal GetUsedAmount(FundDto f) => Math.Max(0m, f.TotalAmount - f.AvailableAmount);

    private static string GetStatusClass(int percent) => percent switch
    {
        >= 90 => "critical",
        >= 70 => "warning",
        _ => "healthy"
    };

    private static string GetStatusLabel(int percent) => percent switch
    {
        >= 90 => "Almost Used Up",
        >= 70 => "Watch Closely",
        _ => "Money Available"
    };
}
