@page "/programs"
@attribute [Authorize]
@using GrowIT.Shared.DTOs
@using GrowIT.Client.Shared
@inject IFinancialService FinancialService

<PageTitle>Programs - grow.IT</PageTitle>

<div class="programs-page">
    <PageHeader Title="Programs & Services" Subtitle="Define repeatable service models so each act of care becomes measurable, fundable, and scalable.">
        <Actions>
            <button class="btn btn-primary" @onclick="OpenCreateModal">
                <i class="bi bi-plus-lg"></i>
                <span>Add Program</span>
            </button>
        </Actions>
    </PageHeader>

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center" role="alert">
            <div>@_loadError</div>
            <button class="btn btn-sm btn-outline-light" @onclick="LoadPrograms">Retry</button>
        </div>
    }

    <div class="program-kpis">
        <div class="program-kpi-card">
            <div class="program-kpi-icon total"><i class="bi bi-folder2-open"></i></div>
            <div>
                <div class="program-kpi-label">Programs</div>
                <div class="program-kpi-value">@(programs?.Count ?? 0)</div>
            </div>
        </div>
        <div class="program-kpi-card">
            <div class="program-kpi-icon capacity"><i class="bi bi-speedometer2"></i></div>
            <div>
                <div class="program-kpi-label">With Capacity Limits</div>
                <div class="program-kpi-value">@ProgramsWithCapacity</div>
            </div>
        </div>
        <div class="program-kpi-card">
            <div class="program-kpi-icon unit"><i class="bi bi-cash-coin"></i></div>
            <div>
                <div class="program-kpi-label">Avg Unit Cost</div>
                <div class="program-kpi-value">@AverageUnitCostLabel</div>
            </div>
        </div>
        <div class="program-kpi-card">
            <div class="program-kpi-icon readiness"><i class="bi bi-clipboard-data"></i></div>
            <div>
                <div class="program-kpi-label">Capacity-Ready Models</div>
                <div class="program-kpi-value">@CapacityReadyPrograms</div>
            </div>
        </div>
    </div>

    <section class="program-panel">
        <div class="program-panel-header">
            <div>
                <h2>Program Catalog</h2>
                <p>Maintain service definitions and cost assumptions used across investments and reporting.</p>
            </div>
            <div class="program-panel-meta">@(FilteredPrograms.Count()) program(s)</div>
        </div>

        <div class="program-toolbar">
            <div class="program-search">
                <i class="bi bi-search"></i>
                <input class="form-control" placeholder="Search by name or description" @bind="SearchQuery" @bind:event="oninput" />
            </div>
        </div>

        @if (programs == null)
        {
            <div class="program-loading"><div class="spinner-border text-primary" role="status"></div><p>Loading programs...</p></div>
        }
        else if (!FilteredPrograms.Any())
        {
            <div class="program-empty">
                <div class="program-empty-icon"><i class="bi bi-folder-x"></i></div>
                <h3>No programs found</h3>
                <p>Create your first service model to standardize what you do, what it costs, and how it scales.</p>
                <button class="btn btn-outline-primary" @onclick="OpenCreateModal">
                    <i class="bi bi-plus-lg"></i>
                    <span>Create First Program</span>
                </button>
            </div>
        }
        else
        {
            <div class="program-grid">
                @foreach (var p in FilteredPrograms.OrderBy(p => p.Name))
                {
                    <article class="program-card" @key="p.Id">
                        <div class="program-card-header">
                            <div>
                                <h3>@p.Name</h3>
                                <div class="program-unit-cost">
                                    <i class="bi bi-cash-coin"></i>
                                    @if (p.DefaultUnitCost > 0)
                                    {
                                        <span>@p.DefaultUnitCost.ToString("C0") default unit cost</span>
                                    }
                                    else
                                    {
                                        <span>Unit cost not configured</span>
                                    }
                                </div>
                            </div>
                            @if (p.CapacityLimit.HasValue)
                            {
                                <span class="capacity-chip configured">@p.CapacityLimit @p.CapacityPeriod</span>
                            }
                            else
                            {
                                <span class="capacity-chip missing">No capacity limit</span>
                            }
                        </div>
                        <div class="program-card-body">
                            <p class="program-description">@(string.IsNullOrWhiteSpace(p.Description) ? "No description provided yet." : p.Description)</p>
                            <div class="program-attributes">
                                <div class="program-attr">
                                    <span class="label">Capacity</span>
                                    <span class="value">@(p.CapacityLimit.HasValue ? $"{p.CapacityLimit} per {p.CapacityPeriod}" : "Not set")</span>
                                </div>
                                <div class="program-attr">
                                    <span class="label">Unit Cost</span>
                                    <span class="value">@(p.DefaultUnitCost > 0 ? p.DefaultUnitCost.ToString("C2") : "Not set")</span>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@if (showCreateModal)
{
    <div class="modal fade show d-block programs-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content programs-modal-shell">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title">New Program</h5>
                        <div class="modal-subtitle">Define a repeatable service model that can be measured, costed, and explained to funders.</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrWhiteSpace(_saveError))
                    {
                        <div class="alert alert-danger">@_saveError</div>
                    }

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Program Name</label>
                            <input @bind="newProgram.Name" class="form-control" placeholder="e.g. Community Care Box Distribution" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea @bind="newProgram.Description" class="form-control" rows="4" placeholder="Describe what this service provides and what outcome it supports."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Capacity Limit</label>
                            <input @bind="newProgram.CapacityLimit" type="number" class="form-control" placeholder="e.g. 50" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Capacity Period</label>
                            <select @bind="newProgram.CapacityPeriod" class="form-select">
                                <option value="">None</option>
                                <option value="Weekly">Weekly</option>
                                <option value="Monthly">Monthly</option>
                                <option value="Annual">Annual</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseCreateModal">Cancel</button>
                        <button class="btn btn-primary" @onclick="CreateProgram" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            <span>Save Program</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ProgramDto>? programs;
    private bool showCreateModal;
    private bool _isSaving;
    private string? _loadError;
    private string? _saveError;
    private CreateProgramRequest newProgram = new();
    private string SearchQuery { get; set; } = string.Empty;

    private int ProgramsWithCapacity => programs?.Count(p => p.CapacityLimit.HasValue && p.CapacityLimit.Value > 0) ?? 0;
    private int CapacityReadyPrograms => programs?.Count(p => p.CapacityLimit.HasValue && p.CapacityLimit > 0 && p.DefaultUnitCost > 0) ?? 0;
    private string AverageUnitCostLabel => (programs?.Any(p => p.DefaultUnitCost > 0) ?? false)
        ? programs!.Where(p => p.DefaultUnitCost > 0).Average(p => p.DefaultUnitCost).ToString("C0")
        : "$0";

    private IEnumerable<ProgramDto> FilteredPrograms
    {
        get
        {
            var source = programs ?? [];
            if (string.IsNullOrWhiteSpace(SearchQuery)) return source;

            return source.Where(p =>
                (p.Name?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Description?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false));
        }
    }

    protected override async Task OnInitializedAsync() => await LoadPrograms();

    private async Task LoadPrograms()
    {
        try
        {
            _loadError = null;
            programs = await FinancialService.GetProgramsAsync();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            programs = [];
        }
    }

    private void OpenCreateModal()
    {
        _saveError = null;
        showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _saveError = null;
        showCreateModal = false;
    }

    private async Task CreateProgram()
    {
        _saveError = null;

        if (string.IsNullOrWhiteSpace(newProgram.Name))
        {
            _saveError = "Program name is required.";
            return;
        }

        _isSaving = true;
        try
        {
            await FinancialService.CreateProgramAsync(newProgram);
            showCreateModal = false;
            newProgram = new();
            await LoadPrograms();
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }
}
