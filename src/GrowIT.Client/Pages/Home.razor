@page "/home"
@attribute [Authorize]
@using System.Globalization
@using GrowIT.Shared.DTOs
@using GrowIT.Client.Services
@inject IDashboardService DashboardService
@inject NavigationManager Nav

<PageTitle>grow.IT - Founder Dashboard</PageTitle>

@if (_isLoading)
{
    <div class="loading-state">
        <div class="spinner-growit"></div>
        <p class="loading-state-text">Loading impact data...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="alert alert-danger d-flex justify-content-between align-items-center mt-4">
        <span>@_loadError</span>
        <button class="btn btn-sm btn-outline-light" @onclick="Refresh">Retry</button>
    </div>
}
else if (stats == null)
{
    <div class="alert alert-secondary mt-4">No dashboard data available.</div>
}
else
{
    <div class="dashboard fade-in">
        <PageHeader Title="Founder Dashboard" Subtitle="See what you have saved, what needs attention, and what Grow.IT can turn into reports or portfolio content.">
            <Actions>
                <button class="btn-growit btn-secondary-growit" @onclick="Refresh">
                    <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                </button>
            </Actions>
        </PageHeader>

        <div class="card-growit dashboard-intro mb-4">
            <div class="card-body dashboard-intro-body">
                <div class="dashboard-intro-copy">
                    <div class="dashboard-intro-kicker">What This Page Does</div>
                    <h3 class="dashboard-intro-title">Your saved work becomes useful reports, funder language, and next steps.</h3>
                    <p class="dashboard-intro-text">Add people, programs, money sources, services, and outcomes once. Grow.IT reuses that information across dashboards, reports, and your organization portfolio.</p>
                </div>
                <div class="dashboard-intro-badges">
                    <span class="badge-growit badge-success">Save once</span>
                    <span class="badge-growit badge-success">Reuse in reports</span>
                    <span class="badge-growit badge-success">Build your portfolio</span>
                </div>
            </div>
        </div>

        <div class="grid-4 mb-4">
            <KpiCard Label="Service Value This Year"
                     Value="@stats.TotalInvestedYtd.ToString("C0")"
                     Icon="bi bi-graph-up-arrow"
                     Color="success"
                     TrendText="Saved from service records"
                     TrendIcon="bi bi-arrow-up-right"
                     TrendDirection="up" />

            <KpiCard Label="People or Households Served"
                     Value="@stats.HouseholdsServedYtd.ToString()"
                     Icon="bi bi-house-door"
                     Color="info"
                     TrendText="Used in impact reports" />

            <KpiCard Label="Open Service Records"
                     Value="@stats.ActiveCases.ToString()"
                     Icon="bi bi-person-lines-fill"
                     Color="warning"
                     TrendText="Records your team is using" />

            <KpiCard Label="Money Available"
                     Value="@stats.FundsAvailable.ToString("C0")"
                     Icon="bi bi-wallet2"
                     Color="primary"
                     TrendText="Remaining money sources" />
        </div>

        <div class="card-growit mb-4">
            <div class="card-header">
                <h3 class="section-title">Monthly Service Value</h3>
                <div class="chart-legend">
                    <div class="legend-item impact">
                        <span class="legend-dot"></span>
                        <span>Service value saved by month</span>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (_hasChartData)
                {
                    <div class="chart-summary">
                        <div class="chart-summary-item">
                            <span class="chart-summary-label">Total this year</span>
                            <span class="chart-summary-value">@stats.TotalInvestedYtd.ToString("C0")</span>
                        </div>
                        <div class="chart-summary-item">
                            <span class="chart-summary-label">Best month</span>
                            <span class="chart-summary-value">@_bestMonthLabel</span>
                        </div>
                        <div class="chart-summary-item">
                            <span class="chart-summary-label">Monthly average</span>
                            <span class="chart-summary-value">@_monthlyAverage.ToString("C0")</span>
                        </div>
                    </div>

                    <div class="bar-chart" role="img" aria-label="Bar chart of service value saved by month">
                        <div class="bar-chart-plot">
                            @foreach (var step in _gridSteps)
                            {
                                <div class="bar-grid-line" style="bottom: @step.Percent.ToString("0.##", CultureInfo.InvariantCulture)%">
                                    <span class="bar-grid-label">@FormatCompactMoney(step.Value)</span>
                                </div>
                            }
                            <div class="bar-row">
                                @for (var i = 0; i < _chartBars.Count; i++)
                                {
                                    var bar = _chartBars[i];
                                    <div class="bar-col" @key="bar.Label">
                                        <div class="bar-fill @(bar.Amount <= 0 ? "empty" : null) @(bar.IsBest ? "best" : null)"
                                             style="height: @bar.HeightPercent.ToString("0.##", CultureInfo.InvariantCulture)%; animation-delay: @(i * 45)ms"
                                             data-value="@bar.Amount.ToString("C0")"></div>
                                    </div>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(_trendLinePath))
                            {
                                <svg class="trend-overlay" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true" focusable="false">
                                    <defs>
                                        <linearGradient id="trend-area-gradient" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0" class="trend-area-stop-top" />
                                            <stop offset="1" class="trend-area-stop-bottom" />
                                        </linearGradient>
                                    </defs>
                                    <path class="trend-area" d="@_trendAreaPath" />
                                    <path class="trend-line" d="@_trendLinePath" pathLength="1" />
                                </svg>
                                <div class="trend-markers" aria-hidden="true">
                                    @foreach (var marker in _trendMarkers)
                                    {
                                        <span class="trend-marker"
                                              style="left: @marker.X.ToString("0.##", CultureInfo.InvariantCulture)%; bottom: @marker.BottomPercent.ToString("0.##", CultureInfo.InvariantCulture)%"></span>
                                    }
                                </div>
                            }
                        </div>
                        <div class="bar-labels">
                            @foreach (var bar in _chartBars)
                            {
                                <span class="bar-label @(bar.Amount > 0 ? "has-data" : null)">@bar.Label</span>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="chart-empty-state">
                        <i class="bi bi-bar-chart"></i>
                        <p>No trend data available for this period.</p>
                        <span>Disbursed service records will appear here month by month.</span>
                    </div>
                }
            </div>
        </div>

        <div class="grid-2">
            <div class="card-growit">
                <div class="card-header">
                    <h3 class="section-title">Next Steps</h3>
                    <span class="badge-growit badge-warning">@stats.PendingFollowUps.Count Action Items</span>
                </div>
                <div class="card-body p-0">
                    <div class="tasks-list">
                        @if (stats.PendingFollowUps.Any())
                        {
                            @foreach (var task in stats.PendingFollowUps)
                            {
                                <div class="task-item cursor-pointer" @onclick="() => NavigateToClient(task.ClientId)">
                                    <div class="task-content">
                                        <div class="task-row">
                                            <span class="task-action fw-600">@task.ClientName</span>
                                            <span class="task-due">Due @task.DueDate.ToString("MMM dd")</span>
                                        </div>
                                        <div class="task-note">@task.Note</div>
                                    </div>
                                    <i class="bi bi-chevron-right task-chevron"></i>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="bi bi-check2-circle empty-state-icon text-success"></i>
                                <div class="empty-state-title">No follow-ups due today</div>
                                <div class="empty-state-description">When a person, household, or program needs attention, the next step will show here.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card-growit">
                <div class="card-header">
                    <h3 class="section-title">Recent Updates</h3>
                </div>
                <div class="card-body p-0">
                    <div class="activity-list">
                        @if (stats.RecentActivity.Any())
                        {
                            @foreach (var item in stats.RecentActivity)
                            {
                                <div class="activity-item">
                                    <div class="activity-icon @(GetActivityClass(item.Icon))">
                                        <i class="@GetActivityIconClass(item.Icon)"></i>
                                    </div>
                                    <div class="activity-content">
                                        <div class="activity-text">@item.Description</div>
                                        <div class="activity-meta">@GetTimeAgo(item.Date)</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <p class="empty-state-description">No recent activity yet. Start by adding a person, program, money source, service record, or outcome.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardStatsDto? stats;
    private bool _isLoading = true;
    private string? _loadError;

    private sealed record ChartBar(string Label, decimal Amount, double HeightPercent, bool IsBest);
    private sealed record GridStep(decimal Value, double Percent);
    private sealed record TrendMarker(double X, double BottomPercent);

    private List<ChartBar> _chartBars = new();
    private List<GridStep> _gridSteps = new();
    private List<TrendMarker> _trendMarkers = new();
    private string _trendLinePath = string.Empty;
    private string _trendAreaPath = string.Empty;
    private bool _hasChartData;
    private string _bestMonthLabel = "-";
    private decimal _monthlyAverage;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    private async Task Refresh()
    {
        _isLoading = true;
        _loadError = null;
        try
        {
            stats = await DashboardService.GetStatsAsync();
            BuildChart();
        }
        catch (Exception ex)
        {
            stats = null;
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BuildChart()
    {
        var trends = stats?.MonthlyTrends ?? new List<MonthlyMetric>();
        _hasChartData = trends.Any(t => t.Amount > 0);
        if (!_hasChartData)
        {
            _chartBars = new();
            _gridSteps = new();
            _trendMarkers = new();
            _trendLinePath = string.Empty;
            _trendAreaPath = string.Empty;
            return;
        }

        // The backend keys months by invariant abbreviated names; fill the full year so
        // the chart reads as a January-December timeline instead of a gap-free sample.
        var byMonth = trends
            .GroupBy(t => t.Month, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.Sum(t => t.Amount), StringComparer.OrdinalIgnoreCase);

        var max = trends.Max(t => t.Amount);
        var scaleMax = NiceCeiling(max);
        var bestAmount = trends.Max(t => t.Amount);

        _chartBars = Enumerable.Range(1, 12)
            .Select(m => CultureInfo.InvariantCulture.DateTimeFormat.GetAbbreviatedMonthName(m))
            .Select(label =>
            {
                var amount = byMonth.TryGetValue(label, out var value) ? value : 0m;
                var percent = scaleMax <= 0 ? 0 : (double)(amount / scaleMax) * 100.0;
                return new ChartBar(label, amount, percent, amount > 0 && amount == bestAmount);
            })
            .ToList();

        _gridSteps = new List<GridStep>
        {
            new(scaleMax, 100),
            new(scaleMax * 0.75m, 75),
            new(scaleMax * 0.5m, 50),
            new(scaleMax * 0.25m, 25),
            new(0m, 0)
        };

        BuildTrendOverlay();

        var best = _chartBars.Where(b => b.Amount > 0).MaxBy(b => b.Amount);
        _bestMonthLabel = best is null ? "-" : $"{best.Label} ({best.Amount:C0})";

        var monthsWithData = _chartBars.Count(b => b.Amount > 0);
        _monthlyAverage = monthsWithData == 0 ? 0m : _chartBars.Sum(b => b.Amount) / monthsWithData;
    }

    // Trend line over the elapsed part of the year: from January through the last month
    // with data, including in-between zero months (honest dips), but never into future
    // months that simply haven't happened yet.
    private void BuildTrendOverlay()
    {
        _trendMarkers = new();
        _trendLinePath = string.Empty;
        _trendAreaPath = string.Empty;

        var lastDataIndex = _chartBars.FindLastIndex(b => b.Amount > 0);
        if (lastDataIndex < 0)
        {
            return;
        }

        const double slotWidth = 100.0 / 12.0;
        var points = new List<(double X, double Y)>();
        for (var i = 0; i <= lastDataIndex; i++)
        {
            var x = (i + 0.5) * slotWidth;
            var y = 100.0 - _chartBars[i].HeightPercent;
            points.Add((x, y));

            if (_chartBars[i].Amount > 0)
            {
                _trendMarkers.Add(new TrendMarker(x, _chartBars[i].HeightPercent));
            }
        }

        if (points.Count < 2)
        {
            return;
        }

        _trendLinePath = BuildSmoothPath(points);
        _trendAreaPath =
            $"{_trendLinePath} L {Svg(points[^1].X)} 100 L {Svg(points[0].X)} 100 Z";
    }

    // Quadratic midpoint smoothing: curves stay between neighboring points (no overshoot
    // below the baseline), which matters when zero months sit between data months.
    private static string BuildSmoothPath(IReadOnlyList<(double X, double Y)> points)
    {
        var path = new System.Text.StringBuilder($"M {Svg(points[0].X)} {Svg(points[0].Y)}");
        if (points.Count == 2)
        {
            path.Append($" L {Svg(points[1].X)} {Svg(points[1].Y)}");
            return path.ToString();
        }

        for (var i = 1; i < points.Count - 1; i++)
        {
            var midX = (points[i].X + points[i + 1].X) / 2;
            var midY = (points[i].Y + points[i + 1].Y) / 2;
            path.Append($" Q {Svg(points[i].X)} {Svg(points[i].Y)} {Svg(midX)} {Svg(midY)}");
        }

        path.Append($" L {Svg(points[^1].X)} {Svg(points[^1].Y)}");
        return path.ToString();
    }

    private static string Svg(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);

    // Rounds up to a "nice" chart ceiling (1 / 2 / 2.5 / 5 x 10^n) so gridline labels land
    // on friendly values.
    private static decimal NiceCeiling(decimal value)
    {
        if (value <= 0)
        {
            return 100m;
        }

        var magnitude = (decimal)Math.Pow(10, Math.Floor(Math.Log10((double)value)));
        var normalized = value / magnitude;
        var nice = normalized <= 1m ? 1m
            : normalized <= 2m ? 2m
            : normalized <= 2.5m ? 2.5m
            : normalized <= 5m ? 5m
            : 10m;
        return nice * magnitude;
    }

    private static string FormatCompactMoney(decimal value) =>
        value >= 1_000_000m ? $"${value / 1_000_000m:0.#}M"
        : value >= 1_000m ? $"${value / 1_000m:0.#}K"
        : $"${value:0}";

    private void NavigateToClient(Guid clientId)
    {
        Nav.NavigateTo($"clients/{clientId}");
    }

    private string GetTimeAgo(DateTime date)
    {
        var span = DateTime.UtcNow - date;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private string GetActivityClass(string icon)
    {
        if (icon.Contains("dollar") || icon.Contains("cash")) return "investment";
        if (icon.Contains("house") || icon.Contains("home")) return "fund";
        if (icon.Contains("people") || icon.Contains("person") || icon.Contains("flag")) return "client";
        return "fund";
    }

    private static string GetActivityIconClass(string icon) => icon switch
    {
        var value when value.Contains("dollar", StringComparison.OrdinalIgnoreCase) || value.Contains("cash", StringComparison.OrdinalIgnoreCase) => "bi bi-cash-stack",
        var value when value.Contains("flag", StringComparison.OrdinalIgnoreCase) => "bi bi-flag",
        var value when value.Contains("house", StringComparison.OrdinalIgnoreCase) || value.Contains("home", StringComparison.OrdinalIgnoreCase) => "bi bi-house-door",
        var value when value.Contains("people", StringComparison.OrdinalIgnoreCase) || value.Contains("person", StringComparison.OrdinalIgnoreCase) => "bi bi-people",
        _ => "bi bi-activity"
    };
}
