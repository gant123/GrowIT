@page "/home"
@attribute [Authorize]
@using System.Globalization
@using GrowIT.Shared.DTOs
@using GrowIT.Client.Services
@using Syncfusion.Blazor.Charts
@implements IAsyncDisposable
@inject IDashboardService DashboardService
@inject IProfileService ProfileService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Today - grow.IT</PageTitle>

@if (_isLoading)
{
    <div class="loading-state">
        <div class="spinner-growit"></div>
        <p class="loading-state-text">Opening your field journal...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="alert alert-danger d-flex justify-content-between align-items-center mt-4">
        <span>@_loadError</span>
        <button class="btn btn-sm btn-outline-light" @onclick="Refresh">Retry</button>
    </div>
}
else if (stats == null)
{
    <div class="alert alert-secondary mt-4">No dashboard data available.</div>
}
else
{
    <div class="dashboard fade-in">
        <header class="today-head">
            <div class="today-head-text">
                <h1 class="today-greeting">@_greeting</h1>
                <div class="today-season"><span class="dot"></span> @_seasonLine</div>
            </div>
            <button class="btn-growit btn-secondary-growit" @onclick="Refresh" title="Refresh">
                <i class="bi bi-arrow-clockwise me-1"></i> Refresh
            </button>
        </header>

        <div class="card-growit today-hero mb-4">
            <div class="card-body">
                <div class="hero-label">Service value this year</div>
                <div class="hero-money">@stats.TotalInvestedYtd.ToString("C0")</div>
                @if (_hasChartData)
                {
                    <div class="chart-summary">
                        <div class="chart-summary-item">
                            <span class="chart-summary-label">Best month</span>
                            <span class="chart-summary-value">@_bestMonthLabel</span>
                        </div>
                        <div class="chart-summary-item">
                            <span class="chart-summary-label">Monthly average</span>
                            <span class="chart-summary-value">@_monthlyAverage.ToString("C0")</span>
                        </div>
                    </div>

                    @* Syncfusion resolves colors into SVG attributes, where CSS variables
                       do NOT work — every color below is a concrete hex from the active
                       theme palette, refreshed live via the themeChanged listener. *@
                    <div class="chart-container">
                        <SfChart @key="_chartTheme" Height="340px" Width="100%" Background="transparent" Theme="@_chartTheme">
                            <ChartArea>
                                <ChartAreaBorder Width="0"></ChartAreaBorder>
                            </ChartArea>

                            <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category"
                                               EdgeLabelPlacement="EdgeLabelPlacement.Shift"
                                               LabelPlacement="LabelPlacement.OnTicks">
                                <ChartAxisLabelStyle Color="@_palette.AxisLabel" Size="12px"></ChartAxisLabelStyle>
                                <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
                                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                            </ChartPrimaryXAxis>

                            <ChartPrimaryYAxis LabelFormat="${value}" EdgeLabelPlacement="EdgeLabelPlacement.Shift">
                                <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                                <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
                                <ChartAxisMajorGridLines Width="1" Color="@_palette.GridLine" DashArray="4,4"></ChartAxisMajorGridLines>
                                <ChartAxisLabelStyle Color="@_palette.AxisLabel" Size="12px"></ChartAxisLabelStyle>
                            </ChartPrimaryYAxis>

                            <ChartTooltipSettings Enable="true" Shared="true" Header="Service value"></ChartTooltipSettings>

                            <ChartSeriesCollection>
                                <ChartSeries DataSource="@stats.MonthlyTrends"
                                             XName="Month"
                                             YName="Amount"
                                             Type="ChartSeriesType.Column"
                                             ColumnWidth="0.55"
                                             Fill="url(#growit-column-gradient)">
                                    <ChartCornerRadius TopLeft="6" TopRight="6"></ChartCornerRadius>
                                </ChartSeries>
                                <ChartSeries DataSource="@stats.MonthlyTrends"
                                             XName="Month"
                                             YName="Amount"
                                             Type="ChartSeriesType.Spline"
                                             Width="3"
                                             Fill="@BrandGreen">
                                    <ChartMarker Visible="true" Width="10" Height="10" Shape="ChartShape.Circle" Fill="@_palette.MarkerFill">
                                        <ChartMarkerBorder Width="3" Color="@BrandGreen"></ChartMarkerBorder>
                                    </ChartMarker>
                                </ChartSeries>
                            </ChartSeriesCollection>
                        </SfChart>

                        @* Brand green is identical in both themes, so the gradient can be static. *@
                        <svg class="chart-gradient-defs" aria-hidden="true" focusable="false">
                            <defs>
                                <linearGradient id="growit-column-gradient" x1="0" x2="0" y1="0" y2="1">
                                    <stop offset="0" stop-color="#27B062" stop-opacity="0.85" />
                                    <stop offset="1" stop-color="#27B062" stop-opacity="0.12" />
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                }
                else
                {
                    <div class="chart-empty-state">
                        <i class="bi bi-bar-chart"></i>
                        <p>Nothing planted yet this year.</p>
                        <span>Disbursed service records will appear here month by month.</span>
                    </div>
                }
            </div>
        </div>

        <div class="today-stats mb-4">
            <button type="button" class="today-stat" @onclick="@(() => Nav.NavigateTo("/clients"))">
                <span class="today-stat-value">@stats.HouseholdsServedYtd</span>
                <span class="today-stat-label">Households served</span>
            </button>
            <button type="button" class="today-stat" @onclick="@(() => Nav.NavigateTo("/clients"))">
                <span class="today-stat-value">@stats.ActiveCases</span>
                <span class="today-stat-label">Open records</span>
            </button>
            <button type="button" class="today-stat" @onclick="@(() => Nav.NavigateTo("/funds"))">
                <span class="today-stat-value">@stats.FundsAvailable.ToString("C0")</span>
                <span class="today-stat-label">Money available</span>
            </button>
        </div>

        <div class="grid-2">
            <div class="card-growit">
                <div class="card-header">
                    <h3 class="section-title">Needs you</h3>
                    <span class="badge-growit badge-warning">@stats.PendingFollowUps.Count due</span>
                </div>
                <div class="card-body p-0">
                    <div class="tasks-list">
                        @if (stats.PendingFollowUps.Any())
                        {
                            @foreach (var task in stats.PendingFollowUps)
                            {
                                <div class="task-item cursor-pointer" @onclick="() => NavigateToClient(task.ClientId)">
                                    <div class="task-content">
                                        <div class="task-row">
                                            <span class="task-action fw-600">@task.ClientName</span>
                                            <span class="task-due">Due @task.DueDate.ToString("MMM dd")</span>
                                        </div>
                                        <div class="task-note">@task.Note</div>
                                    </div>
                                    <i class="bi bi-chevron-right task-chevron"></i>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="bi bi-check2-circle empty-state-icon text-success"></i>
                                <div class="empty-state-title">Nothing needs you right now</div>
                                <div class="empty-state-description">When a person, household, or program needs attention, it shows here first.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card-growit">
                <div class="card-header">
                    <h3 class="section-title">Field notes</h3>
                </div>
                <div class="card-body p-0">
                    <div class="activity-list">
                        @if (stats.RecentActivity.Any())
                        {
                            @foreach (var item in stats.RecentActivity)
                            {
                                <div class="activity-item">
                                    <div class="activity-icon @(GetActivityClass(item.Icon))">
                                        <i class="@GetActivityIconClass(item.Icon)"></i>
                                    </div>
                                    <div class="activity-content">
                                        <div class="activity-text">@item.Description</div>
                                        <div class="activity-meta">@GetTimeAgo(item.Date)</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <p class="empty-state-description">No entries yet. Tap Log to plant your first seed — a person, a service record, or an outcome.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const string BrandGreen = "#27B062";

    // Concrete hex palettes matching the --growit-* values in app.css: Syncfusion writes
    // these into SVG attributes, so CSS variables cannot be used here.
    private sealed record ChartPalette(string AxisLabel, string GridLine, string MarkerFill);
    private static readonly ChartPalette LightPalette = new("#5c6e62", "#dce5d6", "#ffffff");
    private static readonly ChartPalette DarkPalette = new("#9fb4a6", "#24352b", "#121d17");

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private DashboardStatsDto? stats;
    private bool _isLoading = true;
    private string? _loadError;
    private bool _hasChartData;
    private string _bestMonthLabel = "-";
    private decimal _monthlyAverage;
    private string _greeting = "Welcome back";
    private string _seasonLine = "";

    private Syncfusion.Blazor.Theme _chartTheme = Syncfusion.Blazor.Theme.Bootstrap5;
    private ChartPalette _palette = LightPalette;
    private DotNetObjectReference<Home>? _selfRef;
    private int _themeListenerId;

    protected override async Task OnInitializedAsync()
    {
        await BuildGreetingAsync();
        BuildSeasonLine();
        await Refresh();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var theme = await JS.InvokeAsync<string>("blazorInterop.getTheme");
            ApplyTheme(theme);

            _selfRef = DotNetObjectReference.Create(this);
            _themeListenerId = await JS.InvokeAsync<int>("blazorInterop.registerThemeListener", _selfRef, nameof(OnThemeChangedJs));

            StateHasChanged();
        }
        catch (JSException)
        {
            // Prerender/interop not ready — the light palette default is a safe fallback.
        }
    }

    [JSInvokable]
    public Task OnThemeChangedJs(string theme)
    {
        ApplyTheme(theme);
        return InvokeAsync(StateHasChanged);
    }

    private void ApplyTheme(string? theme)
    {
        var isDark = string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase);
        _chartTheme = isDark ? Syncfusion.Blazor.Theme.Bootstrap5Dark : Syncfusion.Blazor.Theme.Bootstrap5;
        _palette = isDark ? DarkPalette : LightPalette;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_themeListenerId != 0)
            {
                await JS.InvokeVoidAsync("blazorInterop.unregisterThemeListener", _themeListenerId);
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or ObjectDisposedException or InvalidOperationException)
        {
            // Circuit already gone — nothing to clean up on the client.
        }

        _selfRef?.Dispose();
    }

    private async Task BuildGreetingAsync()
    {
        var firstName = "";
        try
        {
            var profile = await ProfileService.GetProfileAsync();
            firstName = profile?.FirstName?.Trim() ?? "";
        }
        catch
        {
            // Profile lookup is cosmetic here; fall back to the identity name below.
        }

        if (string.IsNullOrWhiteSpace(firstName) && AuthState is not null)
        {
            var authState = await AuthState;
            var identityName = authState.User.Identity?.Name ?? "";
            // Identity name can be the email address — never greet someone with one.
            if (!identityName.Contains('@'))
            {
                firstName = identityName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "";
            }
        }

        var hour = DateTime.Now.Hour;
        var timeOfDay = hour switch
        {
            >= 5 and < 12 => "Good morning",
            >= 12 and < 17 => "Good afternoon",
            _ => "Good evening"
        };

        _greeting = string.IsNullOrWhiteSpace(firstName) ? $"{timeOfDay}." : $"{timeOfDay}, {firstName}.";
    }

    private void BuildSeasonLine()
    {
        var now = DateTime.Now;
        var season = now.Month switch
        {
            3 or 4 or 5 => "Planting Season",
            6 or 7 or 8 => "Growing Season",
            9 or 10 or 11 => "Harvest Season",
            _ => "Planning Season"
        };

        _seasonLine = $"{now:MMMM d} · {season} · Week {ISOWeek.GetWeekOfYear(now)}";
    }

    private async Task Refresh()
    {
        _isLoading = true;
        _loadError = null;
        try
        {
            stats = await DashboardService.GetStatsAsync();
            BuildSummary();
        }
        catch (Exception ex)
        {
            stats = null;
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BuildSummary()
    {
        var trends = stats?.MonthlyTrends ?? new List<MonthlyMetric>();
        _hasChartData = trends.Any(t => t.Amount > 0);
        if (!_hasChartData)
        {
            _bestMonthLabel = "-";
            _monthlyAverage = 0m;
            return;
        }

        var best = trends.MaxBy(t => t.Amount);
        _bestMonthLabel = best is null ? "-" : $"{best.Month} ({best.Amount:C0})";

        var monthsWithData = trends.Count(t => t.Amount > 0);
        _monthlyAverage = monthsWithData == 0 ? 0m : trends.Sum(t => t.Amount) / monthsWithData;
    }

    private void NavigateToClient(Guid clientId)
    {
        Nav.NavigateTo($"clients/{clientId}");
    }

    private string GetTimeAgo(DateTime date)
    {
        var span = DateTime.UtcNow - date;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private string GetActivityClass(string icon)
    {
        if (icon.Contains("dollar") || icon.Contains("cash")) return "investment";
        if (icon.Contains("house") || icon.Contains("home")) return "fund";
        if (icon.Contains("people") || icon.Contains("person") || icon.Contains("flag")) return "client";
        return "fund";
    }

    private static string GetActivityIconClass(string icon) => icon switch
    {
        var value when value.Contains("dollar", StringComparison.OrdinalIgnoreCase) || value.Contains("cash", StringComparison.OrdinalIgnoreCase) => "bi bi-cash-stack",
        var value when value.Contains("flag", StringComparison.OrdinalIgnoreCase) => "bi bi-flower1",
        var value when value.Contains("house", StringComparison.OrdinalIgnoreCase) || value.Contains("home", StringComparison.OrdinalIgnoreCase) => "bi bi-house-door",
        var value when value.Contains("people", StringComparison.OrdinalIgnoreCase) || value.Contains("person", StringComparison.OrdinalIgnoreCase) => "bi bi-people",
        _ => "bi bi-activity"
    };
}
