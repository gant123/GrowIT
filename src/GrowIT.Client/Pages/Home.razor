@page "/home"
@attribute [Authorize]
@using GrowIT.Shared.DTOs
@using GrowIT.Client.Services
@using Syncfusion.Blazor.Charts 
@inject IDashboardService DashboardService
@inject NavigationManager Nav

<PageTitle>grow.IT - Impact Dashboard</PageTitle>

@if (_isLoading)
{
    <div class="loading-state">
        <div class="spinner-growit"></div>
        <p class="loading-state-text">Loading impact data...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="alert alert-danger d-flex justify-content-between align-items-center mt-4">
        <span>@_loadError</span>
        <button class="btn btn-sm btn-outline-light" @onclick="Refresh">Retry</button>
    </div>
}
else if (stats == null)
{
    <div class="alert alert-secondary mt-4">No dashboard data available.</div>
}
else
{
    <div class="dashboard fade-in">
        <PageHeader Title="Founder Survivability Dashboard" Subtitle="Protect the mission by tracking capacity, cost, and documented impact in real time.">
            <Actions>
                <button class="btn-growit btn-secondary-growit" @onclick="Refresh">
                    <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                </button>
            </Actions>
        </PageHeader>

        <div class="card-growit mb-4">
            <div class="card-body d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3">
                <div>
                    <div class="text-uppercase fw-700 text-muted" style="font-size: 0.72rem; letter-spacing: 0.08em;">Mission Operating Signal</div>
                    <h3 class="mb-1" style="font-size: 1.15rem;">Plant the seed. Measure the growth. Build the future.</h3>
                    <p class="mb-0 text-muted">grow.IT helps founders document service as financial intelligence, prove capacity, and stay funding-ready without burning out.</p>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge-growit badge-neutral" style="color: var(--growit-text-secondary) !important;">Cost Clarity</span>
                    <span class="badge-growit badge-neutral" style="color: var(--growit-text-secondary) !important;">Capacity Visibility</span>
                    <span class="badge-growit badge-neutral" style="color: var(--growit-text-secondary) !important;">Funding Readiness</span>
                </div>
            </div>
        </div>

        <div class="grid-4 mb-4">
            <KpiCard Label="Verified Service Value (YTD)" 
                     Value="@stats.TotalInvestedYtd.ToString("C0")" 
                     Icon="bi bi-heart-pulse" 
                     Color="success" 
                     TrendText="Documented in real time" 
                     TrendIcon="bi bi-arrow-up-right" 
                     TrendDirection="up" />
            
            <KpiCard Label="Households Reached" 
                     Value="@stats.HouseholdsServedYtd.ToString()" 
                     Icon="bi bi-people" 
                     Color="info" 
                     TrendText="Unique households this year" />

            <KpiCard Label="Active Service Records" 
                     Value="@stats.ActiveCases.ToString()" 
                     Icon="bi bi-folder2-open" 
                     Color="warning" 
                     TrendText="Profiles being tracked" />
            
            <KpiCard Label="Current Capacity" 
                     Value="@stats.FundsAvailable.ToString("C0")" 
                     Icon="bi bi-wallet2" 
                     Color="primary" 
                     TrendText="Available to continue serving" />
        </div>

        <div class="card-growit mb-4">
            <div class="card-header">
                <h3 class="section-title">Growth Trend: Service Becoming Structure</h3>
                <div class="chart-legend">
                    <div class="legend-item impact">
                        <span class="legend-dot"></span>
                        <span>Monthly documented service value</span>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="chart-container">
                @if (stats?.MonthlyTrends != null && stats.MonthlyTrends.Any())
                {
                    <SfChart Height="350px" Width="100%" Background="transparent">
                        <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
                        <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category" 
                                           LabelPlacement="LabelPlacement.OnTicks">
                            <ChartAxisLabelStyle Color="transparent"></ChartAxisLabelStyle>
                            <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                        </ChartPrimaryXAxis>
                        
                        <ChartPrimaryYAxis LabelFormat="${value}">
                            <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                            <ChartAxisMajorTickLines Width="0"></ChartAxisMajorTickLines>
                        </ChartPrimaryYAxis>
                        
                        <ChartTooltipSettings Enable="true" Shared="true" Fill="#0f172a"></ChartTooltipSettings>
                        
                        <ChartSeriesCollection>
                            <ChartSeries DataSource="@stats.MonthlyTrends" 
                                         XName="Month" 
                                         YName="Amount" 
                                         Type="ChartSeriesType.SplineArea" 
                                         Width="3"
                                         Fill="var(--growit-green-glow)"
                                         Opacity="0.3">
                                <ChartSeriesBorder Width="3" Color="var(--growit-green)"></ChartSeriesBorder>
                                <ChartMarker Visible="true" Width="8" Height="8" Shape="ChartShape.Circle" Fill="white">
                                    <ChartMarkerBorder Width="2" Color="var(--growit-green)"></ChartMarkerBorder>
                                </ChartMarker>
                            </ChartSeries>
                        </ChartSeriesCollection>
                    </SfChart>
                }
                else
                {
                    <div class="d-flex justify-content-center align-items-center" style="height: 350px;">
                        <p class="text-muted">No trend data available for this period.</p>
                    </div>
                }
                </div>
            </div>
        </div>

        <div class="grid-2">
            <div class="card-growit">
                <div class="card-header">
                    <h3 class="section-title">Founder Follow-Ups</h3>
                    <span class="badge-growit badge-warning">@stats!.PendingFollowUps.Count Action Items</span>
                </div>
                <div class="card-body p-0">
                    <div class="tasks-list">
                        @if (stats.PendingFollowUps.Any())
                        {
                            @foreach (var task in stats.PendingFollowUps)
                            {
                                <div class="task-item cursor-pointer" @onclick="() => NavigateToClient(task.ClientId)">
                                    <div class="task-content">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="task-action fw-600">@task.ClientName</span>
                                            <span class="badge-growit badge-neutral" style="color: var(--growit-text-secondary) !important;">Due @task.DueDate.ToString("MMM dd")</span>
                                        </div>
                                        <div class="task-client text-muted" style="color: var(--growit-text-muted) !important;">@task.Note</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="bi bi-check2-circle empty-state-icon text-success"></i>
                                <div class="empty-state-title">Clear for Today</div>
                                <div class="empty-state-description">No immediate follow-ups are due. Your team can focus on service delivery.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card-growit">
                <div class="card-header">
                    <h3 class="section-title">Recent Service Signals</h3>
                </div>
                <div class="card-body p-0">
                    <div class="activity-list">
                        @if (stats.RecentActivity.Any())
                        {
                            @foreach (var item in stats.RecentActivity)
                            {
                                <div class="activity-item">
                                    <div class="activity-icon @(GetActivityClass(item.Icon))">
                                        <i class="@GetActivityIconClass(item.Icon)"></i>
                                    </div>
                                    <div class="activity-content">
                                        <div class="activity-text">@item.Description</div>
                                        <div class="activity-meta" style="color: var(--growit-text-muted) !important;">@GetTimeAgo(item.Date)</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <p class="text-muted">No recent activity yet. Start by planting a seed investment or documenting an imprint.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardStatsDto? stats;
    private bool _isLoading = true;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    private async Task Refresh()
    {
        _isLoading = true;
        _loadError = null;
        try 
        {
            stats = await DashboardService.GetStatsAsync();
        }
        catch (Exception ex)
        {
            stats = null;
            _loadError = ex.Message;
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NavigateToClient(Guid clientId)
    {
        Nav.NavigateTo($"clients/{clientId}");
    }

    private string GetTimeAgo(DateTime date)
    {
        var span = DateTime.UtcNow - date;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private string GetActivityClass(string icon)
    {
        if (icon.Contains("dollar")) return "investment";
        if (icon.Contains("people") || icon.Contains("person") || icon.Contains("flag")) return "client";
        return "fund";
    }

    private static string GetActivityIconClass(string icon) => icon switch
    {
        var value when value.Contains("dollar", StringComparison.OrdinalIgnoreCase) => "bi bi-cash-stack",
        var value when value.Contains("flag", StringComparison.OrdinalIgnoreCase) => "bi bi-flag",
        var value when value.Contains("people", StringComparison.OrdinalIgnoreCase) || value.Contains("person", StringComparison.OrdinalIgnoreCase) => "bi bi-people",
        _ => "bi bi-activity"
    };
}
