@page "/imprints"
@using GrowIT.Shared.DTOs
@using GrowIT.Shared.Enums
@inject IImprintService ImprintService
@inject IClientService ClientService
@inject IInvestmentService InvestmentService

<PageTitle>Imprints - grow.IT</PageTitle>

<div class="imprints-page">
    <PageHeader Title="Imprints" Subtitle="Document verified outcomes and milestones so service translates into credible impact evidence.">
        <Actions>
            <button class="btn btn-primary" @onclick="OpenNewImprint">
                <i class="bi bi-plus-lg"></i>
                <span>Record Imprint</span>
            </button>
        </Actions>
    </PageHeader>

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center" role="alert">
            <div>@_loadError</div>
            <button class="btn btn-sm btn-outline-light" @onclick="ReloadImprintsAsync">Retry</button>
        </div>
    }

    <div class="imprint-kpis">
        <div class="imprint-kpi-card">
            <div class="imprint-kpi-icon total"><i class="bi bi-journal-check"></i></div>
            <div>
                <div class="imprint-kpi-label">Total Imprints</div>
                <div class="imprint-kpi-value">@_allImprints.Count</div>
            </div>
        </div>
        <div class="imprint-kpi-card">
            <div class="imprint-kpi-icon verified"><i class="bi bi-patch-check"></i></div>
            <div>
                <div class="imprint-kpi-label">Verified Outcomes</div>
                <div class="imprint-kpi-value">@VerifiedImprintCount</div>
            </div>
        </div>
        <div class="imprint-kpi-card">
            <div class="imprint-kpi-icon people"><i class="bi bi-people"></i></div>
            <div>
                <div class="imprint-kpi-label">People Documented</div>
                <div class="imprint-kpi-value">@DistinctPeopleCount</div>
            </div>
        </div>
        <div class="imprint-kpi-card">
            <div class="imprint-kpi-icon recent"><i class="bi bi-calendar-event"></i></div>
            <div>
                <div class="imprint-kpi-label">This Month</div>
                <div class="imprint-kpi-value">@ThisMonthImprintCount</div>
            </div>
        </div>
    </div>

    <section class="imprint-panel">
        <div class="imprint-panel-header">
            <div>
                <h2>Impact Records</h2>
                <p>Search, filter, and review the milestones that prove service outcomes over time.</p>
            </div>
            <div class="imprint-panel-meta">@FilteredImprints.Count() result(s)</div>
        </div>

        <div class="imprint-filters">
            <div class="imprint-filter-field imprint-filter-search">
                <label>Search</label>
                <div class="filter-input-wrap">
                    <i class="bi bi-search"></i>
                    <input type="text" class="form-control" placeholder="Search title or person" @bind="_searchQuery" @bind:event="oninput" />
                </div>
            </div>
            <div class="imprint-filter-field">
                <label>Category</label>
                <select class="form-select" @bind="_categoryFilter">
                    <option value="">All Categories</option>
                    @foreach (var cat in Enum.GetNames(typeof(ImprintCategory)))
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="imprint-loading">
                <div class="spinner-border text-primary" role="status"></div>
                <p>Loading imprints...</p>
            </div>
        }
        else if (FilteredImprints.Any())
        {
            <div class="imprint-list">
                @foreach (var imprint in FilteredImprints.OrderByDescending(i => i.Date))
                {
                    <article class="imprint-row" @key="imprint.Id">
                        <div class="imprint-row-leading">
                            <div class="imprint-row-icon @GetCategoryTone(imprint.Category)">
                                <i class="@GetCategoryIcon(imprint.Category)"></i>
                            </div>
                            <div class="imprint-row-content">
                                <h3>@imprint.Title</h3>
                                <div class="imprint-row-meta">
                                    <span><i class="bi bi-person"></i> @imprint.PersonName</span>
                                    <span><i class="bi bi-calendar3"></i> @imprint.Date.ToLocalTime().ToString("MMM d, yyyy")</span>
                                    <span class="category-chip">@FormatEnumLabel(imprint.Category.ToString())</span>
                                </div>
                            </div>
                        </div>
                        <div class="imprint-row-trailing">
                            @if (imprint.IsVerified)
                            {
                                <span class="verification-pill verified">
                                    <i class="bi bi-patch-check-fill"></i>
                                    Verified
                                </span>
                            }
                            else
                            {
                                <span class="verification-pill pending">
                                    <i class="bi bi-hourglass-split"></i>
                                    Pending Verification
                                </span>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="imprint-empty">
                <div class="imprint-empty-icon"><i class="bi bi-journal-x"></i></div>
                <h3>No imprints found</h3>
                <p>Start documenting service outcomes to build a reliable impact history for funding readiness.</p>
                <button class="btn btn-outline-primary" @onclick="OpenNewImprint">
                    <i class="bi bi-plus-lg"></i>
                    <span>Record First Imprint</span>
                </button>
            </div>
        }
    </section>
</div>

@if (_showCreateModal)
{
    <div class="modal fade show d-block growit-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content growit-modal-shell">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title">Record Imprint</h5>
                        <div class="modal-subtitle">Capture an outcome while service details are still current and verifiable.</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(_createError))
                    {
                        <div class="alert alert-danger">@_createError</div>
                    }

                    @if (_isCreateLoading)
                    {
                        <div class="text-center py-4 text-muted">Loading required data...</div>
                    }
                    else
                    {
                        <EditForm Model="_createRequest" OnValidSubmit="SubmitImprintAsync">
                            <DataAnnotationsValidator />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Client</label>
                                    <select class="form-select" value="@_createRequest.ClientId" @onchange="OnCreateClientChanged">
                                        <option value="">Select client</option>
                                        @foreach (var client in _clients.OrderBy(c => c.Name))
                                        {
                                            <option value="@client.Id">@client.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Family Member (Optional)</label>
                                    <InputSelect class="form-select" @bind-Value="_createRequest.FamilyMemberId">
                                        <option value="">Entire household</option>
                                        @foreach (var member in _selectedMembers)
                                        {
                                            <option value="@member.Id">@member.Name (@member.Relationship)</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Linked Investment (Optional)</label>
                                    <InputSelect class="form-select" @bind-Value="_createRequest.InvestmentId">
                                        <option value="">None</option>
                                        @foreach (var inv in _selectedClientInvestments)
                                        {
                                            <option value="@inv.Id">@inv.Date.ToLocalTime().ToString("MMM d") - @inv.Purpose - @inv.Amount.ToString("C0")</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Date Occurred</label>
                                    <InputDate class="form-control" @bind-Value="_createRequest.DateOccurred" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Category</label>
                                    <InputSelect class="form-select" @bind-Value="_createRequest.Category">
                                        @foreach (var cat in Enum.GetValues<ImprintCategory>())
                                        {
                                            <option value="@cat">@FormatEnumLabel(cat.ToString())</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Outcome</label>
                                    <InputSelect class="form-select" @bind-Value="_createRequest.Outcome">
                                        @foreach (var outcome in Enum.GetValues<ImpactOutcome>())
                                        {
                                            <option value="@outcome">@FormatEnumLabel(outcome.ToString())</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Title</label>
                                    <InputText class="form-control" @bind-Value="_createRequest.Title" placeholder="Example: Household retained housing for 90 days" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Notes</label>
                                    <InputTextArea class="form-control" rows="4" @bind-Value="_createRequest.Notes" placeholder="Record context, evidence source, and follow-up details." />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Follow-up Date (Optional)</label>
                                    <InputDate class="form-control" @bind-Value="_createRequest.FollowupDate" />
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <button type="button" class="btn btn-outline-secondary" @onclick="CloseCreateModal">Cancel</button>
                                <button type="submit" class="btn btn-primary" disabled="@_isSavingCreate">
                                    @if (_isSavingCreate)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <span>Save Imprint</span>
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ImprintListDto> _allImprints = new();
    private List<ClientDto> _clients = new();
    private List<FamilyMemberDto> _selectedMembers = new();
    private List<InvestmentListDto> _selectedClientInvestments = new();
    private string _searchQuery = "";
    private string _categoryFilter = "";
    private bool _isLoading = true;
    private bool _showCreateModal;
    private bool _isCreateLoading;
    private bool _isSavingCreate;
    private string _createError = "";
    private string? _loadError;
    private CreateImprintRequest _createRequest = new()
    {
        DateOccurred = DateTime.UtcNow,
        Outcome = ImpactOutcome.Improved
    };

    private int VerifiedImprintCount => _allImprints.Count(i => i.IsVerified);
    private int DistinctPeopleCount => _allImprints.Select(i => i.PersonId).Distinct().Count();
    private int ThisMonthImprintCount => _allImprints.Count(i => i.Date.ToUniversalTime() >= new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1));

    protected override async Task OnInitializedAsync() => await ReloadImprintsAsync();

    private async Task ReloadImprintsAsync()
    {
        _isLoading = true;
        _loadError = null;
        try
        {
            _allImprints = await ImprintService.GetImprintsAsync();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            _allImprints = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private IEnumerable<ImprintListDto> FilteredImprints
    {
        get
        {
            var query = _allImprints.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                query = query.Where(i =>
                    (i.Title?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (i.PersonName?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            if (!string.IsNullOrEmpty(_categoryFilter) && Enum.TryParse<ImprintCategory>(_categoryFilter, out var cat))
            {
                query = query.Where(i => i.Category == cat);
            }

            return query;
        }
    }

    private async Task OpenNewImprint()
    {
        _showCreateModal = true;
        _isCreateLoading = true;
        _createError = "";
        _selectedMembers.Clear();
        _selectedClientInvestments.Clear();
        _createRequest = new CreateImprintRequest
        {
            DateOccurred = DateTime.UtcNow,
            Outcome = ImpactOutcome.Improved
        };

        try
        {
            _clients = await ClientService.GetAllClientsAsync();
        }
        catch (Exception ex)
        {
            _createError = $"Failed to load clients: {ex.Message}";
        }
        finally
        {
            _isCreateLoading = false;
        }
    }

    private async Task OnCreateClientChanged(ChangeEventArgs e)
    {
        _selectedMembers.Clear();
        _selectedClientInvestments.Clear();
        _createRequest.FamilyMemberId = null;
        _createRequest.InvestmentId = null;

        if (!Guid.TryParse(e.Value?.ToString(), out var clientId))
        {
            _createRequest.ClientId = Guid.Empty;
            return;
        }

        _createRequest.ClientId = clientId;

        try
        {
            var detail = await ClientService.GetClientDetailAsync(clientId);
            _selectedMembers = detail?.HouseholdMembers ?? new();

            var investments = await InvestmentService.GetInvestmentsAsync(new InvestmentQueryParams
            {
                PersonId = clientId,
                PageNumber = 1,
                PageSize = 100
            });
            _selectedClientInvestments = investments?.Items ?? new();
        }
        catch (Exception ex)
        {
            _createError = $"Failed to load client details: {ex.Message}";
            _selectedMembers.Clear();
            _selectedClientInvestments.Clear();
        }
    }

    private async Task SubmitImprintAsync()
    {
        _createError = "";

        if (_createRequest.ClientId == Guid.Empty)
        {
            _createError = "Client is required.";
            return;
        }

        _isSavingCreate = true;
        try
        {
            var created = await ImprintService.CreateImprintAsync(_createRequest);
            if (created == null)
            {
                _createError = "Failed to save imprint.";
                return;
            }

            CloseCreateModal();
            await ReloadImprintsAsync();
        }
        catch (Exception ex)
        {
            _createError = ex.Message;
        }
        finally
        {
            _isSavingCreate = false;
        }
    }

    private void CloseCreateModal()
    {
        _showCreateModal = false;
        _createError = "";
    }

    private static string FormatEnumLabel(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return value;
        return System.Text.RegularExpressions.Regex.Replace(value, "([a-z])([A-Z])", "$1 $2");
    }

    private static string GetCategoryIcon(ImprintCategory category) => category switch
    {
        ImprintCategory.HousingStability => "bi bi-house-check",
        ImprintCategory.FinancialStability => "bi bi-cash-stack",
        ImprintCategory.EmploymentStability => "bi bi-briefcase",
        ImprintCategory.FoodSecurity => "bi bi-basket2",
        ImprintCategory.PhysicalHealth or ImprintCategory.MentalHealth or ImprintCategory.HealthcareAccess => "bi bi-heart-pulse",
        ImprintCategory.EducationalAttainment or ImprintCategory.SkillDevelopment or ImprintCategory.Certification => "bi bi-mortarboard",
        ImprintCategory.FamilyWellbeing or ImprintCategory.ChildWelfare or ImprintCategory.ParentingSkills => "bi bi-people",
        ImprintCategory.SocialConnection or ImprintCategory.CommunityEngagement or ImprintCategory.CivicParticipation => "bi bi-diagram-3",
        ImprintCategory.Independence or ImprintCategory.GoalAchievement or ImprintCategory.LifeSkills => "bi bi-graph-up-arrow",
        _ => "bi bi-check2-circle"
    };

    private static string GetCategoryTone(ImprintCategory category) => category switch
    {
        ImprintCategory.FinancialStability or ImprintCategory.EmploymentStability or ImprintCategory.FoodSecurity => "tone-amber",
        ImprintCategory.HousingStability or ImprintCategory.HealthcareAccess => "tone-blue",
        ImprintCategory.GoalAchievement or ImprintCategory.Independence or ImprintCategory.SkillDevelopment => "tone-green",
        ImprintCategory.ChildWelfare or ImprintCategory.MentalHealth => "tone-danger",
        _ => "tone-neutral"
    };
}
