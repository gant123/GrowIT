@page "/investments"
@using GrowIT.Client.Services
@using GrowIT.Client.Shared
@using GrowIT.Shared.DTOs
@using GrowIT.Shared.Enums
@inject IInvestmentService InvestmentService
@inject IRoleAccessService RoleAccessService
@inject IJSRuntime JS

<PageTitle>Investments - grow.IT</PageTitle>

<div class="dashboard fade-in mt-4">
    <PageHeader Title="Service Investments" Subtitle="Document real-time service costs to build capacity, repeatability, and funding readiness.">
        <Actions>
            @if (_canDocumentServiceRecords)
            {
                <button class="btn-growit btn-primary-growit" @onclick="OpenNewInvestment">
                    <i class="bi bi-plus-lg me-2"></i>Plant Seed
                </button>
            }
        </Actions>
    </PageHeader>

    @if (!_canDocumentServiceRecords)
    {
        <div class="alert alert-info mb-3">You have read-only access to investments. `Case Manager`, `Manager`, `Admin`, or `Owner` can create investment records.</div>
    }

    <div class="card-growit mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="search-box">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" placeholder="Search by person or purpose..." @bind="SearchQuery" @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-md-4">
                    <select class="form-select-growit" @bind="StatusFilter">
                        <option value="">All Statuses</option>
                        @foreach (var status in Enum.GetValues<GrowIT.Shared.Enums.InvestmentStatus>())
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="loading-state">
            <div class="spinner-growit"></div>
            <p class="loading-state-text">Loading investments...</p>
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_actionError))
        {
            <div class="alert alert-danger mb-3">@_actionError</div>
        }

        <div class="card-growit">
            <div class="table-responsive">
                <table class="table-growit">
                    <thead>
                        <tr>
                            <th class="ps-4">Date</th>
                            <th>Person</th>
                            <th>Purpose</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in FilteredInvestments)
                        {
                            <tr>
                                <td class="ps-4">@inv.Date.ToString("MMM d, yyyy")</td>
                                <td class="fw-600 text-primary">@inv.PersonName</td>
                                <td>@inv.Purpose</td>
                                <td class="fw-700">@inv.Amount.ToString("C0")</td>
                                <td>
                                    <span class="badge-growit @GetBadge(inv.Status)">@inv.Status</span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (_canApproveServiceInvestments && inv.Status == GrowIT.Shared.Enums.InvestmentStatus.Pending)
                                    {
                                        <button class="btn-growit btn-primary-growit btn-sm me-1"
                                                disabled="@(_busyInvestmentId == inv.Id)"
                                                @onclick="() => Approve(inv.Id)">Approve</button>
                                    }
                                    @if (_canApproveServiceInvestments && inv.Status == GrowIT.Shared.Enums.InvestmentStatus.Approved)
                                    {
                                        <button class="btn-growit btn-secondary-growit btn-sm me-1"
                                                disabled="@(_busyInvestmentId == inv.Id)"
                                                @onclick="() => Disburse(inv.Id)">Disburse</button>
                                    }
                                    <button class="btn-growit btn-ghost-growit btn-sm" @onclick="() => OpenDetails(inv.Id)">Details</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<PlantSeedModal @bind-Show="showPlantSeedModal" OnSeedPlanted="ReloadInvestments" />
<InvestmentDetailModal @bind-Show="showInvestmentDetailModal"
                       InvestmentId="selectedInvestmentId"
                       CanApproveDisburse="_canApproveServiceInvestments"
                       CanDelete="_canApproveServiceInvestments"
                       OnChanged="ReloadInvestments" />

@code {
    private List<InvestmentListDto> _investments = new();
    private bool _isLoading = true;
    private bool showPlantSeedModal;
    private bool showInvestmentDetailModal;
    private Guid selectedInvestmentId;
    private Guid? _busyInvestmentId;
    private string? _actionError;
    private bool _canDocumentServiceRecords;
    private bool _canApproveServiceInvestments;
    private string SearchQuery { get; set; } = "";
    private string StatusFilter { get; set; } = "";

    private IEnumerable<InvestmentListDto> FilteredInvestments
    {
        get
        {
            var query = _investments.AsEnumerable();
            if (!string.IsNullOrEmpty(SearchQuery))
                query = query.Where(i => i.PersonName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || i.Purpose.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));
            
            // FIXED: Fully qualified name
            if (!string.IsNullOrEmpty(StatusFilter) && Enum.TryParse<GrowIT.Shared.Enums.InvestmentStatus>(StatusFilter, out var status))
                query = query.Where(i => i.Status == status);

            return query.OrderByDescending(i => i.Date);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var access = await RoleAccessService.GetAccessAsync();
        _canDocumentServiceRecords = access.CanDocumentServiceRecords;
        _canApproveServiceInvestments = access.CanApproveServiceInvestments;
        await ReloadInvestments();
    }

    private async Task ReloadInvestments()
    {
        try
        {
            var result = await InvestmentService.GetInvestmentsAsync(new InvestmentQueryParams());
            _investments = result.Items;
        }
        finally { _isLoading = false; }
    }

 private async Task Approve(Guid id)
{
    if (!_canApproveServiceInvestments) return;
    _actionError = null;
    _busyInvestmentId = id;
    try
    {
        await InvestmentService.ApproveInvestmentAsync(id, "Current User");
        await ReloadInvestments();
    }
    catch (Exception ex)
    {
        _actionError = ex.Message;
    }
    finally
    {
        _busyInvestmentId = null;
    }
}

    private async Task Disburse(Guid id)
    {
        if (!_canApproveServiceInvestments) return;
        _actionError = null;
        _busyInvestmentId = id;
        try
        {
            if (!await JS.InvokeAsync<bool>("confirm", "Mark this investment as disbursed?"))
            {
                return;
            }

            await InvestmentService.DisburseInvestmentAsync(id);
            await ReloadInvestments();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _busyInvestmentId = null;
        }
    }

    private void OpenNewInvestment()
    {
        if (!_canDocumentServiceRecords) return;
        showPlantSeedModal = true;
    }
    private void OpenDetails(Guid id)
    {
        selectedInvestmentId = id;
        showInvestmentDetailModal = true;
    }

    // FIXED: Fully qualified name
    private string GetBadge(GrowIT.Shared.Enums.InvestmentStatus status) => status switch
    {
        GrowIT.Shared.Enums.InvestmentStatus.Approved => "bg-success",
        GrowIT.Shared.Enums.InvestmentStatus.Disbursed => "bg-info",
        GrowIT.Shared.Enums.InvestmentStatus.Pending => "bg-warning text-dark",
        GrowIT.Shared.Enums.InvestmentStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
