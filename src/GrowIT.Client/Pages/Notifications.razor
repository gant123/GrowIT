@page "/notifications"
@attribute [Authorize]

<div style="max-width: 1100px; margin: 0 auto;">
    <PageHeader Title="Notifications" Subtitle="Alerts and activity notifications" />

    <div class="card-growit">
        <div class="card-body">
            <p style="margin-bottom: 8px;">Header notifications now route here correctly.</p>
            <p style="margin-bottom: 0; color: var(--growit-text-secondary);">
                This is a placeholder inbox page until notifications are backed by a dedicated API endpoint.
            </p>
        </div>
    </div>
</div>
