@page "/partners"
@layout PublicLayout

<PageTitle>Partners - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Partners</span>
        <h1>Partner with Grow.IT to help organizations become easier to fund.</h1>
        <p>We work with people and teams who help founders strengthen structure, reporting, governance, funding readiness, and operational follow-through.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>Implementation Partners</h2>
                <p>Help organizations onboard data, define programs, clean up records, and build repeatable reporting routines.</p>
            </article>
            <article class="contact-card">
                <h2>Funding & Advisory Partners</h2>
                <p>Use Grow.IT evidence to support grant preparation, donor strategy, loan readiness, and board development.</p>
            </article>
            <article class="contact-card">
                <h2>Community Ecosystem Partners</h2>
                <p>Connect founders to services that strengthen compliance, accounting, communications, technology, or program delivery.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Tell us how you support mission-led founders.</h2>
            <p>We are looking for partners who make the founder's job easier and help turn good work into usable proof.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Partnership%20Inquiry" class="btn btn-primary">Contact Partnerships</a>
                <a href="/about" class="btn btn-outline">About Grow.IT</a>
            </div>
        </div>
    </section>
</div>
