@page "/partners"
@layout PublicLayout

<PageTitle>Partners - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Company</span>
        <h1>Partners</h1>
        <p>We collaborate with implementation teams, advisory groups, and ecosystem partners serving mission-led organizations.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>Implementation Partners</h2>
                <p>Support onboarding, process design, and operating cadence rollout for client organizations.</p>
            </article>
            <article class="contact-card">
                <h2>Advisory Partners</h2>
                <p>Guide governance, compliance strategy, and funding-readiness frameworks for scaling operations.</p>
            </article>
            <article class="contact-card">
                <h2>Service Ecosystem Partners</h2>
                <p>Connect complementary services that improve mission delivery and organizational durability.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Explore partnership opportunities.</h2>
            <p>Tell us where your team fits and how we can collaborate.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Partnership%20Inquiry" class="btn btn-primary">Contact Partnerships</a>
                <a href="/about" class="btn btn-outline">Learn About grow.IT</a>
            </div>
        </div>
    </section>
</div>
