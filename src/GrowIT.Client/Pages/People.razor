@page "/people"
@using GrowIT.Client.Services
@using GrowIT.Shared.DTOs
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@inject IClientService ClientService
@inject NavigationManager Navigation

<PageTitle>People - grow.IT</PageTitle>

<div class="dashboard fade-in mt-4">
    <PageHeader Title="People Directory" Subtitle="Manage active households and profiles.">
        <Actions>
            <button class="btn-growit btn-primary-growit" @onclick="OpenAddPerson">
                <span class="oi oi-plus me-2"></span>Add Person
            </button>
        </Actions>
    </PageHeader>

    <div class="card-growit mb-4">
        <div class="card-body p-3">
            <div class="search-box">
                <span class="oi oi-magnifying-glass search-icon"></span>
                <input type="text" placeholder="Search by name, email or phone..." 
                       @bind="SearchQuery" @bind:event="oninput" />
            </div>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="loading-state">
            <div class="spinner-growit"></div>
            <p class="loading-state-text">Loading directory...</p>
        </div>
    }
    else
    {
        <div class="card-growit">
            <div class="card-body p-0">
                <SfGrid TValue="ClientDto"
                        @ref="_peopleGrid"
                        DataSource="@FilteredPeople.ToList()"
                        AllowPaging="true"
                        AllowSorting="true"
                        AllowFiltering="true"
                        AllowResizing="true"
                        AllowExcelExport="true"
                        AllowTextWrap="true"
                        ShowColumnChooser="true"
                        Toolbar="@GridToolbarItems"
                        Height="560">
                    <GridPageSettings PageSize="10"></GridPageSettings>
                    <GridFilterSettings Type="FilterType.Menu"></GridFilterSettings>
                    <GridTextWrapSettings WrapMode="WrapMode.Content"></GridTextWrapSettings>
                    <GridEvents TValue="ClientDto" OnToolbarClick="OnPeopleToolbarClick"></GridEvents>
                    <GridColumns>
                        <GridColumn Field=@nameof(ClientDto.Name) HeaderText="Name" Width="280" ClipMode="ClipMode.EllipsisWithTooltip">
                            <Template>
                                @{
                                    var person = (context as ClientDto)!;
                                }
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-growit avatar-md">
                                        @GetInitials(person.Name)
                                    </div>
                                    <div>
                                        <div class="fw-600">@person.Name</div>
                                        <div class="small text-muted">@person.Email</div>
                                    </div>
                                </div>
                            </Template>
                        </GridColumn>
                        <GridColumn Field=@nameof(ClientDto.LifePhase) HeaderText="Phase" Width="140" TextAlign="TextAlign.Center">
                            <Template>
                                @{
                                    var person = (context as ClientDto)!;
                                }
                                <span class="badge-growit @GetPhaseClass(person.LifePhase.ToString())">
                                    @person.LifePhase
                                </span>
                            </Template>
                        </GridColumn>
                        <GridColumn Field=@nameof(ClientDto.StabilityScore) HeaderText="Stability" Width="180" TextAlign="TextAlign.Center">
                            <Template>
                                @{
                                    var person = (context as ClientDto)!;
                                }
                                <div class="stability-indicator" style="max-width: 150px;">
                                    <span class="small fw-700">@person.StabilityScore</span>
                                    <div class="stability-bar">
                                        <div class="stability-fill" style="width: @($"{person.StabilityScore * 10}%")"></div>
                                    </div>
                                </div>
                            </Template>
                        </GridColumn>
                        <GridColumn Field=@nameof(ClientDto.Phone) HeaderText="Contact" Width="220" ClipMode="ClipMode.EllipsisWithTooltip">
                            <Template>
                                @{
                                    var person = (context as ClientDto)!;
                                }
                                <div class="small">
                                    <div class="text-muted">@person.Phone</div>
                                    <div class="text-muted">@person.Email</div>
                                </div>
                            </Template>
                        </GridColumn>
                        <GridColumn HeaderText="Actions" Width="140" AllowFiltering="false" AllowSorting="false" TextAlign="TextAlign.Right">
                            <Template>
                                @{
                                    var person = (context as ClientDto)!;
                                }
                                <button class="btn-growit btn-ghost-growit btn-sm" @onclick="() => ViewPerson(person.Id)">View</button>
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </SfGrid>
            </div>
        </div>
        <div class="mt-3 text-muted small text-end">
            Showing @FilteredPeople.Count() of @_allPeople.Count records
        </div>
    }
</div>

@code {
    private List<ClientDto> _allPeople = new();
    private SfGrid<ClientDto>? _peopleGrid;
    private bool _isLoading = true;
    private string SearchQuery { get; set; } = "";
    private static readonly List<string> GridToolbarItems = ["Search", "ColumnChooser", "ExcelExport"];

    // Client-side filtering logic
    private IEnumerable<ClientDto> FilteredPeople
    {
        get
        {
            var query = _allPeople.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchQuery))
            {
                query = query.Where(p => 
                    (p.Name?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (p.Email?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (p.Phone?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false)
                );
            }

            return query.OrderBy(p => p.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _allPeople = await ClientService.GetAllClientsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ViewPerson(Guid id) => Navigation.NavigateTo($"/clients/{id}"); // Point to new Client Detail route
    private void OpenAddPerson() => Navigation.NavigateTo("/clients/create");

    private async Task OnPeopleToolbarClick(ClickEventArgs args)
    {
        if (_peopleGrid is null) return;
        if (args.Item?.Id?.Contains("excelexport", StringComparison.OrdinalIgnoreCase) == true)
        {
            await _peopleGrid.ExportToExcelAsync();
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length > 1 ? $"{parts[0][0]}{parts[1][0]}".ToUpper() : name[0].ToString().ToUpper();
    }

    private string GetPhaseClass(string phase) => phase?.ToLower() switch
    {
        "crisis" => "badge-phase-crisis",
        "stable" => "badge-phase-stable",
        "thriving" => "badge-phase-thriving",
        _ => "badge-neutral"
    };

}
