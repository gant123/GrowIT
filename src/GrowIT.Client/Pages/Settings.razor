    private async Task LoadSecurityAttemptsAsync()
    {
        _isLoadingSecurity = true;
        try
        {
            var query = new SecurityAccessAttemptQueryParams
            {
                Take = 250,
                Ip = string.IsNullOrWhiteSpace(_securityIpSearch) ? null : _securityIpSearch.Trim()
            };

            _securityAttempts = (await AdminService.GetSecurityAccessAttemptsAsync(query, _cts.Token))
                .OrderByDescending(a => a.OccurredAt)
                .ToList();
        }
        catch (Exception ex)
        {
            _pageError = ex.Message;
        }
        finally
