@page "/settings"
@using GrowIT.Shared.DTOs
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Navigations
@inject IAdminService AdminService
@inject IRoleAccessService RoleAccessService
@inject IJSRuntime JS

<PageTitle>Settings - grow.IT</PageTitle>

<div class="settings-page">
    <PageHeader Title="Settings" Subtitle="Manage organization configuration, team access, and operational controls." />

    @if (!string.IsNullOrWhiteSpace(_pageError))
    {
        <div class="alert alert-danger settings-page-alert d-flex justify-content-between align-items-center" role="alert">
            <div>@_pageError</div>
            <button class="btn btn-sm btn-outline-light" @onclick="LoadAllAsync">Retry</button>
        </div>
    }

    <section class="settings-overview-shell">
        <div class="settings-overview-hero">
            <div class="settings-overview-copy">
                <span class="settings-overview-kicker">Workspace Control Center</span>
                <h2>Run the operational backbone behind your team, access model, and delivery governance.</h2>
                <p>
                    Settings is where organizational identity, team permissions, invite lifecycle, diagnostics, and security readiness stay aligned.
                    Keep this area clean, current, and tightly controlled.
                </p>
                <div class="settings-overview-badges">
                    <span class="settings-overview-badge"><i class="bi bi-shield-check"></i> Identity-managed access</span>
                    <span class="settings-overview-badge"><i class="bi bi-activity"></i> Live diagnostics</span>
                    <span class="settings-overview-badge"><i class="bi bi-diagram-3"></i> Tenant-aware controls</span>
                </div>
            </div>

            <div class="settings-ops-spotlight">
                <div class="settings-ops-card">
                    <span class="settings-ops-label">Current focus</span>
                    <strong>@GetActiveTabTitle()</strong>
                    <p>@GetActiveTabDescription()</p>
                </div>
                <div class="settings-ops-grid">
                    <div class="settings-ops-metric">
                        <span>Users</span>
                        <strong>@_users.Count</strong>
                    </div>
                    <div class="settings-ops-metric">
                        <span>Pending invites</span>
                        <strong>@PendingInviteCount</strong>
                    </div>
                    <div class="settings-ops-metric">
                        <span>Unread alerts</span>
                        <strong>@InviteActivityUnreadCount</strong>
                    </div>
                    <div class="settings-ops-metric">
                        <span>Theme</span>
                        <strong>Adaptive</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="settings-kpis">
        <div class="settings-kpi-card">
            <div class="settings-kpi-icon org"><i class="bi bi-building"></i></div>
            <div>
                <div class="settings-kpi-label">Organization</div>
                <div class="settings-kpi-value">@(_organization?.Name ?? "Loading...")</div>
            </div>
        </div>
        <div class="settings-kpi-card">
            <div class="settings-kpi-icon users"><i class="bi bi-people"></i></div>
            <div>
                <div class="settings-kpi-label">Active Users</div>
                <div class="settings-kpi-value">@_users.Count(u => u.IsActive)</div>
            </div>
        </div>
        <div class="settings-kpi-card">
            <div class="settings-kpi-icon pending"><i class="bi bi-envelope-paper"></i></div>
            <div>
                <div class="settings-kpi-label">Pending Invites</div>
                <div class="settings-kpi-value">@PendingInviteCount</div>
            </div>
        </div>
        <div class="settings-kpi-card">
            <div class="settings-kpi-icon modules"><i class="bi bi-bell"></i></div>
            <div>
                <div class="settings-kpi-label">Invite Alerts</div>
                <div class="settings-kpi-value">@InviteActivityUnreadCount</div>
            </div>
        </div>
        </div>
    </section>

    @if (!_hasSettingsAccess)
    {
        <section class="settings-access-card" role="alert">
            <div class="settings-access-icon"><i class="bi bi-shield-lock"></i></div>
            <div>
                <h2>Settings access is restricted.</h2>
                <p>This workspace is limited to `Admin`, `Manager`, or `Owner` roles. Request elevated access if you need to manage configuration or team controls.</p>
            </div>
        </section>
    }
    else
    {
        <section class="settings-workspace-shell">
            <aside class="settings-rail">
                <div class="settings-rail-header">
                    <span class="settings-rail-kicker">Sections</span>
                    <h2>Admin workspace</h2>
                    <p>Select the control surface you need. Each section is tuned for a different layer of operational governance.</p>
                </div>

                <div class="settings-tabbar" role="tablist" aria-label="Settings sections">
                    <button class="settings-tab @(ActiveTab == "organization" ? "active" : null)" @onclick="@(() => SetActiveTab("organization"))">
                        <span class="settings-tab-icon"><i class="bi bi-buildings"></i></span>
                        <span class="settings-tab-content">
                            <span class="settings-tab-title">Organization</span>
                            <span class="settings-tab-copy">Identity, profile, and enabled operating modules</span>
                        </span>
                    </button>
                    <button class="settings-tab @(ActiveTab == "users" ? "active" : null)" @onclick="@(() => SetActiveTab("users"))">
                        <span class="settings-tab-icon"><i class="bi bi-people"></i></span>
                        <span class="settings-tab-content">
                            <span class="settings-tab-title">Users & Roles</span>
                            <span class="settings-tab-copy">@_users.Count user accounts with role-based access control</span>
                        </span>
                    </button>
                    <button class="settings-tab @(ActiveTab == "invites" ? "active" : null)" @onclick="@(() => SetActiveTab("invites"))">
                        <span class="settings-tab-icon"><i class="bi bi-envelope-paper"></i></span>
                        <span class="settings-tab-content">
                            <span class="settings-tab-title">Invites</span>
                            <span class="settings-tab-copy">@PendingInviteCount pending invites and @InviteActivityUnreadCount unread activity items</span>
                        </span>
                    </button>
                    <button class="settings-tab @(ActiveTab == "security" ? "active" : null)" @onclick="@(() => SetActiveTab("security"))">
                        <span class="settings-tab-icon"><i class="bi bi-shield-check"></i></span>
                        <span class="settings-tab-content">
                            <span class="settings-tab-title">Security</span>
                            <span class="settings-tab-copy">Diagnostics, audit trail, seed tooling, and readiness controls</span>
                        </span>
                    </button>
                </div>

                <div class="settings-rail-footnote">
                    <span class="settings-rail-footnote-label">Current section</span>
                    <strong>@GetActiveTabTitle()</strong>
                    <p>@GetActiveTabDescription()</p>
                </div>
            </aside>

            <div class="settings-main-stage">
                @if (_isLoading)
                {
                    <div class="settings-loading">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p>Loading settings workspace...</p>
                    </div>
                }
                else
                {
                    <div class="settings-stage-header">
                        <div>
                            <span class="settings-stage-kicker">@GetActiveTabEyebrow()</span>
                            <h2>@GetActiveTabTitle()</h2>
                            <p>@GetActiveTabDescription()</p>
                        </div>
                        <div class="settings-stage-meta">
                            <span class="settings-stage-chip">
                                <i class="bi bi-building"></i>
                                @_organization?.Name
                            </span>
                            <span class="settings-stage-chip">
                                <i class="bi bi-stars"></i>
                                Enterprise workspace
                            </span>
                        </div>
                    </div>

                    @if (ActiveTab == "organization")
                    {
                        <section class="settings-panel">
                <div class="settings-panel-header">
                    <div>
                        <h2>Organization Profile</h2>
                        <p>Update the organization profile and module configuration used throughout the platform.</p>
                    </div>
                </div>
                <div class="settings-panel-body">
                    @if (!string.IsNullOrWhiteSpace(_orgSaveMessage))
                    {
                        <div class="alert alert-success">@_orgSaveMessage</div>
                    }
                    @if (_organizationEdit is not null)
                    {
                        <EditForm Model="_organizationEdit" OnValidSubmit="SaveOrganizationAsync">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Organization Name</label>
                                    <InputText class="form-control" @bind-Value="_organizationEdit.Name" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Contact Email</label>
                                    <InputText class="form-control" @bind-Value="_organizationEdit.ContactEmail" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Organization Type</label>
                                    <InputText class="form-control" @bind-Value="_organizationEdit.OrganizationType" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Organization Size</label>
                                    <InputText class="form-control" @bind-Value="_organizationEdit.OrganizationSize" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Address</label>
                                    <InputTextArea class="form-control" rows="3" @bind-Value="_organizationEdit.Address" />
                                </div>
                            </div>

                            <div class="module-grid mt-4">
                                <label class="module-card @(_organizationEdit.TrackPeople ? "selected" : null)">
                                    <InputCheckbox @bind-Value="_organizationEdit.TrackPeople" />
                                    <div>
                                        <strong><i class="bi bi-people"></i> People / Clients</strong>
                                        <span>Case files, households, and member profiles</span>
                                    </div>
                                </label>
                                <label class="module-card @(_organizationEdit.TrackInvestments ? "selected" : null)">
                                    <InputCheckbox @bind-Value="_organizationEdit.TrackInvestments" />
                                    <div>
                                        <strong><i class="bi bi-cash-stack"></i> Investments</strong>
                                        <span>Service costs, disbursements, and funding usage</span>
                                    </div>
                                </label>
                                <label class="module-card @(_organizationEdit.TrackOutcomes ? "selected" : null)">
                                    <InputCheckbox @bind-Value="_organizationEdit.TrackOutcomes" />
                                    <div>
                                        <strong><i class="bi bi-check2-circle"></i> Outcomes / Imprints</strong>
                                        <span>Milestones, evidence, and impact verification</span>
                                    </div>
                                </label>
                                <label class="module-card @(_organizationEdit.TrackPrograms ? "selected" : null)">
                                    <InputCheckbox @bind-Value="_organizationEdit.TrackPrograms" />
                                    <div>
                                        <strong><i class="bi bi-folder2-open"></i> Programs</strong>
                                        <span>Service models, capacity assumptions, and categories</span>
                                    </div>
                                </label>
                            </div>

                            <div class="d-flex justify-content-end mt-4">
                                <button class="btn btn-primary" type="submit" disabled="@_isSavingOrganization">
                                    @if (_isSavingOrganization)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <span>Save Organization Settings</span>
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
                        </section>
                    }

                    @if (ActiveTab == "users")
                    {
                        <section class="settings-panel">
                <div class="settings-panel-header">
                    <div>
                        <h2>Users & Roles</h2>
                        <p>Manage roles and access state for users in your organization. Invite new team members from the Invites tab.</p>
                    </div>
                </div>
                <div class="settings-panel-body">
                    @if (!string.IsNullOrWhiteSpace(_userActionMessage))
                    {
                        <div class="alert alert-success">@_userActionMessage</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_userActionError))
                    {
                        <div class="alert alert-danger">@_userActionError</div>
                    }

                    <SfGrid TValue="AdminUserListItemDto"
                            @ref="_usersGrid"
                            DataSource="@_users"
                            CssClass="settings-grid settings-grid-users"
                            AllowPaging="true"
                            AllowSorting="true"
                            AllowFiltering="true"
                            AllowResizing="true"
                            AllowExcelExport="true"
                            AllowTextWrap="true"
                            ShowColumnChooser="true"
                            Toolbar="@GridToolbarItems"
                            Width="100%">
                        <GridPageSettings PageSize="8"></GridPageSettings>
                        <GridFilterSettings Type="FilterType.Excel"></GridFilterSettings>
                        <GridTextWrapSettings WrapMode="WrapMode.Content"></GridTextWrapSettings>
                        <GridEvents TValue="AdminUserListItemDto" OnToolbarClick="OnUsersGridToolbarClick"></GridEvents>
                        <GridColumns>
                            <GridColumn Field=@nameof(AdminUserListItemDto.FullName) HeaderText="Name" Width="200"></GridColumn>
                            <GridColumn Field=@nameof(AdminUserListItemDto.Email) HeaderText="Email" Width="240"></GridColumn>
                            <GridColumn HeaderText="Status" Width="130">
                                <Template>
                                    @{
                                        var user = (context as AdminUserListItemDto)!;
                                    }
                                    <span class="user-status-pill @(user.IsActive ? "active" : "inactive")">
                                        @(user.IsActive ? "Active" : "Inactive")
                                    </span>
                                </Template>
                            </GridColumn>
                            <GridColumn HeaderText="Role" Width="220">
                                <Template>
                                    @{
                                        var user = (context as AdminUserListItemDto)!;
                                    }
                                    <div class="user-role-editor">
                                        <select class="form-select form-select-sm"
                                                value="@GetRoleDraft(user)"
                                                @onchange="e => SetRoleDraft(user.Id, e.Value?.ToString())"
                                                disabled="@IsUserBusy(user.Id)">
                                            @foreach (var role in RoleOptions)
                                            {
                                                <option value="@role">@role</option>
                                            }
                                            @if (!IsPresetRole(GetRoleDraft(user)))
                                            {
                                                <option value="@GetRoleDraft(user)">@GetRoleDraft(user)</option>
                                            }
                                        </select>
                                        <button class="btn btn-sm btn-outline-primary"
                                                disabled="@(!CanSaveRole(user) || IsUserBusy(user.Id))"
                                                @onclick="() => SaveUserRoleAsync(user)">
                                            Save
                                        </button>
                                    </div>
                                </Template>
                            </GridColumn>
                            <GridColumn HeaderText="Joined" Width="150">
                                <Template>
                                    @{
                                        var user = (context as AdminUserListItemDto)!;
                                    }
                                    <span>@user.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                                </Template>
                            </GridColumn>
                            <GridColumn HeaderText="Actions" Width="200">
                                <Template>
                                    @{
                                        var user = (context as AdminUserListItemDto)!;
                                    }
                                    <div class="grid-action-row">
                                        @if (user.IsActive)
                                        {
                                            <button class="btn btn-sm btn-outline-danger"
                                                    disabled="@IsUserBusy(user.Id)"
                                                    @onclick="() => DeactivateUserAsync(user)">
                                                Deactivate
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-success"
                                                    disabled="@IsUserBusy(user.Id)"
                                                    @onclick="() => ReactivateUserAsync(user)">
                                                Reactivate
                                            </button>
                                        }
                                    </div>
                                </Template>
                            </GridColumn>
                        </GridColumns>
                    </SfGrid>
                </div>
                        </section>
                    }

                    @if (ActiveTab == "invites")
                    {
                        <section class="settings-panel">
                <div class="settings-panel-header">
                    <div>
                        <h2>Invite Team Members</h2>
                        <p>Send secure invitations so staff can join your organization workspace without creating a new tenant.</p>
                    </div>
                </div>
                <div class="settings-panel-body">
                    @if (!string.IsNullOrWhiteSpace(_inviteMessage))
                    {
                        <div class="alert alert-success">@_inviteMessage</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_inviteError))
                    {
                        <div class="alert alert-danger">@_inviteError</div>
                    }

                    <div class="invite-create-card">
                        <h3>Send Invitation</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <InputText class="form-control" @bind-Value="_newInvite.Email" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">First Name</label>
                                <InputText class="form-control" @bind-Value="_newInvite.FirstName" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Last Name</label>
                                <InputText class="form-control" @bind-Value="_newInvite.LastName" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Role</label>
                                <InputText class="form-control" @bind-Value="_newInvite.Role" placeholder="Admin / Manager / Case Manager" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Expires (days)</label>
                                <InputNumber class="form-control" @bind-Value="_newInvite.ExpiresInDays" />
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <button class="btn btn-primary" @onclick="CreateInviteAsync" disabled="@_isSendingInvite">
                                    @if (_isSendingInvite)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <span>Send Invite</span>
                                </button>
                                @if (!string.IsNullOrWhiteSpace(_lastInviteLink))
                                {
                                    <button class="btn btn-outline-secondary ms-2" @onclick="CopyLastInviteLinkAsync">
                                        <i class="bi bi-clipboard"></i>
                                        <span>Copy Link</span>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="invite-grid-wrap mt-4">
                        <SfGrid TValue="OrganizationInviteListItemDto"
                                @ref="_invitesGrid"
                                DataSource="@_invites"
                                CssClass="settings-grid settings-grid-invites"
                                AllowPaging="true"
                                AllowSorting="true"
                                AllowFiltering="true"
                                AllowResizing="true"
                                AllowExcelExport="true"
                                AllowTextWrap="true"
                                ShowColumnChooser="true"
                                Toolbar="@GridToolbarItems"
                                Width="100%">
                            <GridPageSettings PageSize="8"></GridPageSettings>
                            <GridFilterSettings Type="FilterType.Excel"></GridFilterSettings>
                            <GridTextWrapSettings WrapMode="WrapMode.Content"></GridTextWrapSettings>
                            <GridEvents TValue="OrganizationInviteListItemDto" OnToolbarClick="OnInvitesGridToolbarClick"></GridEvents>
                            <GridColumns>
                                <GridColumn Field=@nameof(OrganizationInviteListItemDto.Email) HeaderText="Email" Width="220"></GridColumn>
                                <GridColumn HeaderText="Invitee" Width="180">
                                    <Template>
                                        @{
                                            var invite = (context as OrganizationInviteListItemDto)!;
                                            var name = string.Join(" ", new[] { invite.FirstName, invite.LastName }.Where(s => !string.IsNullOrWhiteSpace(s))).Trim();
                                        }
                                        <span>@(string.IsNullOrWhiteSpace(name) ? "Not provided" : name)</span>
                                    </Template>
                                </GridColumn>
                                <GridColumn Field=@nameof(OrganizationInviteListItemDto.Role) HeaderText="Role" Width="130"></GridColumn>
                                <GridColumn HeaderText="Status" Width="130">
                                    <Template>
                                        @{
                                            var invite = (context as OrganizationInviteListItemDto)!;
                                        }
                                        <span class="invite-status-pill @GetInviteStatusClass(invite.Status)">@invite.Status</span>
                                    </Template>
                                </GridColumn>
                                <GridColumn HeaderText="Created" Width="150">
                                    <Template>
                                        @{
                                            var invite = (context as OrganizationInviteListItemDto)!;
                                        }
                                        <span>@invite.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                                    </Template>
                                </GridColumn>
                                <GridColumn HeaderText="Expires" Width="150">
                                    <Template>
                                        @{
                                            var invite = (context as OrganizationInviteListItemDto)!;
                                        }
                                        <span>@invite.ExpiresAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                                    </Template>
                                </GridColumn>
                                <GridColumn HeaderText="Actions" Width="200">
                                    <Template>
                                        @{
                                            var invite = (context as OrganizationInviteListItemDto)!;
                                        }
                                        <div class="grid-action-row">
                                            @if (invite.Status == "Pending" || invite.Status == "Expired")
                                            {
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ResendInviteAsync(invite.Id)">Resend</button>
                                            }
                                            @if (invite.Status != "Accepted" && invite.Status != "Revoked")
                                            {
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RevokeInviteAsync(invite.Id)">Revoke</button>
                                            }
                                        </div>
                                    </Template>
                                </GridColumn>
                            </GridColumns>
                        </SfGrid>
                    </div>

                    <div class="invite-audit-card mt-4">
                        <div class="invite-audit-header">
                            <div>
                                <h3>Invite Activity Notifications</h3>
                                <p>Audit trail alerts for invite creation, resend, revocation, and acceptance.</p>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary"
                                    disabled="@(_inviteActivity.Count == 0 || InviteActivityUnreadCount == 0)"
                                    @onclick="MarkInviteActivityReadAllAsync">
                                Mark all read
                            </button>
                        </div>

                        @if (_inviteActivity.Count == 0)
                        {
                            <div class="invite-audit-empty">
                                <i class="bi bi-bell-slash"></i>
                                <span>No invite activity yet.</span>
                            </div>
                        }
                        else
                        {
                            <div class="invite-audit-list">
                                @foreach (var item in _inviteActivity)
                                {
                                    <div class="invite-audit-item @(item.IsRead ? "read" : "unread")">
                                        <div class="invite-audit-dot" aria-hidden="true"></div>
                                        <div class="invite-audit-content">
                                            <div class="invite-audit-title-row">
                                                <strong>@item.Title</strong>
                                                <span>@item.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                                            </div>
                                            <p>@item.Message</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
                        </section>
                    }

                    @if (ActiveTab == "security")
                    {
                        <section class="settings-panel">
                <div class="settings-panel-header">
                    <div>
                        <h2>Security & Access Controls</h2>
                        <p>Foundational security controls are available now. Advanced policies can be layered in next.</p>
                    </div>
                </div>
                <div class="settings-panel-body">
                    <div class="seed-tools-card mb-4">
                        <div>
                            <h3>Demo Data</h3>
                            <p>Seed sample households, clients, funds, programs, investments, imprints, and growth plans for UI and workflow testing.</p>
                            @if (!string.IsNullOrWhiteSpace(_seedDataMessage))
                            {
                                <div class="alert alert-success py-2 mb-0 mt-2">@_seedDataMessage</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_seedDataError))
                            {
                                <div class="alert alert-danger py-2 mb-0 mt-2">@_seedDataError</div>
                            }
                        </div>
                        @if (_canSeedDemoData)
                        {
                            <button class="btn btn-outline-primary"
                                    disabled="@_isSeedingDemoData"
                                    @onclick="SeedDemoDataAsync">
                                @if (_isSeedingDemoData)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                <span>Seed Demo Data</span>
                            </button>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Admin/Owner Only</span>
                        }
                    </div>

                    <div class="email-diagnostics-card mb-4">
                        <div class="email-diagnostics-header">
                            <div>
                                <h3>Email Delivery Diagnostics</h3>
                                <p>Validate SMTP configuration and send a live test email from this environment.</p>
                            </div>
                            <button class="btn btn-outline-secondary btn-sm"
                                    disabled="@_isLoadingEmailDiagnostics"
                                    @onclick="RefreshEmailDiagnosticsAsync">
                                @if (_isLoadingEmailDiagnostics)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                <span>Refresh</span>
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_emailDiagnosticsError))
                        {
                            <div class="alert alert-danger py-2 mb-3">@_emailDiagnosticsError</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_testEmailMessage))
                        {
                            <div class="alert @(_testEmailSucceeded ? "alert-success" : "alert-warning") py-2 mb-3">@_testEmailMessage</div>
                        }

                        <div class="email-diagnostics-grid">
                            <div class="diag-item">
                                <span>Status</span>
                                <strong>@(_emailDiagnostics?.StatusSummary ?? "Loading...")</strong>
                            </div>
                            <div class="diag-item">
                                <span>Environment</span>
                                <strong>@(_emailDiagnostics?.EnvironmentName ?? "-")</strong>
                            </div>
                            <div class="diag-item">
                                <span>SMTP Host</span>
                                <strong>@(_emailDiagnostics?.SmtpHost ?? "Not configured")</strong>
                            </div>
                            <div class="diag-item">
                                <span>Port / SSL</span>
                                <strong>@($"{_emailDiagnostics?.SmtpPort?.ToString() ?? "-"} / {(_emailDiagnostics?.UseSsl is null ? "-" : (_emailDiagnostics.UseSsl.Value ? "SSL" : "No SSL"))}")</strong>
                            </div>
                            <div class="diag-item">
                                <span>SMTP User</span>
                                <strong>@(_emailDiagnostics?.SmtpUserMasked ?? "-")</strong>
                            </div>
                            <div class="diag-item">
                                <span>Password</span>
                                <strong>@((_emailDiagnostics?.HasPassword ?? false) ? "Configured" : "Missing")</strong>
                            </div>
                            <div class="diag-item">
                                <span>From Email</span>
                                <strong>@(_emailDiagnostics?.FromEmail ?? "-")</strong>
                            </div>
                            <div class="diag-item">
                                <span>Dev Fallback</span>
                                <strong>@((_emailDiagnostics?.DevFileFallbackEnabled ?? false) ? "Enabled" : "Disabled")</strong>
                            </div>
                        </div>

                        <div class="email-test-form mt-3">
                            <div class="row g-2">
                                <div class="col-md-5">
                                    <label class="form-label">Send Test To</label>
                                    <InputText class="form-control" @bind-Value="_testEmailRequest.ToEmail" placeholder="Defaults to your account email" />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label">Subject (optional)</label>
                                    <InputText class="form-control" @bind-Value="_testEmailRequest.Subject" placeholder="grow.IT SMTP Test" />
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button class="btn btn-primary w-100"
                                            disabled="@_isSendingTestEmail"
                                            @onclick="SendTestEmailAsync">
                                        @if (_isSendingTestEmail)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        <span>Send Test</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="system-diagnostics-card mb-4">
                        <div class="email-diagnostics-header">
                            <div>
                                <h3>System Diagnostics</h3>
                                <p>Beta readiness checks for database, migrations, storage, scheduler, and report health.</p>
                            </div>
                            <button class="btn btn-outline-secondary btn-sm"
                                    disabled="@_isLoadingSystemDiagnostics"
                                    @onclick="RefreshSystemDiagnosticsAsync">
                                @if (_isLoadingSystemDiagnostics)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                <span>Refresh</span>
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_systemDiagnosticsError))
                        {
                            <div class="alert alert-danger py-2 mb-3">@_systemDiagnosticsError</div>
                        }

                        <div class="diag-item mb-3">
                            <span>Overall Status</span>
                            <strong>
                                @if (_systemDiagnostics is null)
                                {
                                    <text>Loading...</text>
                                }
                                else
                                {
                                    <span class="badge-growit @GetDiagnosticBadgeClass(_systemDiagnostics.StatusSummary)">@_systemDiagnostics.StatusSummary</span>
                                }
                            </strong>
                            @if (_systemDiagnostics is not null)
                            {
                                <div class="small text-muted mt-1">
                                    Checked @FormatLocalTime(_systemDiagnostics.CheckedAtUtc) in @_systemDiagnostics.EnvironmentName
                                </div>
                            }
                        </div>

                        @if (_systemDiagnostics?.Checks?.Count > 0)
                        {
                            <div class="system-diagnostics-list">
                                @foreach (var check in _systemDiagnostics.Checks)
                                {
                                    <div class="system-check-row">
                                        <div class="system-check-main">
                                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                                <strong>@check.Label</strong>
                                                <span class="badge-growit @GetDiagnosticBadgeClass(check.Status)">@check.Status</span>
                                            </div>
                                            <div class="small text-muted">@check.Message</div>
                                            @if (!string.IsNullOrWhiteSpace(check.Details))
                                            {
                                                <div class="small text-muted mt-1" title="@check.Details">@TruncateText(check.Details, 180)</div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="security-grid">
                        <div class="security-card">
                            <div class="security-icon"><i class="bi bi-shield-lock"></i></div>
                            <div>
                                <h3>Password Resets</h3>
                                <p>Users can self-serve password resets via the secure token-based reset flow.</p>
                            </div>
                            <span class="security-status ready">Enabled</span>
                        </div>
                        <div class="security-card">
                            <div class="security-icon"><i class="bi bi-building-lock"></i></div>
                            <div>
                                <h3>Tenant Isolation</h3>
                                <p>Tenant-scoped query filters and endpoint validation protect organization boundaries.</p>
                            </div>
                            <span class="security-status ready">Enabled</span>
                        </div>
                        <div class="security-card">
                            <div class="security-icon"><i class="bi bi-envelope-check"></i></div>
                            <div>
                                <h3>Invite Expiration</h3>
                                <p>New org invites expire automatically and can be revoked or resent from this workspace.</p>
                            </div>
                            <span class="security-status ready">Enabled</span>
                        </div>
                        <div class="security-card">
                            <div class="security-icon"><i class="bi bi-key"></i></div>
                            <div>
                                <h3>Advanced MFA Policy</h3>
                                <p>Planned next: enforced MFA, session controls, and role policy templates.</p>
                            </div>
                            <span class="security-status planned">Planned</span>
                        </div>
                    </div>

                    <div class="audit-log-panel mt-4">
                        <div class="audit-log-header">
                            <div>
                                <h3>Audit Trail</h3>
                                <p>Review recent create/update/delete events recorded across the workspace.</p>
                            </div>
                            <div class="audit-log-actions">
                                <select class="form-select form-select-sm" @bind="_auditTableFilter">
                                    <option value="">All tables</option>
                                    @foreach (var tableName in _auditTableOptions)
                                    {
                                        <option value="@tableName">@tableName</option>
                                    }
                                </select>
                                <select class="form-select form-select-sm" @bind="_auditActionFilter">
                                    <option value="">All actions</option>
                                    <option value="Create">Create</option>
                                    <option value="Update">Update</option>
                                    <option value="Delete">Delete</option>
                                    <option value="Budget Adjustment">Budget Adjustment</option>
                                </select>
                                <button class="btn btn-outline-secondary btn-sm" disabled="@_isLoadingAuditLogs" @onclick="RefreshAuditLogsAsync">
                                    @if (_isLoadingAuditLogs)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <span>Refresh</span>
                                </button>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_auditLogError))
                        {
                            <div class="alert alert-danger py-2 mb-3">@_auditLogError</div>
                        }

                        <SfGrid TValue="AdminAuditLogItemDto"
                                @ref="_auditLogsGrid"
                                DataSource="@FilteredAuditLogs"
                                CssClass="settings-grid settings-grid-audit"
                                AllowPaging="true"
                                AllowSorting="true"
                                AllowFiltering="true"
                                AllowResizing="true"
                                AllowExcelExport="true"
                                AllowTextWrap="true"
                                ShowColumnChooser="true"
                                Toolbar="@GridToolbarItems"
                                Width="100%">
                            <GridPageSettings PageSize="10"></GridPageSettings>
                            <GridFilterSettings Type="FilterType.Excel"></GridFilterSettings>
                            <GridTextWrapSettings WrapMode="WrapMode.Content"></GridTextWrapSettings>
                            <GridEvents TValue="AdminAuditLogItemDto" OnToolbarClick="OnAuditLogsGridToolbarClick"></GridEvents>
                            <GridColumns>
                                <GridColumn HeaderText="When" Width="170">
                                    <Template>
                                        @{
                                            var log = (context as AdminAuditLogItemDto)!;
                                        }
                                        <span>@log.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                                    </Template>
                                </GridColumn>
                                <GridColumn Field=@nameof(AdminAuditLogItemDto.ActionType) HeaderText="Action" Width="150"></GridColumn>
                                <GridColumn Field=@nameof(AdminAuditLogItemDto.TableName) HeaderText="Table" Width="160"></GridColumn>
                                <GridColumn Field=@nameof(AdminAuditLogItemDto.UserName) HeaderText="User" Width="190"></GridColumn>
                                <GridColumn HeaderText="Summary" Width="300">
                                    <Template>
                                        @{
                                            var log = (context as AdminAuditLogItemDto)!;
                                        }
                                        <span>@(string.IsNullOrWhiteSpace(log.Summary) ? $"{log.ActionType} on {log.TableName}" : log.Summary)</span>
                                    </Template>
                                </GridColumn>
                                <GridColumn HeaderText="Record" Width="220">
                                    <Template>
                                        @{
                                            var log = (context as AdminAuditLogItemDto)!;
                                        }
                                        <code>@log.RecordId</code>
                                    </Template>
                                </GridColumn>
                            </GridColumns>
                        </SfGrid>
                    </div>
                </div>
                        </section>
                    }
                }
            </div>
        </section>
    }
</div>

@code {
    private string ActiveTab { get; set; } = "organization";
    private bool _isLoading = true;
    private bool _isSavingOrganization;
    private bool _isSendingInvite;
    private bool _isSeedingDemoData;
    private bool _isLoadingAuditLogs;
    private bool _isLoadingEmailDiagnostics;
    private bool _isLoadingSystemDiagnostics;
    private bool _isSendingTestEmail;
    private bool _testEmailSucceeded;
    private bool _hasSettingsAccess = true;
    private bool _canSeedDemoData;
    private string? _pageError;
    private string? _orgSaveMessage;
    private string? _userActionMessage;
    private string? _userActionError;
    private string? _inviteMessage;
    private string? _inviteError;
    private string? _lastInviteLink;
    private string? _seedDataMessage;
    private string? _seedDataError;
    private string? _auditLogError;
    private string? _emailDiagnosticsError;
    private string? _systemDiagnosticsError;
    private string? _testEmailMessage;

    private OrganizationSettingsDto? _organization;
    private EmailDiagnosticsDto? _emailDiagnostics;
    private SystemDiagnosticsDto? _systemDiagnostics;
    private UpdateOrganizationSettingsRequest? _organizationEdit;
    private SfGrid<AdminUserListItemDto>? _usersGrid;
    private SfGrid<OrganizationInviteListItemDto>? _invitesGrid;
    private SfGrid<AdminAuditLogItemDto>? _auditLogsGrid;
    private List<AdminUserListItemDto> _users = new();
    private List<OrganizationInviteListItemDto> _invites = new();
    private List<InviteAuditNotificationDto> _inviteActivity = new();
    private List<AdminAuditLogItemDto> _auditLogs = new();
    private CreateOrganizationInviteRequest _newInvite = new() { ExpiresInDays = 7, Role = "Member" };
    private readonly HashSet<Guid> _busyUserIds = new();
    private readonly Dictionary<Guid, string> _roleDrafts = new();
    private SendTestEmailRequest _testEmailRequest = new();
    private static readonly List<object> GridToolbarItems =
    [
        "Search",
        "ColumnChooser",
        new ItemModel
        {
            Id = "growit-excelexport",
            Text = "Export Excel",
            TooltipText = "Export grid to Excel",
            PrefixIcon = "bi bi-file-earmark-excel growit-grid-toolbar-icon"
        }
    ];
    private static readonly string[] RoleOptions = ["Admin", "Manager", "Case Manager", "Analyst", "Member"];
    private string _auditTableFilter = "";
    private string _auditActionFilter = "";

    private int PendingInviteCount => _invites.Count(i => string.Equals(i.Status, "Pending", StringComparison.OrdinalIgnoreCase));
    private int InviteActivityUnreadCount => _inviteActivity.Count(i => !i.IsRead);
    private List<string> _auditTableOptions => _auditLogs.Select(l => l.TableName).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
    private List<AdminAuditLogItemDto> FilteredAuditLogs => _auditLogs
        .Where(l => string.IsNullOrWhiteSpace(_auditTableFilter) || string.Equals(l.TableName, _auditTableFilter, StringComparison.OrdinalIgnoreCase))
        .Where(l => string.IsNullOrWhiteSpace(_auditActionFilter) || string.Equals(l.ActionType, _auditActionFilter, StringComparison.OrdinalIgnoreCase))
        .ToList();
    protected override async Task OnInitializedAsync()
    {
        var access = await RoleAccessService.GetAccessAsync();
        _hasSettingsAccess = access.CanManageAdminWorkspace;
        _canSeedDemoData = access.CanSeedDemoData;

        if (!_hasSettingsAccess)
        {
            _isLoading = false;
            return;
        }

        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        _isLoading = true;
        _pageError = null;
        _orgSaveMessage = null;
        try
        {
            var orgTask = AdminService.GetOrganizationAsync();
            var usersTask = AdminService.GetUsersAsync();
            var invitesTask = AdminService.GetInvitesAsync();
            var inviteActivityTask = AdminService.GetInviteActivityAsync(30);
            var auditLogsTask = AdminService.GetAuditLogsAsync(100);
            var emailDiagnosticsTask = AdminService.GetEmailDiagnosticsAsync();
            var systemDiagnosticsTask = AdminService.GetSystemDiagnosticsAsync();
            await Task.WhenAll(orgTask, usersTask, invitesTask, inviteActivityTask, auditLogsTask, emailDiagnosticsTask, systemDiagnosticsTask);

            _organization = await orgTask;
            _organizationEdit = new UpdateOrganizationSettingsRequest
            {
                Name = _organization.Name,
                Address = _organization.Address,
                ContactEmail = _organization.ContactEmail,
                OrganizationType = _organization.OrganizationType,
                OrganizationSize = _organization.OrganizationSize,
                TrackPeople = _organization.TrackPeople,
                TrackInvestments = _organization.TrackInvestments,
                TrackOutcomes = _organization.TrackOutcomes,
                TrackPrograms = _organization.TrackPrograms
            };

            _users = await usersTask;
            InitializeRoleDrafts(_users);
            _invites = await invitesTask;
            _inviteActivity = await inviteActivityTask;
            _auditLogs = await auditLogsTask;
            _emailDiagnostics = await emailDiagnosticsTask;
            _systemDiagnostics = await systemDiagnosticsTask;
        }
        catch (Exception ex)
        {
            _pageError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnUsersGridToolbarClick(ClickEventArgs args)
    {
        if (_usersGrid is null) return;
        if (args.Item?.Id?.Contains("excelexport", StringComparison.OrdinalIgnoreCase) == true)
        {
            await _usersGrid.ExportToExcelAsync();
        }
    }

    private async Task OnInvitesGridToolbarClick(ClickEventArgs args)
    {
        if (_invitesGrid is null) return;
        if (args.Item?.Id?.Contains("excelexport", StringComparison.OrdinalIgnoreCase) == true)
        {
            await _invitesGrid.ExportToExcelAsync();
        }
    }

    private async Task OnAuditLogsGridToolbarClick(ClickEventArgs args)
    {
        if (_auditLogsGrid is null) return;
        if (args.Item?.Id?.Contains("excelexport", StringComparison.OrdinalIgnoreCase) == true)
        {
            await _auditLogsGrid.ExportToExcelAsync();
        }
    }

    private async Task SaveOrganizationAsync()
    {
        if (_organizationEdit is null) return;

        _isSavingOrganization = true;
        _orgSaveMessage = null;
        _pageError = null;
        try
        {
            _organization = await AdminService.UpdateOrganizationAsync(_organizationEdit);
            _orgSaveMessage = "Organization settings saved.";
        }
        catch (Exception ex)
        {
            _pageError = ex.Message;
        }
        finally
        {
            _isSavingOrganization = false;
        }
    }

    private async Task CreateInviteAsync()
    {
        ClearTransientMessages();
        _inviteError = null;
        _inviteMessage = null;
        _lastInviteLink = null;

        if (string.IsNullOrWhiteSpace(_newInvite.Email))
        {
            _inviteError = "Email is required.";
            return;
        }

        _isSendingInvite = true;
        try
        {
            var response = await AdminService.CreateInviteAsync(_newInvite);
            _inviteMessage = response.Message;
            _lastInviteLink = response.InviteLink;
            _newInvite = new CreateOrganizationInviteRequest { ExpiresInDays = 7, Role = "Member" };
            _invites = await AdminService.GetInvitesAsync();
            _inviteActivity = await AdminService.GetInviteActivityAsync(30);
            ActiveTab = "invites";
        }
        catch (Exception ex)
        {
            _inviteError = ex.Message;
        }
        finally
        {
            _isSendingInvite = false;
        }
    }

    private async Task ResendInviteAsync(Guid inviteId)
    {
        ClearTransientMessages();
        _inviteError = null;
        _inviteMessage = null;
        try
        {
            var response = await AdminService.ResendInviteAsync(inviteId);
            _inviteMessage = response.Message;
            _lastInviteLink = response.InviteLink;
            _invites = await AdminService.GetInvitesAsync();
            _inviteActivity = await AdminService.GetInviteActivityAsync(30);
        }
        catch (Exception ex)
        {
            _inviteError = ex.Message;
        }
    }

    private async Task RevokeInviteAsync(Guid inviteId)
    {
        ClearTransientMessages();
        _inviteError = null;
        _inviteMessage = null;
        try
        {
            await AdminService.RevokeInviteAsync(inviteId);
            _inviteMessage = "Invite revoked.";
            _invites = await AdminService.GetInvitesAsync();
            _inviteActivity = await AdminService.GetInviteActivityAsync(30);
        }
        catch (Exception ex)
        {
            _inviteError = ex.Message;
        }
    }

    private async Task CopyLastInviteLinkAsync()
    {
        if (string.IsNullOrWhiteSpace(_lastInviteLink)) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _lastInviteLink);
        try
        {
            await JS.InvokeVoidAsync("blazorInterop.showToast", "Invite link copied", "success");
        }
        catch
        {
            // Clipboard succeeded; toast is optional.
        }
    }

    private static string GetInviteStatusClass(string status) => status.ToLowerInvariant() switch
    {
        "pending" => "pending",
        "accepted" => "accepted",
        "expired" => "expired",
        "revoked" => "revoked",
        _ => "unknown"
    };

    private string GetActiveTabTitle() => ActiveTab switch
    {
        "organization" => "Organization",
        "users" => "Users & Roles",
        "invites" => "Invites",
        "security" => "Security",
        _ => "Settings"
    };

    private string GetActiveTabEyebrow() => ActiveTab switch
    {
        "organization" => "Workspace Identity",
        "users" => "Access Control",
        "invites" => "Invite Operations",
        "security" => "Operational Readiness",
        _ => "Administration"
    };

    private string GetActiveTabDescription() => ActiveTab switch
    {
        "organization" => "Maintain the workspace profile, tenant metadata, and the operating modules your team relies on across the platform.",
        "users" => "Manage team membership, role alignment, and who is allowed to operate inside sensitive admin surfaces.",
        "invites" => "Track pending invitations, resend or revoke access, and monitor invite activity before new users enter the workspace.",
        "security" => "Review diagnostics, audit flow, demo tooling, and service readiness from one controlled operations surface.",
        _ => "Manage organization settings and administrative controls."
    };

    private void SetActiveTab(string tab)
    {
        ActiveTab = tab;
        ClearTransientMessages();
    }

    private string GetRoleDraft(AdminUserListItemDto user)
    {
        if (_roleDrafts.TryGetValue(user.Id, out var role) && !string.IsNullOrWhiteSpace(role))
            return role;

        _roleDrafts[user.Id] = user.Role;
        return user.Role;
    }

    private void SetRoleDraft(Guid userId, string? value)
    {
        _roleDrafts[userId] = string.IsNullOrWhiteSpace(value) ? "Member" : value.Trim();
        _userActionError = null;
        _userActionMessage = null;
    }

    private bool CanSaveRole(AdminUserListItemDto user) =>
        !string.Equals(GetRoleDraft(user).Trim(), user.Role?.Trim(), StringComparison.OrdinalIgnoreCase);

    private bool IsUserBusy(Guid userId) => _busyUserIds.Contains(userId);

    private static bool IsPresetRole(string role) =>
        RoleOptions.Any(r => string.Equals(r, role, StringComparison.OrdinalIgnoreCase));

    private async Task SaveUserRoleAsync(AdminUserListItemDto user)
    {
        var newRole = GetRoleDraft(user);
        if (string.IsNullOrWhiteSpace(newRole)) return;

        ClearTransientMessages();
        _busyUserIds.Add(user.Id);
        try
        {
            var updated = await AdminService.UpdateUserRoleAsync(user.Id, new UpdateAdminUserRoleRequest { Role = newRole });
            ReplaceUser(updated);
            _roleDrafts[user.Id] = updated.Role;
            _userActionMessage = $"Updated role for {updated.FullName}.";
        }
        catch (Exception ex)
        {
            _userActionError = ex.Message;
        }
        finally
        {
            _busyUserIds.Remove(user.Id);
        }
    }

    private async Task DeactivateUserAsync(AdminUserListItemDto user)
    {
        ClearTransientMessages();
        _busyUserIds.Add(user.Id);
        try
        {
            var updated = await AdminService.DeactivateUserAsync(user.Id);
            ReplaceUser(updated);
            _userActionMessage = $"{updated.FullName} has been deactivated.";
        }
        catch (Exception ex)
        {
            _userActionError = ex.Message;
        }
        finally
        {
            _busyUserIds.Remove(user.Id);
        }
    }

    private async Task ReactivateUserAsync(AdminUserListItemDto user)
    {
        ClearTransientMessages();
        _busyUserIds.Add(user.Id);
        try
        {
            var updated = await AdminService.ReactivateUserAsync(user.Id);
            ReplaceUser(updated);
            _userActionMessage = $"{updated.FullName} has been reactivated.";
        }
        catch (Exception ex)
        {
            _userActionError = ex.Message;
        }
        finally
        {
            _busyUserIds.Remove(user.Id);
        }
    }

    private async Task MarkInviteActivityReadAllAsync()
    {
        ClearTransientMessages();
        try
        {
            await AdminService.MarkInviteActivityReadAllAsync();
            _inviteActivity = _inviteActivity
                .Select(i => { i.IsRead = true; return i; })
                .ToList();
            _inviteMessage = "Invite activity marked as read.";
        }
        catch (Exception ex)
        {
            _inviteError = ex.Message;
        }
    }

    private async Task SeedDemoDataAsync()
    {
        ClearTransientMessages();
        _seedDataError = null;
        _seedDataMessage = null;
        _isSeedingDemoData = true;
        try
        {
            var result = await AdminService.SeedDemoDataAsync();
            _seedDataMessage = $"{result.Message} " +
                $"Programs:{result.ProgramsCreated}, Funds:{result.FundsCreated}, Households:{result.HouseholdsCreated}, " +
                $"Clients:{result.ClientsCreated}, Members:{result.FamilyMembersCreated}, Investments:{result.InvestmentsCreated}, " +
                $"Imprints:{result.ImprintsCreated}, Plans:{result.GrowthPlansCreated}.";

            await LoadAllAsync();
            ActiveTab = "security";
        }
        catch (Exception ex)
        {
            _seedDataError = ex.Message;
        }
        finally
        {
            _isSeedingDemoData = false;
        }
    }

    private async Task RefreshAuditLogsAsync()
    {
        _auditLogError = null;
        _isLoadingAuditLogs = true;
        try
        {
            _auditLogs = await AdminService.GetAuditLogsAsync(100);
        }
        catch (Exception ex)
        {
            _auditLogError = ex.Message;
        }
        finally
        {
            _isLoadingAuditLogs = false;
        }
    }

    private async Task RefreshEmailDiagnosticsAsync()
    {
        _emailDiagnosticsError = null;
        _isLoadingEmailDiagnostics = true;
        try
        {
            _emailDiagnostics = await AdminService.GetEmailDiagnosticsAsync();
        }
        catch (Exception ex)
        {
            _emailDiagnosticsError = ex.Message;
        }
        finally
        {
            _isLoadingEmailDiagnostics = false;
        }
    }

    private async Task RefreshSystemDiagnosticsAsync()
    {
        _systemDiagnosticsError = null;
        _isLoadingSystemDiagnostics = true;
        try
        {
            _systemDiagnostics = await AdminService.GetSystemDiagnosticsAsync();
        }
        catch (Exception ex)
        {
            _systemDiagnosticsError = ex.Message;
        }
        finally
        {
            _isLoadingSystemDiagnostics = false;
        }
    }

    private async Task SendTestEmailAsync()
    {
        _emailDiagnosticsError = null;
        _testEmailMessage = null;
        _testEmailSucceeded = false;
        _isSendingTestEmail = true;
        try
        {
            var response = await AdminService.SendTestEmailAsync(_testEmailRequest);
            _testEmailSucceeded = response.Succeeded;
            _testEmailMessage = response.Succeeded
                ? $"Test email sent to {response.TargetEmail} via {response.DeliveryMode}.{(string.IsNullOrWhiteSpace(response.FallbackFilePath) ? "" : $" File: {response.FallbackFilePath}")}"
                : response.Message;

            await RefreshEmailDiagnosticsAsync();
            await RefreshSystemDiagnosticsAsync();
        }
        catch (Exception ex)
        {
            _testEmailMessage = ex.Message;
        }
        finally
        {
            _isSendingTestEmail = false;
        }
    }

    private void ReplaceUser(AdminUserListItemDto updated)
    {
        var index = _users.FindIndex(u => u.Id == updated.Id);
        if (index >= 0)
        {
            _users[index] = updated;
        }
        else
        {
            _users.Add(updated);
        }

        _users = _users
            .OrderBy(u => u.FullName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(u => u.Email, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void InitializeRoleDrafts(IEnumerable<AdminUserListItemDto> users)
    {
        _roleDrafts.Clear();
        foreach (var user in users)
        {
            _roleDrafts[user.Id] = user.Role;
        }
    }

    private void ClearTransientMessages()
    {
        _orgSaveMessage = null;
        _userActionMessage = null;
        _userActionError = null;
        _inviteMessage = null;
        _inviteError = null;
        _seedDataMessage = null;
        _seedDataError = null;
        _auditLogError = null;
        _emailDiagnosticsError = null;
        _systemDiagnosticsError = null;
    }

    private static string GetDiagnosticBadgeClass(string? status) => status?.Trim().ToLowerInvariant() switch
    {
        "healthy" => "badge-success",
        "warning" => "badge-warning",
        "unhealthy" => "badge-danger",
        _ => "badge-neutral"
    };

    private static string FormatLocalTime(DateTime utc) => utc.ToLocalTime().ToString("MMM d, yyyy h:mm tt");

    private static string TruncateText(string? value, int max)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        var text = value.Trim();
        return text.Length <= max ? text : text[..(max - 1)] + "…";
    }
}
