@page "/templates"
@layout PublicLayout

<PageTitle>Report Templates - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Resources</span>
        <h1>Report Templates</h1>
        <p>Starter structures for impact reporting, program review, and leadership operating cadence.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>Board Brief Template</h2>
                <p>Summarize outcomes, risks, and execution priorities in a governance-ready monthly format.</p>
            </article>
            <article class="contact-card">
                <h2>Funder Progress Template</h2>
                <p>Communicate service delivery, milestones, and variance drivers with clean, auditable structure.</p>
            </article>
            <article class="contact-card">
                <h2>Operations Health Template</h2>
                <p>Track staffing pressure, service continuity, and capacity indicators across program lines.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Want templates aligned to your grant model?</h2>
            <p>We can configure your workspace with reporting outputs matched to your stakeholders.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Template%20Configuration%20Request" class="btn btn-primary">Request Setup</a>
                <a href="/docs" class="btn btn-outline">Read Documentation</a>
            </div>
        </div>
    </section>
</div>
