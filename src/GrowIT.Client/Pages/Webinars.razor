@page "/webinars"
@layout PublicLayout

<PageTitle>Webinars - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Learning</span>
        <h1>Webinars</h1>
        <p>Training sessions for leaders and operators building durable, funder-ready operations.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>Operator Readiness</h2>
                <p>How to transition from survival mode to predictable program operations and reporting discipline.</p>
            </article>
            <article class="contact-card">
                <h2>Funding Readiness Systems</h2>
                <p>Translate service activity into board- and funder-facing evidence without adding admin drag.</p>
            </article>
            <article class="contact-card">
                <h2>Implementation Playbooks</h2>
                <p>Practical rollout plans for executive sponsors, managers, and frontline teams.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Host a private workshop for your team.</h2>
            <p>We can run a focused session around your mission model and reporting goals.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Private%20Workshop%20Request" class="btn btn-primary">Request Workshop</a>
                <a href="/register" class="btn btn-outline">Start Trial Workspace</a>
            </div>
        </div>
    </section>
</div>
