@page "/webinars"
@layout PublicLayout

<PageTitle>Webinars - grow.IT</PageTitle>

<div class="contact-page footer-info-page">
    <section class="contact-hero">
        <span class="contact-kicker">Learning</span>
        <h1>Practical sessions for building funding-ready operations.</h1>
        <p>Our sessions focus on the work founders actually need help with: organizing data, explaining service value, and knowing what proof funders expect.</p>
    </section>

    <section class="contact-grid-section">
        <div class="contact-grid">
            <article class="contact-card">
                <h2>From mission story to funder language</h2>
                <p>Learn how simple founder answers can become stronger organization overviews, program descriptions, and impact statements.</p>
            </article>
            <article class="contact-card">
                <h2>Showing the dollar value of help</h2>
                <p>Walk through programs, funds, service records, and cost-per-person visibility inside Grow.IT.</p>
            </article>
            <article class="contact-card">
                <h2>ASC readiness walkthrough</h2>
                <p>Understand what the score is measuring, why tiers should be hard to earn, and how saved data moves readiness forward.</p>
            </article>
        </div>
    </section>

    <section class="contact-cta">
        <div class="contact-cta-card">
            <h2>Want a private workshop for your team?</h2>
            <p>We can tailor a session around your board, programs, donor goals, and funding-readiness questions.</p>
            <div class="contact-cta-actions">
                <a href="/contact?subject=Private%20Workshop%20Request" class="btn btn-primary">Request Workshop</a>
                <a href="/register" class="btn btn-outline">Start Trial Workspace</a>
            </div>
        </div>
    </section>
</div>
